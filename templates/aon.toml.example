# aon.toml — per-team config for ai-over-nats engine.
# Single source of truth for roster, paths, NATS endpoints.
# Card 236 — schema v0.1. Bumped on incompatible changes.

[engine]
version = "0.1"

[team]
name           = "@TEAM_NAME@"
account        = "@TEAM_NAME@"          # NATS account name (often == team.name)
kv_bucket      = "@TEAM_NAME@-state"
subject_prefix = "org.@TEAM_NAME@"      # optional; default = "org.<team.name>"

[nats]
# url is machine-local — set in ~/.aon/teams/<team>/aon-local.toml, not here.
ws_url     = "wss://nats.example.com"   # optional; cloudflared / public endpoint
admin_user = "sysadmin"

# ── Roles ──
# kind ∈ { manager, generalist, specialist }
# domain: primary skill area (terraform, python, ui, go, …) — drives ACL + prompt
# learning: optional growth domain — emits learning-board subscriptions

# Add roles via `aon add-role NAME [KIND] [DOMAIN]` or `aon onboard`.
# The operator-manager is the only required seed; everyone else
# joins via share-block tokens.
[[roles]]
name   = "@OPERATOR@"
kind   = "manager"
domain = "manager"

# Examples (uncomment + edit, or use `aon add-role`):
# [[roles]]
# name     = "alice"
# kind     = "generalist"     # manager | generalist | specialist
# domain   = "python"         # primary skill — drives ACL + prompt
# learning = "go"             # optional growth domain

[paths]
task_dir    = ".tasks"
prompts_dir = "agent-prompts"
agents_dir  = "agents"
hooks_dir   = "hooks"

[model]
# provider ∈ { claude, ollama }
# When provider=ollama, `aon launch` runs `ollama run <name>` instead of
# `claude`. Ollama host defaults to http://localhost:11434; override via
# AON_OLLAMA_HOST env var or ollama_host in this section.
provider    = "claude"
name        = "claude-sonnet-4-20250514"   # model name / tag
# ollama_host = "http://localhost:11434"

[repos]
default = "ai-over-nats"
known   = ["ai-over-nats"]
# repos_root = "/Users/$USER/Repos"     # override default repos root
