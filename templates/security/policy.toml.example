# Per-team cmd-gate config. Drop into your aon.toml. All keys
# optional; defaults shown. Env vars (AON_GATE_*) override these so
# operator can experiment without committing.

[security.cmd_gate]
enabled              = true
model                = "nemotron-3-nano:4b"        # AON_GATE_MODEL
ollama_url           = "http://127.0.0.1:11434"    # AON_GATE_OLLAMA_URL
timeout_ms           = 4000                        # AON_GATE_TIMEOUT_MS
cache_ttl_seconds    = 3600                        # AON_GATE_CACHE_TTL
ask_timeout_seconds  = 60                          # AON_GATE_ASK_TIMEOUT
fallback_on_error    = "ask"                       # AON_GATE_FALLBACK
                                                    #   ask | deny | allow

# Self-evolving prompt loop (ADR-002). Wired via this section.
[security.cmd_gate.evolve]
backend_provider     = "anthropic"                 # AON_GATE_EVOLVE_BACKEND
                                                    #   anthropic | ollama
model                = "claude-opus-4-7-20251001"  # AON_GATE_EVOLVE_MODEL
                                                    #   ollama default: gpt-oss:20b
ollama_url           = "http://127.0.0.1:11434"    # AON_GATE_EVOLVE_OLLAMA_URL
timeout_s            = 30                          # AON_GATE_EVOLVE_TIMEOUT_S
budget_usd           = 20                          # AON_GATE_EVOLVE_BUDGET_USD
                                                    #   daily cap; anthropic only
# ANTHROPIC_API_KEY stays in env — never commit secrets to aon.toml.

# Personal overrides live OUTSIDE the repo (mirrors the AppArmor
# personal-override pattern from docs/sandbox.md):
#
#   ~/.aon/security/allow.local.regex   extra always-allow patterns
#   ~/.aon/security/deny.local.regex    extra always-deny (wins over allow)
#
# Hard bypass:
#
#   aon security bypass on              writes ~/.aon/security/bypass
#   AON_GATE_BYPASS=1 aon launch <role> one-shot env
#
# Bypass disables the classifier and allow.regex but still enforces
# the deny.regex hard floor (rm -rf /, terraform destroy, etc.).

# Per-role lanes — NOT WIRED YET. Sketch for the follow-up:
