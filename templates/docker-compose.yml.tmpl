services:
  nats:
    image: nats:latest
    command: ["-c", "/etc/nats/runtime/nats-server.conf"]
    environment:
      - AON_SERVER_NAME=aon-server-1
    ports:
      - "0.0.0.0:4222:4222"   # client
      - "0.0.0.0:8080:8080"   # websocket
      - "0.0.0.0:8222:8222"   # monitor
      - "0.0.0.0:6222:6222"   # cluster
    volumes:
      - nats_data:/data
      # Shared runtime dir — holds nats-server.conf, resolver/ (account
      # JWTs for ALL teams). Dir mount avoids macOS single-file staleness.
      # Written by `aon auth render`; SIGHUP picks up new account JWTs.
      - @SHARED_NATS_DIR@:/etc/nats/runtime:ro
    restart: unless-stopped
    healthcheck:
      test: ["NONE"]

volumes:
  nats_data:
