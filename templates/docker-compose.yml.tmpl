services:
  nats:
    image: nats:latest
    command: ["-c", "/etc/nats/nats-server.conf"]
    environment:
      - AON_SERVER_NAME=@TEAM_NAME@-1
    ports:
      - "0.0.0.0:4222:4222"   # client
      - "0.0.0.0:8080:8080"   # websocket
      - "0.0.0.0:8222:8222"   # monitor
      - "0.0.0.0:6222:6222"   # cluster
    volumes:
      - nats_data:/data
      - ./nats/nats-server.conf:/etc/nats/nats-server.conf:ro
      # Directory bind-mount holds the resolver dir (account JWTs) and
      # any other runtime artifacts. Dir mount avoids macOS single-file
      # bind-mount staleness (Docker Desktop VirtioFS, colima 9p).
      # Layout under @NATS_DIR_PATH@:
      #   resolver/<team-account-id>.jwt   — populated by `aon auth render`
      - @NATS_DIR_PATH@:/etc/nats/runtime:ro
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:8222/healthz"]
      interval: 10s
      timeout: 3s
      retries: 5

volumes:
  nats_data:
