# team-alpha base worker image.
#
# Provides the substrate every role needs:
#   - claude CLI (installed via npm)
#   - nats CLI (for hooks + manual debugging)
#   - git (for per-task worktree work)
#   - python3 + venv (for team-alpha-mcp)
#   - jq, curl, ca-certificates (used by hook scripts)
#
# Per-role overlays (Dockerfile.<role>) FROM this image and add
# skill-specific tooling.
#
# Auth (Anthropic API key, NATS role password) is mounted at run
# time, never baked in.
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates curl wget gnupg jq git \
      python3 python3-venv python3-pip \
      tini bash \
 && rm -rf /var/lib/apt/lists/*

# nats CLI — pinned to a recent release; static binary.
ARG NATS_CLI_VERSION=0.1.5
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) suffix=linux-amd64 ;; \
      arm64) suffix=linux-arm64 ;; \
      *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/nats-io/natscli/releases/download/v${NATS_CLI_VERSION}/nats-${NATS_CLI_VERSION}-${suffix}.zip" -o /tmp/nats.zip; \
    apt-get update && apt-get install -y --no-install-recommends unzip; \
    unzip /tmp/nats.zip -d /tmp/nats; \
    install -m 0755 "/tmp/nats/nats-${NATS_CLI_VERSION}-${suffix}/nats" /usr/local/bin/nats; \
    apt-get purge -y unzip; \
    rm -rf /var/lib/apt/lists/* /tmp/nats /tmp/nats.zip

# Node.js (for claude CLI) — NodeSource setup script for current LTS.
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g @anthropic-ai/claude-code \
 && npm cache clean --force

# Non-root worker user. UID 1000 — host bind mounts assume mid:1000.
RUN useradd -m -u 1000 -s /bin/bash worker \
 && mkdir -p /work/repo /work/workspace /work/board /etc/team-alpha \
 && chown -R worker:worker /work /etc/team-alpha

# team-alpha-mcp — copy source + install into role-owned venv.
COPY mcp-server /opt/team-alpha-mcp
RUN chown -R worker:worker /opt/team-alpha-mcp \
 && python3 -m venv /opt/team-alpha-venv \
 && /opt/team-alpha-venv/bin/pip install --no-cache-dir /opt/team-alpha-mcp \
 && chown -R worker:worker /opt/team-alpha-venv

ENV PATH=/opt/team-alpha-venv/bin:/usr/local/bin:/usr/bin:/bin

# Login shells (bash -l) reset PATH from /etc/profile. Re-export
# the venv path there so `bash -l` inside the container still finds
# team-alpha-mcp.
RUN printf 'export PATH=/opt/team-alpha-venv/bin:$PATH\n' \
      > /etc/profile.d/team-alpha.sh

USER worker
WORKDIR /work/workspace

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash", "-l"]
