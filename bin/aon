#!/usr/bin/env bash
# aon — ai-over-nats engine CLI.
#
# Operator entrypoint. Run from inside a per-team repo.
#
# Subcommands:
#   init                   bootstrap harness in current repo
#   add-role NAME KIND     append role to roster (kind ∈ manager|generalist|specialist)
#   doctor                 sanity-check the local setup
#   apparmor SUB           manage personal AppArmor overrides (Cards 228/229)
#                          (delegates to bin/team-alpha-apparmor for now)
#   help                   this help

set -uo pipefail

_aon_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_aon-lib.sh
source "$_aon_dir/_aon-lib.sh"

usage() {
  cat <<EOF
aon — ai-over-nats engine CLI

usage: aon <command> [args]

Commands:
  init                       bootstrap harness in current repo
  onboard NAME BITS [KIND] [DOMAIN]  one-shot operator onboarding (recommended)
                             BITS = current cloudflared subdomain (4-word piece)
                             composes add-role + render + auth + creds + nats up
                             + handshake probe + commit/push + token emit
                             defaults: KIND=generalist, DOMAIN=fullstack
  add-role NAME [KIND] [DOMAIN]  append role to aon.toml roster
                             defaults: KIND=generalist, DOMAIN=fullstack
  doctor                     sanity-check local setup
  prompts render             render agent-prompts/<role>.md from templates
  auth render                render auth.conf.example from roster (→ ~/.aon/teams/<team>/)
  auth set-passwords         substitute PASSWORD_* placeholders → auth.conf
  auth migrate               move legacy nats/auth.conf + .passwords out of repo
  bootstrap                  ensure JetStream streams + KV from aon.toml roster
  nats SUB                   docker compose wrapper (up|down|logs|status)
  creds ROLE [DEST]          write per-role password file (chmod 600)
  creds --all                write all per-role password files
  launch ROLE [WORK_REPO]    set env, install hooks, exec claude as ROLE
  join ROLE WORK_REPO        full joiner setup (creds, .mcp.json, hooks,
                             CLAUDE.md symlink, NATS handshake)
  join-link TOKEN BITS       one-shot joiner setup from operator's token + bits
                             (recommended) — clones team repo, places creds,
                             runs aon join automatically. Re-run with new BITS
                             to rotate the NATS URL only (no re-clone).
  set-nats-url BITS          joiner-side tunnel rotation (no re-clone, no creds
                             change) — updates env + .mcp.json + settings.json
                             and re-probes handshake. Use --role NAME if more
                             than one role on this box.
  monitor [ROLE]             exec role-monitor.sh with env baked from
                             aon.toml + ~/.aon/teams/<team>/creds/<role>.password
                             (defaults role from \$TEAM_ALPHA_ROLE)
  apparmor SUB               personal AppArmor overrides (sync|show|reload|watch)
  help                       this help

Env:
  AON_ENGINE_DIR             engine repo path (auto-detected)
  AON_TEAM_DIR               per-team repo path (default: cwd)
EOF
}

cmd_init() {
  aon_load_config
  aon_info "aon init — team=$AON_TEAM_NAME engine=$AON_ENGINE_DIR"

  if [[ "$AON_TOML_PRESENT" -eq 0 ]]; then
    cp "$AON_ENGINE_DIR/templates/aon.toml.example" "$AON_TOML"
    aon_ok "wrote $AON_TOML (review + edit roster)"
    aon_load_config   # reload after creating
  else
    aon_ok "aon.toml present (schema=$AON_SCHEMA, $AON_ROLES_COUNT roles)"
  fi

  mkdir -p "$AON_TEAM_DIR/$AON_TASK_DIR"        \
           "$AON_TEAM_DIR/$AON_PROMPTS_DIR"     \
           "$AON_TEAM_DIR/$AON_AGENTS_DIR"      \
           "$AON_TEAM_DIR/$AON_HOOKS_DIR"       \
           "$AON_TEAM_DIR/nats"
  aon_ok "directory tree present"

  # Drop NATS server config + docker-compose for self-contained bring-up
  # (Card 240). Idempotent — only writes if absent.
  local NATS_CONF="$AON_TEAM_DIR/nats/nats-server.conf"
  if [[ ! -f "$NATS_CONF" ]]; then
    cp "$AON_ENGINE_DIR/templates/nats-server.conf" "$NATS_CONF"
    aon_ok "wrote nats/nats-server.conf"
  fi
  local COMPOSE="$AON_TEAM_DIR/docker-compose.yml"
  if [[ ! -f "$COMPOSE" ]]; then
    local _auth_path; _auth_path="$(_aon_team_auth_conf "$AON_TEAM_NAME")"
    aon_render "$AON_ENGINE_DIR/templates/docker-compose.yml.tmpl" "$COMPOSE" \
      "TEAM_NAME=$AON_TEAM_NAME" \
      "AUTH_CONF_PATH=$_auth_path"
    aon_ok "wrote docker-compose.yml"
  fi

  cat <<EOF >&2

Next steps:
  1. Edit $AON_TOML — set roster + NATS URLs.
  2. Render agent prompts:  aon prompts render
  3. Render auth.conf:      aon auth render && aon auth set-passwords
  4. Bring up NATS:         aon nats up
  5. Bootstrap streams:     aon bootstrap
  6. Launch your role:      aon launch <role>
EOF
}

cmd_add_role() {
  local name="${1:-}" kind="${2:-generalist}" domain="${3:-fullstack}"
  [[ -n "$name" ]] || {
    aon_err "usage: aon add-role NAME [KIND] [DOMAIN]"
    aon_err "  KIND ∈ manager | generalist | specialist  (default: generalist)"
    aon_err "  DOMAIN: primary skill                      (default: fullstack)"
    return 2
  }
  case "$kind" in
    manager|generalist|specialist) ;;
    *) aon_fail "kind must be manager|generalist|specialist (got: $kind)" ;;
  esac

  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"

  # Detect existing role (idempotency).
  local i count
  count="$AON_ROLES_COUNT"
  for ((i=0; i<count; i++)); do
    if [[ "$(aon_toml_array_get "$AON_TOML" roles "$i" name)" == "$name" ]]; then
      aon_warn "role '$name' already in roster (index $i) — leaving as-is"
      return 0
    fi
  done

  cat >> "$AON_TOML" <<EOF

[[roles]]
name   = "$name"
kind   = "$kind"
domain = "$domain"
EOF
  aon_ok "appended role '$name' ($kind / $domain) to $AON_TOML"
  aon_warn "Templates not yet wired — run 'aon prompts render' + 'aon auth render' once Cards 234/235 land."
}

cmd_doctor() {
  aon_load_config
  local fail=0
  ok() { aon_ok "$*"; }
  bad() { aon_err "$*"; fail=1; }

  [[ "$AON_TOML_PRESENT" -eq 1 ]] && ok "aon.toml present" || bad "aon.toml missing — run 'aon init'"
  [[ -d "$AON_TEAM_DIR/$AON_TASK_DIR" ]]    && ok "$AON_TASK_DIR/ present"    || bad "$AON_TASK_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_PROMPTS_DIR" ]] && ok "$AON_PROMPTS_DIR/ present" || bad "$AON_PROMPTS_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_AGENTS_DIR" ]]  && ok "$AON_AGENTS_DIR/ present"  || bad "$AON_AGENTS_DIR/ missing"

  if [[ "$AON_ROLES_COUNT" -gt 0 ]]; then
    ok "roster has $AON_ROLES_COUNT role(s)"
    local i name kind
    for ((i=0; i<AON_ROLES_COUNT; i++)); do
      name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
      kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
      printf '    - %-12s %s\n' "$name" "$kind" >&2
    done
  else
    bad "roster empty"
  fi

  if command -v nats >/dev/null 2>&1; then ok "nats CLI present"; else bad "nats CLI not on PATH"; fi
  if command -v jq   >/dev/null 2>&1; then ok "jq present";       else bad "jq not on PATH"; fi
  if command -v claude >/dev/null 2>&1; then ok "claude CLI present"; else bad "claude CLI not on PATH"; fi

  # ── Operator-side runtime state (auth.conf + .passwords) ──
  if [[ "$AON_TOML_PRESENT" -eq 1 ]]; then
    local _auth; _auth="$(_aon_team_auth_conf "$AON_TEAM_NAME")"
    local _pwf;  _pwf="$(_aon_team_passwords "$AON_TEAM_NAME")"
    if [[ -f "$_auth" ]]; then
      ok "auth.conf → $_auth"
    else
      aon_warn "no $_auth (operator only — joiners don't have this; run 'aon auth render && aon auth set-passwords')"
    fi
    if [[ -f "$_pwf" ]]; then
      ok ".passwords → $_pwf"
    else
      aon_warn "no $_pwf (operator only)"
    fi
    # Detect lingering legacy files in repo.
    if [[ -f "$AON_TEAM_DIR/nats/auth.conf" || -f "$AON_TEAM_DIR/nats/.passwords" ]]; then
      bad "legacy in-repo state still present under $AON_TEAM_DIR/nats/ — run 'aon auth migrate'"
    fi
  fi

  # ── Registry / cwd resolution ──
  local reg; reg="$(_aon_work_repos_json)"
  if [[ -f "$reg" ]]; then
    local count; count="$(jq 'length' "$reg" 2>/dev/null || echo 0)"
    ok "registry: $reg ($count work-repo entry/entries)"
    local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || res=""
    if [[ -n "$res" ]]; then
      local rt rr rp; IFS=$'\t' read -r rt rr rp <<<"$res"
      ok "cwd resolves → team=$rt role=$rr (work-repo: $rp)"
      local pw; pw="$(_aon_role_pwfile "$rr" "$rt")"
      [[ -f "$pw" ]] && ok "creds present → $pw" || bad "creds missing → $pw"
    else
      ok "cwd not in registry (operator dir or untracked work-repo) — fine"
    fi
  else
    ok "no registry yet ($reg) — first 'aon join' creates it"
  fi
  [[ -f "$HOME/.claude/settings.json" ]] && ok "global ~/.claude/settings.json present" \
    || aon_warn "no ~/.claude/settings.json — run 'aon join' to install global MCP+hooks"

  echo >&2
  if [[ "$fail" -eq 0 ]]; then
    aon_ok "PASS — local setup looks healthy."
    return 0
  else
    aon_err "FAIL — fix items above."
    return 1
  fi
}

cmd_prompts() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render) cmd_prompts_render "$@" ;;
    -h|--help|help|"") echo "Usage: aon prompts render" >&2 ;;
    *) aon_err "aon prompts: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_prompts_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local TPL="$AON_ENGINE_DIR/templates/agent-prompts"
  local OUT="$AON_TEAM_DIR/$AON_PROMPTS_DIR"
  mkdir -p "$OUT"

  # Render _common.md once, shared by all roles.
  aon_render "$TPL/_common.md.tmpl" "$OUT/_common.md" \
    "TEAM_NAME=$AON_TEAM_NAME" \
    "KV_BUCKET=$AON_TEAM_KV"
  aon_ok "rendered $OUT/_common.md"

  local i name kind domain learning title
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    title="$(printf '%s' "$name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
    [[ -f "$TPL/$kind.md.tmpl" ]] || { aon_warn "no template for kind=$kind ($name) — skipping"; continue; }
    aon_render "$TPL/$kind.md.tmpl" "$OUT/$name.md" \
      "ROLE=$name" \
      "ROLE_TITLE=$title" \
      "DOMAIN=$domain" \
      "LEARNING=${learning:-$domain}" \
      "TEAM_NAME=$AON_TEAM_NAME" \
      "KV_BUCKET=$AON_TEAM_KV"
    aon_ok "rendered $OUT/$name.md ($kind / $domain)"
  done
}

cmd_auth() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render)        cmd_auth_render "$@" ;;
    set-passwords) cmd_auth_set_passwords "$@" ;;
    migrate)       cmd_auth_migrate "$@" ;;
    -h|--help|help|"") cat >&2 <<EOF
Usage: aon auth <render|set-passwords|migrate>
  render          render auth.conf.example from aon.toml roster
                  → ~/.aon/teams/<team>/auth.conf.example
  set-passwords   replace PASSWORD_* placeholders → auth.conf
                  → ~/.aon/teams/<team>/auth.conf
                  → ~/.aon/teams/<team>/.passwords (chmod 600)
  migrate         move legacy nats/auth.conf + nats/.passwords out of the
                  team-aon repo into ~/.aon/teams/<team>/. Idempotent.
EOF
    ;;
    *) aon_err "aon auth: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_auth_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local TPL="$AON_ENGINE_DIR/templates/auth"
  local OUT; OUT="$(_aon_team_auth_conf_example "$AON_TEAM_NAME")"
  mkdir -p "$(dirname "$OUT")"
  chmod 700 "$(_aon_registry_root)" 2>/dev/null || true

  local TMP
  TMP="$(mktemp)"

  # Header
  sed "s|@TEAM_ACCOUNT@|$AON_TEAM_ACCOUNT|g" "$TPL/header.tmpl" > "$TMP"
  # sysadmin (always)
  cat "$TPL/sysadmin.tmpl" >> "$TMP"

  # Roles
  local i name kind domain learning title upper
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    [[ -f "$TPL/$kind.tmpl" ]] || { aon_warn "no auth template for kind=$kind ($name)"; continue; }
    title="$(printf '%s' "$name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
    upper="$(printf '%s' "$name" | tr '[:lower:]' '[:upper:]')"
    sed -e "s|@ROLE@|$name|g" \
        -e "s|@ROLE_TITLE@|$title|g" \
        -e "s|@ROLE_UPPER@|$upper|g" \
        -e "s|@DOMAIN@|$domain|g" \
        -e "s|@LEARNING@|${learning:-$domain}|g" \
        -e "s|@KV_BUCKET@|$AON_TEAM_KV|g" \
        "$TPL/$kind.tmpl" >> "$TMP"
  done

  # sys + footer
  cat "$TPL/sys.tmpl" >> "$TMP"
  cat "$TPL/footer.tmpl" >> "$TMP"

  install -m 0644 "$TMP" "$OUT"
  rm -f "$TMP"
  aon_ok "rendered $OUT ($AON_ROLES_COUNT roles + sysadmin + sys)"
  aon_info "Next: aon auth set-passwords  (substitutes PASSWORD_* placeholders)"
}

cmd_auth_set_passwords() {
  aon_load_config
  local SRC; SRC="$(_aon_team_auth_conf_example "$AON_TEAM_NAME")"
  local OUT; OUT="$(_aon_team_auth_conf "$AON_TEAM_NAME")"
  local PWFILE; PWFILE="$(_aon_team_passwords "$AON_TEAM_NAME")"
  [[ -r "$SRC" ]] || aon_fail "no $SRC — run 'aon auth render' first"
  mkdir -p "$(dirname "$OUT")"
  chmod 700 "$(_aon_registry_root)" 2>/dev/null || true

  cp "$SRC" "$OUT"
  : > "$PWFILE"
  chmod 600 "$PWFILE"

  # Find all PASSWORD_<NAME> placeholders, generate one secret per unique
  # name. Sort by length descending so PASSWORD_SYSADMIN substitutes before
  # PASSWORD_SYS (otherwise sed s|PASSWORD_SYS|…| matches the longer
  # placeholder's prefix and leaves "<pw>ADMIN" garbage).
  local placeholders
  placeholders="$(grep -oE 'PASSWORD_[A-Z][A-Z0-9_]*' "$SRC" | sort -u | awk '{ print length, $0 }' | sort -rn | cut -d' ' -f2-)"
  [[ -n "$placeholders" ]] || aon_fail "no PASSWORD_* placeholders found in $SRC"

  local p who pw
  for p in $placeholders; do
    who="${p#PASSWORD_}"
    pw="$(openssl rand -hex 24)"
    # Substitute in-place; sed `|` delimiter to avoid hex collision.
    sed -i '' -e "s|$p|$pw|g" "$OUT"
    printf '%s=%s\n' "$who" "$pw" >> "$PWFILE"
  done
  aon_ok "wrote $OUT"
  aon_ok "wrote $PWFILE (chmod 600) — distribute via secret manager, never commit"
}

# Move legacy nats/auth.conf, nats/.passwords, nats/auth.conf.example
# from $AON_TEAM_DIR/nats/ to ~/.aon/teams/<team>/. Idempotent.
cmd_auth_migrate() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — cd into a team-aon repo first"

  local team="$AON_TEAM_NAME"
  local STATE; STATE="$(_aon_team_state_dir "$team")"
  mkdir -p "$STATE"
  chmod 700 "$(_aon_registry_root)" 2>/dev/null || true

  local moved=0 skipped=0
  _migrate_one() {
    local src="$1" dst="$2" mode="$3"
    if [[ ! -f "$src" ]]; then
      return 0
    fi
    if [[ -f "$dst" ]]; then
      if cmp -s "$src" "$dst"; then
        aon_ok "already migrated: $dst"
      else
        local s_size d_size
        s_size="$(wc -c <"$src" | tr -d ' ')"
        d_size="$(wc -c <"$dst" | tr -d ' ')"
        aon_warn "skip $src → $dst (target exists, sizes differ: src=$s_size dst=$d_size)"
        aon_warn "  resolve manually; rerun migrate after."
      fi
      skipped=$((skipped+1))
      return 0
    fi
    cp "$src" "$dst"
    chmod "$mode" "$dst"
    aon_ok "migrated $src → $dst (chmod $mode)"
    moved=$((moved+1))
  }

  _migrate_one "$AON_TEAM_DIR/nats/auth.conf"         "$STATE/auth.conf"         "0644"
  _migrate_one "$AON_TEAM_DIR/nats/.passwords"        "$STATE/.passwords"        "0600"
  _migrate_one "$AON_TEAM_DIR/nats/auth.conf.example" "$STATE/auth.conf.example" "0644"

  echo >&2
  aon_info "migrate summary: moved=$moved skipped=$skipped"
  echo >&2
  if [[ -f "$AON_TEAM_DIR/nats/auth.conf" || -f "$AON_TEAM_DIR/nats/.passwords" || -f "$AON_TEAM_DIR/nats/auth.conf.example" ]]; then
    cat >&2 <<EOF
Now remove the originals from the team-aon repo (operator runs, not aon):

  cd $AON_TEAM_DIR
  git rm --cached nats/auth.conf nats/.passwords nats/auth.conf.example 2>/dev/null
  rm -f nats/auth.conf nats/.passwords nats/auth.conf.example
  # ensure .gitignore covers them:
  printf '%s\n' 'nats/auth.conf' 'nats/.passwords' 'nats/auth.conf.example' >> .gitignore
  sort -u .gitignore -o .gitignore
  git add .gitignore && git commit -m "Move auth.conf + .passwords out of repo"

If NATS is running with the OLD bind-mount, restart it so the new mount
takes effect:
  aon nats down && aon nats up
EOF
  fi
}

cmd_bootstrap() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local PWFILE; PWFILE="$(_aon_team_passwords "$AON_TEAM_NAME")"
  [[ -r "$PWFILE" ]] || aon_fail "no $PWFILE — run 'aon auth set-passwords' first"

  # Build roster string from aon.toml roles.
  local roster=""
  local i name
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ -n "$name" ]] && roster+="${roster:+ }$name"
  done

  # Pull sysadmin pw.
  local SYS_PW
  SYS_PW="$(grep -E "^${AON_NATS_ADMIN^^}=" "$PWFILE" | cut -d= -f2-)"
  [[ -n "$SYS_PW" ]] || aon_fail "no ${AON_NATS_ADMIN^^}= entry in $PWFILE"

  local script="$AON_ENGINE_DIR/scripts/bootstrap.sh"
  [[ -x "$script" ]] || aon_fail "engine bootstrap not executable: $script"

  aon_info "aon bootstrap — team=$AON_TEAM_NAME url=$AON_NATS_URL roles=($roster)"
  AON_ROSTER="$roster" \
  AON_KV_BUCKET="$AON_TEAM_KV" \
  NATS_URL="$AON_NATS_URL" \
  NATS_ADMIN_USER="$AON_NATS_ADMIN" \
  NATS_ADMIN_PASSWORD="$SYS_PW" \
    bash "$script"
}

cmd_nats() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    up|start)     cmd_nats_up "$@" ;;
    down|stop)    cmd_nats_down "$@" ;;
    logs)   cmd_nats_logs "$@" ;;
    status) cmd_nats_status "$@" ;;
    -h|--help|help|"") cat >&2 <<EOF
Usage: aon nats <up|down|logs|status>
  up      docker compose up -d nats (uses team docker-compose.yml)
  down    docker compose down nats
  logs    docker compose logs -f nats
  status  ps + healthz
EOF
    ;;
    *) aon_err "aon nats: unknown subcommand: $sub"; return 2 ;;
  esac
}

_aon_nats_compose() {
  # Resolve compose file: prefer team repo's, else engine top-level.
  if [[ -f "$AON_TEAM_DIR/docker-compose.yml" ]]; then
    echo "$AON_TEAM_DIR/docker-compose.yml"
  else
    echo "$AON_ENGINE_DIR/docker-compose.yml"
  fi
}

_aon_nats_project_name() {
  # Use the team name from aon.toml so containers have a stable name
  # across cwds. Fall back to the dir basename only if aon.toml is
  # missing (which cmd_nats_up's guard refuses anyway).
  if [[ -n "${AON_TEAM_NAME:-}" ]]; then
    printf '%s' "$AON_TEAM_NAME"
  else
    basename "$AON_TEAM_DIR"
  fi
}

_aon_nats_port_in_use() {
  # Returns 0 if port 4222 already bound on this host.
  lsof -nP -iTCP:4222 -sTCP:LISTEN 2>/dev/null | grep -q LISTEN
}

_aon_nats_find_container() {
  # Find a running container whose auth.conf bind-mount source equals
  # the team's canonical auth.conf path (~/.aon/teams/<team>/auth.conf).
  # Returns the container NAME on stdout (rc=0). Empty + rc=1 if no match.
  # Uses bind-mount, not name, so legacy containers from before the
  # project-name=team-name fix (e.g. saas-nats-1) are still found.
  local auth_path; auth_path="$(_aon_team_auth_conf "${AON_TEAM_NAME:-team-alpha}")"
  [[ -f "$auth_path" ]] || return 1
  local cid
  for cid in $(docker ps -q 2>/dev/null); do
    if docker inspect "$cid" --format '{{range .Mounts}}{{.Source}}{{"\n"}}{{end}}' 2>/dev/null \
         | grep -qxF "$auth_path"; then
      docker inspect "$cid" --format '{{.Name}}' 2>/dev/null | sed 's|^/||'
      return 0
    fi
  done
  return 1
}

_aon_nats_external_serving() {
  # Returns 0 if a real NATS server is answering on :4222. NATS greets
  # every TCP connect with `INFO {…}\r\n` before any auth, so we just
  # peek the first 5 bytes. Use python (already a hard dep) — BSD nc
  # closes stdin too aggressively, missing the greeting. Detects
  # colima/lima port-forwards, remote tunnels, native nats-server,
  # and our own docker container (across cwds with different project
  # names).
  python3 - <<'PY' >/dev/null 2>&1
import socket, sys
try:
    s = socket.create_connection(("127.0.0.1", 4222), timeout=2)
    s.settimeout(2)
    data = s.recv(5)
    s.close()
    sys.exit(0 if data.startswith(b"INFO ") else 1)
except Exception:
    sys.exit(1)
PY
}

cmd_nats_up() {
  aon_load_config
  # Guard: refuse to run outside a team dir. Without this guard,
  # running from $HOME makes project=basename($HOME) (e.g. "mid"), the
  # compose file falls back to engine's docker-compose.yml, and the
  # resulting orphan container squats :4222 forever — blocking later
  # `aon onboard` from the real team dir.
  if [[ "$AON_TOML_PRESENT" -ne 1 ]]; then
    aon_err "no aon.toml in $AON_TEAM_DIR — refusing to spin up nats here."
    aon_err "  cd into your team dir (with aon.toml) before running 'aon nats up'."
    aon_err "  or run 'aon init' first to create one."
    return 1
  fi
  # Pre-check :4222 — three cases when bound:
  #   (1) our compose container running  → already up, return 0
  #   (2) something else answers NATS protocol  → external NATS (colima
  #       VM port-forward, remote tunnel, native nats-server). Trust
  #       it and skip docker start. Auth gets validated on the next
  #       handshake probe anyway.
  #   (3) port held by something that isn't NATS → bail loud.
  local pname; pname="$(_aon_nats_project_name)"
  if _aon_nats_port_in_use; then
    if docker ps --filter "name=${pname}-nats-1" --format "{{.Names}}" 2>/dev/null | grep -q "${pname}-nats-1"; then
      aon_ok "team's NATS container already running ($pname-nats-1)"
      curl -s http://127.0.0.1:8222/healthz 2>/dev/null && echo
      return 0
    fi
    if _aon_nats_external_serving; then
      aon_ok "external NATS already serving on :4222 — skipping docker start"
      aon_info "  (auth.conf changes need a manual reload on whoever runs that nats)"
      return 0
    fi
    aon_err "port 4222 bound but not answering NATS protocol."
    aon_err "  $(lsof -nP -iTCP:4222 -sTCP:LISTEN 2>/dev/null | tail -n +2 | head -1)"
    aon_err "  Stop the squatter first; see 'ps -fp <PID>' to identify."
    return 1
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  aon_info "aon nats up — compose=$compose project=$pname"
  # Capture compose exit so we don't false-positive when port :4222 is
  # held by some OTHER process — that other listener also answers
  # :8222/healthz, which would make us claim health for the wrong nats.
  local compose_log; compose_log="$(mktemp -t aon-nats-up.XXXXXX)"
  if ! ( cd "$AON_TEAM_DIR" && docker compose -f "$compose" --project-name "$pname" up -d nats ) >"$compose_log" 2>&1; then
    cat "$compose_log" >&2
    # Compose often leaves a stopped container behind on port-bind
    # failure. Remove it so the next attempt isn't blocked by it.
    docker rm -f "${pname}-nats-1" >/dev/null 2>&1 || true
    if grep -q "port is already allocated\|address already in use" "$compose_log"; then
      aon_err "port 4222 (or 8222/8080) already bound by another listener."
      local lsof_out; lsof_out="$(lsof -nP -iTCP:4222 -sTCP:LISTEN 2>/dev/null | tail -n +1 | head -3)"
      [[ -n "$lsof_out" ]] && printf '%s\n' "$lsof_out" >&2
      # Identify common cases by command name in lsof output.
      if printf '%s' "$lsof_out" | grep -qE '^ssh\b'; then
        aon_err "  Squatter is 'ssh' — likely a colima/lima VM port-forward or an SSH tunnel."
        aon_err "  Check 'colima list' / 'limactl list' or 'ps -fp <PID>' to find the source."
        aon_err "  If colima is forwarding NATS from inside the VM, you don't need a second"
        aon_err "  container — point aon at the VM's nats and skip 'aon nats up'."
      elif printf '%s' "$lsof_out" | grep -qE '^nats-server\b'; then
        aon_err "  Squatter is a native 'nats-server' process — kill it: pkill nats-server"
      elif printf '%s' "$lsof_out" | grep -qE '^com.docker'; then
        aon_err "  Squatter is Docker — find the stale container:"
        aon_err "    docker ps --format 'table {{.Names}}\t{{.Ports}}' | grep 4222"
        aon_err "    docker rm -f <name>     # or: aon nats down (if it's this team's)"
      else
        aon_err "  Stop the other listener and retry. (ps -fp <PID> shows what it is.)"
      fi
    fi
    rm -f "$compose_log"
    return 1
  fi
  rm -f "$compose_log"

  # Verify OUR container is actually running before probing :8222.
  local cname="${pname}-nats-1"
  if ! docker ps --filter "name=^${cname}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${cname}$"; then
    aon_err "compose returned 0 but $cname is not running — check 'docker ps -a' and 'aon nats logs'"
    return 1
  fi

  # Wait for healthz (10s) — now safe to trust because we know our
  # container is the one bound to :8222.
  local i
  for i in {1..20}; do
    sleep 0.5
    if curl -sf http://127.0.0.1:8222/healthz >/dev/null 2>&1; then
      aon_ok "NATS healthy on 127.0.0.1:4222 (monitor :8222, ws :8080) — container $cname"
      return 0
    fi
  done
  aon_err "NATS did not pass healthz within 10s — check 'aon nats logs'"
  return 1
}

cmd_nats_down() {
  aon_load_config
  # Prefer to find OUR container by auth.conf mount — handles legacy
  # containers from before project-name=team-name (e.g. saas-nats-1
  # when team-name is team-alpha). Falls back to compose down.
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    aon_info "stopping container $cname (matched by auth.conf mount)"
    docker stop "$cname" >/dev/null && docker rm "$cname" >/dev/null
    aon_ok "stopped + removed $cname"
    return 0
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  ( cd "$AON_TEAM_DIR" && docker compose -f "$compose" --project-name "$pname" down nats )
  aon_ok "stopped"
}

cmd_nats_logs() {
  aon_load_config
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    exec docker logs -f "$cname"
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  ( cd "$AON_TEAM_DIR" && exec docker compose -f "$compose" --project-name "$pname" logs -f nats )
}

cmd_nats_status() {
  aon_load_config
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    docker ps --filter "name=^${cname}$" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  else
    local pname; pname="$(_aon_nats_project_name)"
    docker ps --filter "name=${pname}-nats-1" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  fi
  echo
  curl -s http://127.0.0.1:8222/healthz 2>&1 || echo "(monitor unreachable)"
}

cmd_creds() {
  aon_load_config
  local role="${1:-}" dest="${2:-}"
  if [[ "$role" == "--all" ]]; then
    cmd_creds_all "${2:-}"
    return $?
  fi
  [[ -n "$role" ]] || { aon_err "usage: aon creds <role> [<dest>]   |   aon creds --all"; return 2; }
  case "$dest" in
    →|←|⇒|"")  : ;;  # empty = default; arrow glyphs handled below
    *) ;;
  esac
  case "$dest" in
    →|←|⇒)
      aon_err "dest looks like a documentation glyph ('$dest'); did you copy-paste a comment?"
      aon_err "  fix: re-run without the glyph, e.g.  aon creds $role"
      return 2
      ;;
  esac
  local PWFILE; PWFILE="$(_aon_team_passwords "$AON_TEAM_NAME")"
  [[ -r "$PWFILE" ]] || aon_fail "no $PWFILE — run 'aon auth set-passwords' first"
  local upper; upper="$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')"
  local pw; pw="$(grep -E "^${upper}=" "$PWFILE" | cut -d= -f2-)"
  [[ -n "$pw" ]] || aon_fail "no ${upper}= entry in $PWFILE (run 'aon auth set-passwords' or check role spelling)"
  if [[ -z "$dest" ]]; then
    local creds_dir; creds_dir="$(_aon_team_creds_dir "$AON_TEAM_NAME")"
    mkdir -p "$creds_dir"
    chmod 700 "$(_aon_registry_root)"
    dest="$creds_dir/$role.password"
  fi
  printf '%s' "$pw" > "$dest"
  chmod 600 "$dest"
  aon_ok "wrote $dest (chmod 600)"
}

cmd_creds_all() {
  aon_load_config
  local PWFILE; PWFILE="$(_aon_team_passwords "$AON_TEAM_NAME")"
  [[ -r "$PWFILE" ]] || aon_fail "no $PWFILE"
  local creds_dir; creds_dir="$(_aon_team_creds_dir "$AON_TEAM_NAME")"
  mkdir -p "$creds_dir"
  chmod 700 "$(_aon_registry_root)"
  local line who pw
  while IFS='=' read -r who pw; do
    [[ -n "$who" && -n "$pw" ]] || continue
    local lower; lower="$(printf '%s' "$who" | tr '[:upper:]' '[:lower:]')"
    local dest="$creds_dir/$lower.password"
    printf '%s' "$pw" > "$dest"
    chmod 600 "$dest"
    aon_ok "wrote $dest"
  done < "$PWFILE"
}

cmd_launch() {
  aon_load_config
  local role="${1:-}" work_repo="${2:-}"
  [[ -n "$role" ]] || { aon_err "usage: aon launch <role> [<work-repo>]"; return 2; }

  # Verify role is in roster.
  local i found="" rname
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    rname="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ "$rname" == "$role" ]] && { found=1; break; }
  done
  [[ -n "$found" ]] || aon_fail "role '$role' not in aon.toml roster"

  # Resolve creds; auto-populate if missing.
  local CREDS; CREDS="$(_aon_role_pwfile "$role")"
  if [[ ! -s "$CREDS" ]]; then
    aon_info "creds missing — running 'aon creds $role'"
    cmd_creds "$role" || return $?
  fi

  # NATS handshake (1s timeout) — bail with a clear msg if auth fails.
  local PASS; PASS="$(tr -d '[:space:]' < "$CREDS")"
  if ! nats --server "$AON_NATS_URL" --user "$role" --password "$PASS" --timeout 2s rtt >/dev/null 2>&1; then
    aon_err "NATS handshake failed for role=$role url=$AON_NATS_URL"
    aon_err "  - is NATS up? try: aon nats up"
    aon_err "  - is the password right? try: rm $CREDS && aon creds $role"
    return 1
  fi
  aon_ok "NATS handshake OK as $role"

  # Hooks — install in the relevant repo.
  local target="$AON_TEAM_DIR"
  if [[ -n "$work_repo" ]]; then
    target="$(cd -- "$work_repo" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory: $work_repo"
  fi

  local HOOK_INSTALL="$AON_ENGINE_DIR/scripts/hooks/install.sh"
  if [[ -x "$HOOK_INSTALL" ]]; then
    ( cd "$target" && bash "$HOOK_INSTALL" install >/dev/null )
    aon_ok "hooks installed in $target/.claude/"
  else
    aon_warn "engine hook installer missing — skipping"
  fi

  # Export env + exec claude.
  export TEAM_ALPHA_ROLE="$role"
  export TEAM_ALPHA_NATS_URL="$AON_NATS_URL"
  export TEAM_ALPHA_CREDS="$CREDS"
  aon_info "launching claude (role=$role url=$AON_NATS_URL cwd=$target)"
  cd "$target"
  exec claude
}

cmd_resolve_env() {
  # Reads cwd → ~/.aon/work-repos.json → echoes shell `export` lines so
  # callers can `eval $(aon resolve-env)`. Silent (rc=0) on miss so eval
  # doesn't error in non-team shells; pass --strict to make miss fatal.
  local strict=0
  [[ "${1:-}" == "--strict" ]] && strict=1
  local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || {
    [[ "$strict" == 1 ]] && { aon_err "cwd not in ~/.aon/work-repos.json"; return 1; }
    return 0
  }
  local team role path; IFS=$'\t' read -r team role path <<<"$res"
  local creds_dir; creds_dir="$(_aon_team_creds_dir "$team")"
  local pw="$creds_dir/$role.password"
  local env_file="$creds_dir/$role.env"
  if [[ ! -f "$pw" ]]; then
    [[ "$strict" == 1 ]] && aon_err "missing $pw"
    return $strict
  fi
  local nats_url="" kv="team-state"
  if [[ -f "$env_file" ]]; then
    nats_url="$(grep '^export TEAM_ALPHA_NATS_URL=' "$env_file" 2>/dev/null | cut -d= -f2-)"
    local k; k="$(grep '^export TEAM_ALPHA_KV_BUCKET=' "$env_file" 2>/dev/null | cut -d= -f2-)"
    [[ -n "$k" ]] && kv="$k"
  fi
  printf 'export TEAM_ALPHA_ROLE=%s\n' "$role"
  printf 'export TEAM_ALPHA_NATS_URL=%s\n' "$nats_url"
  printf 'export TEAM_ALPHA_CREDS=%s\n' "$pw"
  printf 'export TEAM_ALPHA_KV_BUCKET=%s\n' "$kv"
  printf 'export AON_TEAM=%s\n' "$team"
  printf 'export TEAM_ALPHA_WORK_REPO=%s\n' "$path"
}

# Idempotent global install of team-alpha MCP + board MCP + hooks into
# ~/.claude/settings.json. Per-work-repo CLAUDE.md gets a fenced aon
# block (preserves any existing content). Hook commands are wrapped
# in `eval $(aon resolve-env) && ...` so they pick up role/url at
# runtime from the registry instead of being baked per-repo.
_aon_install_global_mcp() {
  local engine_dir="$1"
  local work_repo="${2:-}"
  local global_settings="$HOME/.claude/settings.json"
  local aon_bin="$engine_dir/bin/aon"

  local venv_bin="$engine_dir/mcp-server/.venv/bin/team-alpha-mcp"
  if [[ ! -x "$venv_bin" ]]; then
    aon_info "installing team-alpha-mcp venv (one-time)"
    python3 -m venv "$engine_dir/mcp-server/.venv"
    "$engine_dir/mcp-server/.venv/bin/pip" install --quiet --upgrade pip
    "$engine_dir/mcp-server/.venv/bin/pip" install --quiet "$engine_dir/mcp-server"
  fi
  [[ -x "$venv_bin" ]] || aon_fail "$venv_bin missing after install"

  local board_bin="${BOARD_TUI_MCP_BIN:-$(command -v board-tui-mcp || true)}"
  if [[ -z "$board_bin" || ! -x "$board_bin" ]]; then
    aon_info "installing board-tui via pipx (one-time)"
    pipx install --quiet git+https://github.com/dincamihai/board-tui.git \
      || aon_fail "pipx install board-tui failed"
    board_bin="$(command -v board-tui-mcp || true)"
    [[ -n "$board_bin" && -x "$board_bin" ]] || aon_fail "board-tui-mcp not on PATH after install"
  fi

  local board_tasks_dir="${TEAM_ALPHA_BOARD_DIR:-$HOME/team-alpha-board}"
  mkdir -p "$board_tasks_dir" "$HOME/.claude"

  # Merge MCP servers into existing global settings.json (don't clobber).
  local existing="{}"
  [[ -s "$global_settings" ]] && existing="$(cat "$global_settings")"
  printf '%s' "$existing" | jq \
    --arg venv "$venv_bin" \
    --arg board "$board_bin" \
    --arg board_dir "$board_tasks_dir" \
    --arg aon_bin "$aon_bin" \
    '.mcpServers = ((.mcpServers // {}) + {
      "team-alpha":       {type:"stdio", command:$venv,  args:[]},
      "team-alpha-board": {type:"stdio", command:$board, args:[],
                           env:{BOARD_TASKS_DIR:$board_dir}}
    })' > "$global_settings.tmp" && mv "$global_settings.tmp" "$global_settings"
  aon_ok "global MCP install → $global_settings"

  # Merge hooks from engine .claude/settings.json, wrapping commands so
  # they resolve env via registry at runtime (no per-role baking).
  local engine_settings="$engine_dir/.claude/settings.json"
  if [[ -f "$engine_settings" ]]; then
    local hooks_json; hooks_json="$(jq '.hooks // {}' "$engine_settings")"
    if [[ -n "$hooks_json" && "$hooks_json" != "null" && "$hooks_json" != "{}" ]]; then
      jq --argjson hooks "$hooks_json" --arg aon_bin "$aon_bin" '
        .hooks = ($hooks | with_entries(
          .value |= map(.hooks |= map(
            if .type == "command" and (.command | type) == "string"
            then .command = ("eval $(" + $aon_bin + " resolve-env) && " + .command)
            else .
            end
          ))
        ))
      ' "$global_settings" > "$global_settings.tmp" && mv "$global_settings.tmp" "$global_settings"
      aon_ok "global hooks installed (registry-resolved at runtime)"
    fi
  fi

  # Per-work-repo CLAUDE.md — append a fenced section, never clobber
  # existing content. User's personal ~/.claude/CLAUDE.md (membrain,
  # etc.) is left alone. The aon block goes in <work-repo>/CLAUDE.md
  # so claude sees it only when running from that repo.
  if [[ -z "$work_repo" || ! -d "$work_repo" ]]; then
    aon_warn "no work-repo given to _aon_install_global_mcp — skipping CLAUDE.md install"
    return 0
  fi
  local repo_claude_md="$work_repo/CLAUDE.md"
  local block; block="$(cat <<'EOF'
<!-- AON-MARKER-GET-ROLE-BRIEF-START -->
# team-alpha agent

If a `team-alpha` MCP server is connected for this cwd, you are a
team-alpha agent. Role + NATS auth come from that MCP. Call
`get_role_brief()` on your first turn to load full role context
(subject permissions, comms protocol, preemption rules).

When the human user asks for any of the intents below, take the
matching action. Match generously on phrasing — "arm monitor", "watch
traffic", "show traffic", "tail nats" all mean watch your NATS
traffic. These shortcuts take priority over unrelated "monitor"
workflows another tool in this directory may also provide.

All shortcuts are **shell commands** invoked via the Bash tool (not
the built-in Monitor / mcp__monitor tool — those don't inherit the
registry-resolved env and will fail).

| User says (any phrasing)                          | Bash tool command                            |
|---------------------------------------------------|----------------------------------------------|
| "start monitor", "watch traffic", "arm monitor"   | `aon monitor` (run_in_background=true)       |
| "rotate URL with bits BITS"                       | `aon set-nats-url BITS`                      |
| "doctor", "diagnose env"                          | `aon doctor`                                 |
| "show env", "what env do I have"                  | `aon resolve-env`                            |

`aon monitor` resolves role + URL + creds from the cwd registry, then
exec's a long-running `nats sub` over the team's subjects. Run it in
background (`run_in_background=true`) — don't block your turn.

If `aon` isn't on PATH, fall back to `~/Repos/ai-over-nats/bin/aon`.

If the `team-alpha` MCP server is NOT connected for this directory,
this section is a no-op and claude operates normally.
<!-- AON-MARKER-GET-ROLE-BRIEF-END -->
EOF
)"

  if [[ ! -f "$repo_claude_md" ]]; then
    printf '%s\n' "$block" > "$repo_claude_md"
    aon_ok "created $repo_claude_md (aon block only)"
  elif grep -q "AON-MARKER-GET-ROLE-BRIEF-START" "$repo_claude_md"; then
    AON_CLAUDE_BLOCK="$block" python3 - "$repo_claude_md" <<'PY'
import os, sys, re, pathlib
p = pathlib.Path(sys.argv[1])
src = p.read_text()
new_block = os.environ["AON_CLAUDE_BLOCK"]
out = re.sub(
    r"<!-- AON-MARKER-GET-ROLE-BRIEF-START -->.*?<!-- AON-MARKER-GET-ROLE-BRIEF-END -->",
    lambda m: new_block,
    src,
    flags=re.DOTALL,
)
p.write_text(out)
PY
    aon_ok "refreshed aon block in $repo_claude_md (rest preserved)"
  else
    printf '\n%s\n' "$block" >> "$repo_claude_md"
    aon_ok "appended aon block to $repo_claude_md (existing content preserved)"
  fi
}

cmd_join() {
  aon_load_config
  local role="${1:-}" work_repo="${2:-}"
  if [[ -z "$role" || -z "$work_repo" ]]; then
    cat >&2 <<EOF
Usage: aon join <role> <work-repo>
  role        worker role from this team's aon.toml roster
  work-repo   path to the code repo where you'll run claude
EOF
    return 2
  fi

  # Validate role against roster.
  local i found="" rname
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    rname="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ "$rname" == "$role" ]] && { found=1; break; }
  done
  [[ -n "$found" ]] || aon_fail "role '$role' not in roster (aon.toml)"

  # Validate work repo.
  work_repo="$(cd -- "$work_repo" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory"
  [[ -d "$work_repo/.git" ]] || aon_warn "$work_repo is not a git repo — continuing anyway"

  # Prereq checks.
  local need_msg=""
  for cmd_pair in "claude:npm install -g @anthropic-ai/claude-code" \
                  "nats:brew install nats-io/nats-tools/nats" \
                  "jq:brew install jq" \
                  "python3:standard" \
                  "pipx:brew install pipx && pipx ensurepath"; do
    local cmd="${cmd_pair%%:*}" hint="${cmd_pair#*:}"
    if ! command -v "$cmd" >/dev/null 2>&1; then
      aon_err "$cmd not on PATH — $hint"
      need_msg=1
    fi
  done
  [[ -z "$need_msg" ]] || return 1

  if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    aon_warn "\$ANTHROPIC_API_KEY unset — claude will prompt for login on first run"
  fi

  # All team state lives under ~/.aon/teams/<team>/. Creds + env per role,
  # repo symlink so MCP server can read role briefs.
  local team="$AON_TEAM_NAME"
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local TEAM_REPO_LINK; TEAM_REPO_LINK="$(_aon_team_repo_dir "$team")"
  mkdir -p "$CREDS_DIR" && chmod 700 "$(_aon_registry_root)"

  # Symlink ~/.aon/teams/<team>/repo → $AON_TEAM_DIR (idempotent).
  if [[ ! -e "$TEAM_REPO_LINK" ]]; then
    mkdir -p "$(dirname "$TEAM_REPO_LINK")"
    ln -s "$AON_TEAM_DIR" "$TEAM_REPO_LINK"
    aon_ok "linked $TEAM_REPO_LINK → $AON_TEAM_DIR"
  fi

  local CREDS_FILE="$CREDS_DIR/$role.password"
  if [[ ! -s "$CREDS_FILE" ]]; then
    local PWFILE; PWFILE="$(_aon_team_passwords "$AON_TEAM_NAME")"
    if [[ -r "$PWFILE" ]]; then
      # Operator-side: pull straight from .passwords.
      local upper; upper="$(printf '%s' "$role" | tr '[:lower:]' '[:upper:]')"
      local pw; pw="$(grep -E "^${upper}=" "$PWFILE" | cut -d= -f2-)"
      [[ -n "$pw" ]] || aon_fail "no ${upper}= entry in $PWFILE"
      printf '%s' "$pw" > "$CREDS_FILE"
      chmod 600 "$CREDS_FILE"
      aon_ok "creds → $CREDS_FILE (chmod 600, from $PWFILE)"
    else
      # Joiner-side: prompt.
      printf "Role password for %s: " "$role" >&2
      local PASS; IFS= read -rs PASS
      echo >&2
      [[ -n "$PASS" ]] || aon_fail "empty password"
      printf '%s' "$PASS" > "$CREDS_FILE"
      chmod 600 "$CREDS_FILE"
      unset PASS
      aon_ok "creds → $CREDS_FILE (chmod 600, prompted)"
    fi
  else
    aon_ok "creds present → $CREDS_FILE"
  fi

  # NATS URL — default from aon.toml [nats] ws_url, then url.
  local DEFAULT_URL="${TEAM_ALPHA_NATS_URL:-${AON_NATS_WS_URL:-$AON_NATS_URL}}"
  printf "NATS URL [%s]: " "$DEFAULT_URL" >&2
  local NATS_URL; read -r NATS_URL
  NATS_URL="${NATS_URL:-$DEFAULT_URL}"

  # Persist env file. MCP server + hooks read these at runtime via
  # cwd→registry resolution; no env vars are baked into per-repo files.
  local ENV_FILE="$CREDS_DIR/$role.env"
  cat > "$ENV_FILE" <<EOF
# team env for $role — read by MCP server + 'aon resolve-env'.
export TEAM_ALPHA_ROLE=$role
export TEAM_ALPHA_NATS_URL=$NATS_URL
export TEAM_ALPHA_CREDS=$CREDS_FILE
export TEAM_ALPHA_KV_BUCKET=$AON_TEAM_KV
export TEAM_ALPHA_WORK_REPO=$work_repo
EOF
  chmod 600 "$ENV_FILE"
  aon_ok "wrote $ENV_FILE"

  # Register work-repo + install MCP/CLAUDE.md BEFORE the handshake
  # probe. Stamping is idempotent and useful even when NATS isn't
  # reachable yet (e.g. operator just added the role and nats hasn't
  # reloaded auth.conf). Joiner can run claude immediately; if NATS
  # auth isn't ready, the agent's first publish will surface the real
  # cause.
  _aon_register_work_repo "$work_repo" "$team" "$role"
  aon_ok "registered $work_repo → ($team, $role)"
  _aon_install_global_mcp "$AON_ENGINE_DIR" "$work_repo"

  # NATS handshake — pub returns nonzero on failure (rtt is misleading).
  local PASS_NOSPACE; PASS_NOSPACE="$(tr -d '[:space:]' < "$CREDS_FILE")"
  aon_info "probing $NATS_URL as $role …"
  if ! nats --server "$NATS_URL" --user "$role" --password "$PASS_NOSPACE" --timeout 5s \
       pub "agents.$role.events" '{"kind":"probe","ts":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' \
       >/dev/null 2>&1; then
    cat >&2 <<EOF
⚠ NATS handshake failed (work-repo IS still set up).
  url:  $NATS_URL
  user: $role
  Common causes:
    - operator's NATS not running or tunnel down
    - operator hasn't reloaded auth.conf yet (SIGHUP the nats container)
    - wrong password (rm $CREDS_FILE && aon join $role $work_repo)
    - wrong URL
  Re-probe later:
    nats --server $NATS_URL --user $role --password \$(cat $CREDS_FILE) \\
      --timeout 5s pub agents.$role.events '{"kind":"probe"}'
EOF
    return 1
  fi
  aon_ok "NATS reachable as $role"

  cat <<EOF

✓ Setup complete.

Next:
  cd $work_repo
  claude

On first turn claude calls get_role_brief() to load your role context.
Once running, ask claude any of:
  • "start monitor"          → tails your NATS traffic
  • "doctor"                 → diagnoses the env
  • "rotate URL <bits>"      → applies new tunnel bits

Raw watch (separate terminal, no claude):
  nats --server $NATS_URL --user $role --password \$(cat $CREDS_FILE) sub 'AUDIT.>'

Env file (auto-loaded by hooks via 'aon resolve-env'):
  $ENV_FILE
EOF
}

cmd_onboard() {
  aon_load_config
  local name="${1:-}" bits="${2:-}" kind="${3:-generalist}" domain="${4:-fullstack}"
  [[ -n "$name" && -n "$bits" ]] || {
    aon_err "usage: aon onboard NAME CLOUDFLARED_BITS [KIND] [DOMAIN]"
    aon_err "  CLOUDFLARED_BITS = 4-word subdomain piece, e.g. transportation-repeated-ppm-bobby"
    aon_err "                     (full URL becomes wss://<bits>.trycloudflare.com)"
    aon_err "  defaults: KIND=generalist DOMAIN=fullstack"
    return 2
  }
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"

  # Refuse if aon.toml has a live ws_url committed — that file is in
  # git, anyone with team-repo read can learn the tunnel address.
  # Acceptable values: empty, or the literal placeholder.
  if [[ -n "$AON_NATS_WS_URL" \
        && "$AON_NATS_WS_URL" != "wss://YOUR-CURRENT-TUNNEL.trycloudflare.com" \
        && "$AON_NATS_WS_URL" != "wss://nats.example.com" ]]; then
    aon_err "✗ [nats] ws_url in aon.toml is set to a live URL: $AON_NATS_WS_URL"
    aon_err "  Bits travel out-of-band only — they must NOT live in a committed file."
    aon_err "  Fix: edit $AON_TOML and set ws_url = \"wss://YOUR-CURRENT-TUNNEL.trycloudflare.com\""
    aon_err "       (or remove the ws_url line entirely). Then re-run."
    return 1
  fi

  # Sanity: if NATS is already running, ensure its bind-mounted auth.conf
  # is the canonical one for OUR team (~/.aon/teams/<team>/auth.conf).
  # Otherwise the auth.conf we regenerate in step 3 won't be seen by
  # the running server, and step 5 silently falls through to the
  # "external NATS" branch. After the registry refactor (auth.conf out
  # of repo), the only legitimate mismatch is a stale container from
  # before the migration, mounting the old in-repo path.
  local _expected_auth; _expected_auth="$(_aon_team_auth_conf "$AON_TEAM_NAME")"
  local _running_authconf=""
  local _cid
  for _cid in $(docker ps -q 2>/dev/null); do
    local _src; _src="$(docker inspect "$_cid" --format '{{range .Mounts}}{{if eq .Destination "/etc/nats/auth.conf"}}{{.Source}}{{end}}{{end}}' 2>/dev/null)"
    if [[ -n "$_src" ]]; then
      _running_authconf="$_src"
      break
    fi
  done
  if [[ -n "$_running_authconf" && "$_running_authconf" != "$_expected_auth" ]]; then
    aon_err "Running NATS mounts auth.conf from a non-canonical path:"
    aon_err "  container mount: $_running_authconf"
    aon_err "  expected:        $_expected_auth"
    aon_err ""
    if [[ "$_running_authconf" == */nats/auth.conf ]]; then
      aon_err "Looks like a legacy container from before the registry refactor."
      aon_err "Stop it, run migrate, then restart NATS:"
      aon_err ""
      aon_err "  docker stop $_cid"
      aon_err "  aon auth migrate"
      aon_err "  aon nats up"
      aon_err "  aon onboard $name $bits ${kind:+$kind} ${domain:+$domain}"
    else
      aon_err "Stop the running NATS first ('docker stop ${_cid}') and let"
      aon_err "this onboard restart it with the canonical mount."
    fi
    return 1
  fi

  aon_info "── Step 1/8: roster ──"
  cmd_add_role "$name" "$kind" "$domain"
  aon_load_config   # reload after possible add

  aon_info "── Step 2/8: prompts render ──"
  cmd_prompts_render

  aon_info "── Step 3/8: auth render + set-passwords ──"
  cmd_auth_render
  cmd_auth_set_passwords

  aon_info "── Step 4/8: creds materialize ──"
  cmd_creds "$name"

  aon_info "── Step 5/8: NATS up + auth reload ──"
  # Three modes:
  #   - external: NATS already serving on :4222 from a process we don't
  #       own (colima VM, remote tunnel, native daemon). We don't touch
  #       it — auth.conf reload is the operator's responsibility on
  #       whatever box actually runs nats-server. Skip step 5 entirely,
  #       and skip step 6 (probe would fail until external reload).
  #   - managed-running: our compose container is up. SIGHUP the
  #       running nats-server to hot-reload the new auth.conf without
  #       dropping joiner connections.
  #   - managed-down: no container, port free. cmd_nats_up to start.
  local _pname; _pname="$(_aon_nats_project_name)"
  local _compose; _compose="$(_aon_nats_compose)"
  local _cname="${_pname}-nats-1"
  local _external=0
  # Find OUR running nats container by bind-mount, not by name. Catches
  # the case where a previous `aon nats up` ran with a different
  # project name (e.g. basename(cwd) before the team-name fix), so the
  # container is alive but doesn't match `${team}-nats-1`.
  local _our_container; _our_container="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$_our_container" ]]; then
    aon_info "container '$_our_container' mounts our auth.conf — sending SIGHUP (no drops)"
    if docker kill --signal=HUP "$_our_container" >/dev/null 2>&1; then
      sleep 1
      aon_ok "auth.conf reloaded (existing connections preserved)"
    else
      aon_warn "SIGHUP failed — falling back to recreate"
      ( cd "$AON_TEAM_DIR" && \
        docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
      aon_ok "NATS recreated"
    fi
  elif _aon_nats_port_in_use \
     && ! docker ps --filter "name=${_cname}" --format "{{.Names}}" 2>/dev/null | grep -q "${_cname}" \
     && _aon_nats_external_serving; then
    _external=1
    aon_ok "external NATS detected on :4222 — aon will not touch it."
    aon_info "  auth.conf was regenerated at $(_aon_team_auth_conf "$AON_TEAM_NAME")"
    aon_info "  Reload it on whatever process actually runs nats-server, e.g."
    aon_info "  SIGHUP nats-server (or your usual reload mechanism)."
    aon_info "  Skipping local handshake probe (step 6) — joiner's probe"
    aon_info "  in 'aon join-link' will validate auth end-to-end."
  elif docker ps --filter "name=${_cname}" --format "{{.Names}}" 2>/dev/null \
       | grep -q "${_cname}"; then
    aon_info "container running — sending SIGHUP to reload auth.conf (no drops)"
    if docker kill --signal=HUP "$_cname" >/dev/null 2>&1; then
      sleep 1
      if curl -sf http://127.0.0.1:8222/healthz >/dev/null 2>&1; then
        aon_ok "auth.conf reloaded (existing connections preserved)"
      else
        aon_warn "post-SIGHUP healthz failed — falling back to recreate"
        ( cd "$AON_TEAM_DIR" && \
          docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
        aon_ok "NATS recreated"
      fi
    else
      aon_warn "SIGHUP failed — falling back to recreate"
      ( cd "$AON_TEAM_DIR" && \
        docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
      aon_ok "NATS recreated"
    fi
  else
    if ! cmd_nats_up; then
      aon_err "✗ NATS failed to start — aborting onboard."
      aon_err "  Fix the port collision (see message above), then re-run:"
      aon_err "    aon onboard $name <bits>"
      return 1
    fi
  fi

  if [[ "$_external" -eq 1 ]]; then
    aon_info "── Step 6/8: local handshake probe (skipped — external NATS) ──"
  else
    aon_info "── Step 6/8: local handshake probe ──"
    local PROBE_PW; PROBE_PW="$(tr -d '[:space:]' < "$(_aon_role_pwfile "$name")")"
    local PROBE_URL="${AON_NATS_URL:-nats://localhost:4222}"
    # Use a role-permitted publish (same pattern as `aon join`) — `server
    # check connection` needs reply-inbox perms most roles don't have.
    if ! NATS_PASSWORD="$PROBE_PW" nats --server "$PROBE_URL" --user "$name" --timeout 5s \
         pub "agents.$name.events" '{"kind":"probe","ts":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' \
         >/dev/null 2>&1; then
      aon_err "✗ local handshake failed for $name @ $PROBE_URL"
      aon_err "  diagnose: /aon:diagnose-handshake (or aon doctor)"
      return 1
    fi
    aon_ok "local handshake OK"
  fi

  aon_info "── Step 7/8: commit + push ──"
  if [[ -n "$(git -C "$AON_TEAM_DIR" status --porcelain 2>/dev/null)" ]]; then
    git -C "$AON_TEAM_DIR" add -A
    git -C "$AON_TEAM_DIR" commit -m "Onboard $name ($kind/$domain)" >/dev/null
    if git -C "$AON_TEAM_DIR" push 2>&1 | tail -1 | grep -qiE "rejected|error"; then
      aon_warn "git push failed — push manually after resolving"
    else
      aon_ok "pushed onboarding commit"
    fi
  else
    aon_ok "no changes to commit"
  fi

  aon_info "── Step 8/8: emit share-block token ──"
  local TS_NOW TS_EXPIRE
  TS_NOW=$(_aon_iso_now)
  TS_EXPIRE=$(_aon_iso_plus_1h)
  local REPO_URL; REPO_URL="$(git -C "$AON_TEAM_DIR" remote get-url origin 2>/dev/null || echo '')"
  local PW_CONTENT; PW_CONTENT="$(cat "$(_aon_role_pwfile "$name")")"
  local ENGINE_SHA; ENGINE_SHA="$(git -C "$AON_ENGINE_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"

  # v2 token: NO nats_url. Bits travel separately, OOB-only.
  local TOKEN_JSON; TOKEN_JSON="$(jq -nc \
    --arg v "2" --arg team "$AON_TEAM_NAME" --arg url "$REPO_URL" \
    --arg role "$name" --arg pw "$PW_CONTENT" \
    --arg sha "$ENGINE_SHA" --arg exp "$TS_EXPIRE" --arg ts "$TS_NOW" \
    '{v:($v|tonumber), team:$team, team_repo_url:$url, role:$role,
      password:$pw, engine_sha:$sha,
      issued_at:$ts, expires_at:$exp}')"
  local TOKEN; TOKEN="aon://$(printf '%s' "$TOKEN_JSON" | base64 | tr -d '\n=' | sed 's|+|-|g; s|/|_|g')"

  # Engine repo URL for the joiner's clone+install. Derive from local
  # engine origin so forks / private mirrors work. Strip .git, normalize
  # ssh→https for display (joiner's `gh repo clone` accepts owner/repo).
  local ENGINE_REMOTE; ENGINE_REMOTE="$(git -C "$AON_ENGINE_DIR" remote get-url origin 2>/dev/null \
    | sed -E 's|\.git$||; s|^git@github.com:|https://github.com/|')"
  local ENGINE_URL="${ENGINE_REMOTE:-https://github.com/dincamihai/ai-over-nats}"
  local ENGINE_SLUG; ENGINE_SLUG="$(printf '%s' "$ENGINE_URL" | sed -E 's|^https://github.com/||')"

  aon_info "── doctor ──"
  cmd_doctor || aon_warn "doctor reports issues — review above"

  cat <<EOF

════════════════════════════════════════════════════════════════════
  ✓ ONBOARDING COMPLETE for: $name
════════════════════════════════════════════════════════════════════

Send the JOINER these 2 commands (1Password / private DM only —
token contains the password). Joiner needs read access on
$ENGINE_SLUG and \`gh auth login\` already done.

  gh repo clone $ENGINE_SLUG ~/Repos/ai-over-nats
  ~/Repos/ai-over-nats/bin/aon join-link $TOKEN $bits

For tunnel rotation later, joiner can PATH it:
  export PATH="\$HOME/Repos/ai-over-nats/bin:\$PATH"

Token expires: $TS_EXPIRE (1 hour)
If tunnel rotates: joiner runs  aon set-nats-url <new-bits>

Watch traffic:

  aon monitor $name

════════════════════════════════════════════════════════════════════
EOF
}

# ── helpers: cross-platform ISO-8601 timestamps ─────────────────────
_aon_iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
_aon_iso_plus_1h() {
  date -u -v+1H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || date -u -d '+1 hour' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || python3 -c 'import time, datetime as d; print((d.datetime.utcnow()+d.timedelta(hours=1)).strftime("%Y-%m-%dT%H:%M:%SZ"))'
}

# Build NATS URL from cloudflared bits or pass-through full URL.
_aon_nats_url_from_bits() {
  local bits="$1"
  if [[ "$bits" == wss://* || "$bits" == ws://* || "$bits" == nats://* ]]; then
    printf '%s' "$bits"   # full URL passed through
  else
    printf 'wss://%s.trycloudflare.com' "$bits"
  fi
}

cmd_join_link() {
  local TOKEN="${1:-}" BITS="${2:-}"
  [[ -n "$TOKEN" && -n "$BITS" ]] || {
    aon_err "usage: aon join-link <token> <cloudflared-bits>"
    aon_err "  cloudflared-bits = 4-word subdomain piece (e.g. transportation-repeated-ppm-bobby)"
    aon_err "  or full URL (wss://..., nats://...) for named tunnels"
    return 2
  }
  [[ "$TOKEN" == aon://* ]] || aon_fail "token must start with 'aon://'"

  local B64="${TOKEN#aon://}"
  B64="$(printf '%s' "$B64" | sed 's|-|+|g; s|_|/|g')"
  local PAD=$((4 - ${#B64} % 4)); [[ "$PAD" == 4 ]] || B64="$B64$(printf '=%.0s' $(seq 1 $PAD))"
  local JSON; JSON="$(printf '%s' "$B64" | base64 -d 2>/dev/null)" \
    || aon_fail "token base64 decode failed"

  local v team repo role pw sha exp legacy_nats
  v="$(printf '%s' "$JSON" | jq -r .v)"
  team="$(printf '%s' "$JSON" | jq -r .team)"
  repo="$(printf '%s' "$JSON" | jq -r .team_repo_url)"
  role="$(printf '%s' "$JSON" | jq -r .role)"
  pw="$(printf '%s' "$JSON" | jq -r .password)"
  sha="$(printf '%s' "$JSON" | jq -r .engine_sha)"
  exp="$(printf '%s' "$JSON" | jq -r .expires_at)"
  legacy_nats="$(printf '%s' "$JSON" | jq -r '.nats_url // empty')"

  case "$v" in
    1) aon_warn "v1 token (deprecated; carries nats_url). Bits arg overrides token URL." ;;
    2) : ;;
    *) aon_fail "unsupported token version: $v" ;;
  esac

  # Expiry check (string compare on ISO-8601 UTC works).
  local NOW; NOW=$(_aon_iso_now)
  if [[ "$NOW" > "$exp" ]]; then
    aon_fail "token expired at $exp — ask operator to regenerate"
  fi

  local NATS_URL; NATS_URL="$(_aon_nats_url_from_bits "$BITS")"
  aon_info "token decoded: team=$team role=$role engine_sha=$sha"
  aon_info "nats url: $NATS_URL"

  # Step 1: ensure team-aon repo at registry path ~/.aon/teams/<team>/repo.
  # If joiner ran us from inside a matching git checkout, link to it
  # instead of cloning twice.
  local TEAM_DIR; TEAM_DIR="$(_aon_team_repo_dir "$team")"
  local _norm; _norm() { printf '%s' "$1" | sed -E 's|\.git$||; s|^git@github.com:|https://github.com/|; s|/+$||'; }
  local repo_norm; repo_norm="$(_norm "$repo")"
  if [[ ! -e "$TEAM_DIR" ]]; then
    local CWD_TOP; CWD_TOP="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$CWD_TOP" ]]; then
      local CWD_ORIGIN; CWD_ORIGIN="$(git -C "$CWD_TOP" remote get-url origin 2>/dev/null || true)"
      if [[ -n "$CWD_ORIGIN" && "$(_norm "$CWD_ORIGIN")" == "$repo_norm" ]]; then
        mkdir -p "$(dirname "$TEAM_DIR")"
        ln -s "$CWD_TOP" "$TEAM_DIR"
        aon_ok "linked $TEAM_DIR → $CWD_TOP (running inside matching repo)"
      fi
    fi
  fi
  if [[ ! -e "$TEAM_DIR" ]]; then
    aon_info "cloning team-aon repo → $TEAM_DIR"
    mkdir -p "$(dirname "$TEAM_DIR")"
    git clone "$repo" "$TEAM_DIR" || aon_fail "clone failed: $repo"
  elif [[ -d "$TEAM_DIR/.git" ]]; then
    aon_ok "team-aon repo present → $TEAM_DIR"
    aon_info "git pull (fast-forward only) …"
    git -C "$TEAM_DIR" pull --ff-only 2>&1 | tail -2 || aon_warn "pull non-ff; continuing"
  fi

  # Step 2: place password file in registry.
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  mkdir -p "$CREDS_DIR" && chmod 700 "$(_aon_registry_root)"
  local PWFILE="$CREDS_DIR/$role.password"
  printf '%s' "$pw" > "$PWFILE"
  chmod 600 "$PWFILE"
  aon_ok "creds → $PWFILE (chmod 600)"

  # Step 3: detect rotation mode (existing env file + work-repo).
  local ENV_FILE="$CREDS_DIR/$role.env"
  if [[ -s "$ENV_FILE" ]]; then
    local PREV_WORK_REPO; PREV_WORK_REPO="$(grep '^export TEAM_ALPHA_WORK_REPO=' "$ENV_FILE" 2>/dev/null | cut -d= -f2-)"
    if [[ -n "$PREV_WORK_REPO" && -d "$PREV_WORK_REPO" ]]; then
      aon_info "── rotation mode: existing setup detected, refreshing URL + stamps ──"
      _aon_apply_nats_url "$role" "$PREV_WORK_REPO" "$NATS_URL"
      # Re-stamp registry + global MCP + work-repo CLAUDE.md so adding
      # the aon block later (e.g. after fixing handshake on first run)
      # actually lands. All idempotent.
      _aon_register_work_repo "$PREV_WORK_REPO" "$team" "$role"
      _aon_install_global_mcp "$AON_ENGINE_DIR" "$PREV_WORK_REPO"
      aon_ok "✓ URL rotated + stamps refreshed. Restart claude in $PREV_WORK_REPO."
      return 0
    fi
  fi

  # Step 4: cold join — prompt for work-repo + run cmd_join.
  local WORK_REPO_DEFAULT="${PWD}"
  [[ -d "$WORK_REPO_DEFAULT/.git" ]] || WORK_REPO_DEFAULT=""
  printf "Work-repo path [%s]: " "${WORK_REPO_DEFAULT:-/absolute/path/to/repo}" >&2
  local WORK_REPO; read -r WORK_REPO
  WORK_REPO="${WORK_REPO:-$WORK_REPO_DEFAULT}"
  [[ -n "$WORK_REPO" ]] || aon_fail "work-repo required"
  WORK_REPO="$(cd -- "$WORK_REPO" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory"

  export TEAM_ALPHA_NATS_URL="$NATS_URL"
  AON_TEAM_DIR="$TEAM_DIR" AON_TOML="$TEAM_DIR/aon.toml" cmd_join "$role" "$WORK_REPO"
}

# ── shared NATS URL update helper (used by cmd_join_link rotation +
#    cmd_set_nats_url). Updates ~/.aon/teams/<team>/creds/<role>.env +
#    re-probes handshake. No per-repo patches — MCP server reads URL
#    from registry on next startup.
_aon_apply_nats_url() {
  local role="$1" work_repo="$2" nats_url="$3"

  # Resolve team from work-repo path (registry lookup); fall back to
  # team-alpha for legacy callers.
  local team="team-alpha"
  if [[ -n "$work_repo" ]]; then
    local res; res="$(_aon_resolve_from_cwd "$work_repo" 2>/dev/null)" || true
    if [[ -n "$res" ]]; then
      IFS=$'\t' read -r team _ _ <<<"$res"
    fi
  fi
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local ENV_FILE="$CREDS_DIR/$role.env"
  local PW_FILE="$CREDS_DIR/$role.password"

  if [[ -s "$ENV_FILE" ]]; then
    if grep -q '^export TEAM_ALPHA_NATS_URL=' "$ENV_FILE"; then
      _aon_inplace_sed "$ENV_FILE" "s|^export TEAM_ALPHA_NATS_URL=.*|export TEAM_ALPHA_NATS_URL=$nats_url|"
    else
      printf 'export TEAM_ALPHA_NATS_URL=%s\n' "$nats_url" >> "$ENV_FILE"
    fi
    chmod 600 "$ENV_FILE"
    aon_ok "updated $ENV_FILE"
  else
    aon_warn "$ENV_FILE missing — env not updated"
  fi

  if [[ ! -f "$PW_FILE" ]]; then
    aon_warn "$PW_FILE missing — skipping handshake probe"
    return 0
  fi
  local PW; PW="$(tr -d '[:space:]' < "$PW_FILE")"
  if NATS_PASSWORD="$PW" nats --server "$nats_url" --user "$role" --timeout 5s \
       pub "agents.$role.events" '{"kind":"probe","ts":"'"$(_aon_iso_now)"'"}' \
       >/dev/null 2>&1; then
    aon_ok "handshake OK against $nats_url"
  else
    aon_warn "handshake FAILED against $nats_url — verify bits + tunnel up"
    return 1
  fi
}

# Cross-platform sed -i (macOS uses BSD sed which needs -i ''; GNU sed
# uses -i alone). Write to temp + mv to avoid the difference.
_aon_inplace_sed() {
  local file="$1" expr="$2"
  local tmp; tmp="$(mktemp "${file}.XXXXXX")"
  sed "$expr" "$file" > "$tmp" && mv "$tmp" "$file"
}

cmd_set_nats_url() {
  local BITS="${1:-}"
  local explicit_role="${TEAM_ALPHA_ROLE:-}"
  # parse --role flag (surgical override; default rotates ALL roles).
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role) explicit_role="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  [[ -n "$BITS" ]] || { aon_err "usage: aon set-nats-url <cloudflared-bits> [--role NAME]"; return 2; }

  local NATS_URL; NATS_URL="$(_aon_nats_url_from_bits "$BITS")"

  # Decide which role env files to rotate.
  #   --role NAME (or $TEAM_ALPHA_ROLE) → only that one
  #   otherwise                          → every role in every team
  # Tunnel URL is a team-scoped config param: one team-aon repo, one
  # cloudflared, one wss URL; every role in the team points at it.
  # Rotation defaults to "all roles in the team(s) on this host".
  local team="${AON_TEAM:-team-alpha}"
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local -a targets=()
  if [[ -n "$explicit_role" ]]; then
    targets=("$CREDS_DIR/$explicit_role.env")
    [[ -s "${targets[0]}" ]] || aon_fail "no ${targets[0]} — run 'aon join-link' first"
  else
    local f
    for f in "$CREDS_DIR"/*.env; do
      [[ -s "$f" ]] && targets+=("$f")
    done
    [[ "${#targets[@]}" -gt 0 ]] || aon_fail "no env files in $CREDS_DIR — run 'aon join-link' first"
    aon_info "rotating $((${#targets[@]})) role(s) in $team → $NATS_URL"
  fi

  local fail=0
  local env
  for env in "${targets[@]}"; do
    local role; role="$(basename "$env" .env)"
    local WORK_REPO; WORK_REPO="$(grep '^export TEAM_ALPHA_WORK_REPO=' "$env" 2>/dev/null | cut -d= -f2-)"
    aon_info "── role: $role ──"
    if [[ -z "$WORK_REPO" || ! -d "$WORK_REPO" ]]; then
      aon_warn "  no TEAM_ALPHA_WORK_REPO in $env (or path missing) — updating env file only"
      # Still update the env file so future re-stamps see the new URL.
      if grep -q '^export TEAM_ALPHA_NATS_URL=' "$env"; then
        _aon_inplace_sed "$env" "s|^export TEAM_ALPHA_NATS_URL=.*|export TEAM_ALPHA_NATS_URL=$NATS_URL|"
      else
        printf 'export TEAM_ALPHA_NATS_URL=%s\n' "$NATS_URL" >> "$env"
      fi
      chmod 600 "$env"
      aon_ok "  updated $env (env-only)"
      continue
    fi
    if ! _aon_apply_nats_url "$role" "$WORK_REPO" "$NATS_URL"; then
      fail=$((fail+1))
      aon_warn "  rotation failed for role $role (continuing with other roles)"
    fi
  done

  if [[ "$fail" -gt 0 ]]; then
    aon_err "✗ $fail role(s) failed to rotate — see warnings above"
    return 1
  fi
  aon_ok "✓ Restart claude in each work-repo to pick up new env."
}

cmd_monitor() {
  # Resolve role + nats URL + creds from cwd→registry first; fall back to
  # operator flow (aon_load_config + arg/$TEAM_ALPHA_ROLE) if cwd isn't
  # registered. Lets joiner run `aon monitor` from work-repo with no args.
  local role="${1:-}" nats_url="" creds="" team="" kv="team-state"

  local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || res=""
  if [[ -n "$res" ]]; then
    local r_team r_role _; IFS=$'\t' read -r r_team r_role _ <<<"$res"
    role="${role:-$r_role}"
    team="$r_team"
    creds="$(_aon_role_pwfile "$role" "$team")"
    local env_file; env_file="$(_aon_team_creds_dir "$team")/$role.env"
    if [[ -f "$env_file" ]]; then
      nats_url="$(grep '^export TEAM_ALPHA_NATS_URL=' "$env_file" 2>/dev/null | cut -d= -f2-)"
      local k; k="$(grep '^export TEAM_ALPHA_KV_BUCKET=' "$env_file" 2>/dev/null | cut -d= -f2-)"
      [[ -n "$k" ]] && kv="$k"
    fi
  else
    aon_load_config
    role="${role:-${TEAM_ALPHA_ROLE:-}}"
    [[ -n "$role" ]] || aon_fail "usage: aon monitor <role>   (or cd into a registered work-repo)"
    creds="$(_aon_role_pwfile "$role")"
    nats_url="$AON_NATS_URL"
    kv="$AON_TEAM_KV"
  fi

  [[ -s "$creds" ]] || aon_fail "no creds at $creds — run 'aon creds $role' or 'aon join-link' first"
  [[ -n "$nats_url" ]] || aon_fail "no NATS URL — env file missing or not set"

  local SCRIPT="$AON_ENGINE_DIR/scripts/hooks/role-monitor.sh"
  [[ -x "$SCRIPT" ]] || aon_fail "role-monitor.sh not executable: $SCRIPT"

  export TEAM_ALPHA_ROLE="$role"
  export TEAM_ALPHA_NATS_URL="$nats_url"
  export TEAM_ALPHA_CREDS="$creds"
  export TEAM_ALPHA_KV_BUCKET="$kv"
  exec bash "$SCRIPT" "$role"
}

cmd_apparmor() {
  if [[ -x "$AON_ENGINE_DIR/bin/team-alpha-apparmor" ]]; then
    exec "$AON_ENGINE_DIR/bin/team-alpha-apparmor" "$@"
  else
    aon_fail "team-alpha-apparmor not found at $AON_ENGINE_DIR/bin/team-alpha-apparmor"
  fi
}

case "${1:-}" in
  init)      shift; cmd_init "$@" ;;
  onboard)   shift; cmd_onboard "$@" ;;
  add-role)  shift; cmd_add_role "$@" ;;
  doctor)    shift; cmd_doctor "$@" ;;
  prompts)   shift; cmd_prompts "$@" ;;
  auth)      shift; cmd_auth "$@" ;;
  bootstrap) shift; cmd_bootstrap "$@" ;;
  nats)      shift; cmd_nats "$@" ;;
  creds)     shift; cmd_creds "$@" ;;
  launch)    shift; cmd_launch "$@" ;;
  join)      shift; cmd_join "$@" ;;
  join-link) shift; cmd_join_link "$@" ;;
  set-nats-url) shift; cmd_set_nats_url "$@" ;;
  resolve-env) shift; cmd_resolve_env "$@" ;;
  monitor)   shift; cmd_monitor "$@" ;;
  apparmor)  shift; cmd_apparmor "$@" ;;
  help|-h|--help) usage ;;
  "")        usage; exit 1 ;;
  *)         aon_err "unknown command: $1"; usage; exit 2 ;;
esac
