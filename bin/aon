#!/usr/bin/env bash
# aon — ai-over-nats engine CLI.
#
# Operator entrypoint. Run from inside a per-team repo.
#
# Subcommands:
#   init                   bootstrap harness in current repo
#   add-role NAME KIND     append role to roster (kind ∈ manager|generalist|specialist)
#   doctor                 sanity-check the local setup
#   apparmor SUB           manage personal AppArmor overrides (Cards 228/229)
#                          (delegates to bin/aon-apparmor for now)
#   help                   this help

set -uo pipefail

_aon_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_aon-lib.sh
source "$_aon_dir/_aon-lib.sh"

usage() {
  cat <<EOF
aon — ai-over-nats engine CLI

usage: aon <command> [args]

Commands:
  init                       bootstrap harness in current repo
  onboard NAME BITS [KIND] [DOMAIN]  one-shot operator onboarding (recommended)
                             BITS = current cloudflared subdomain (4-word piece)
                             composes add-role + render + auth + creds + nats up
                             + handshake probe + commit/push + token emit
                             defaults: KIND=generalist, DOMAIN=fullstack
  add-role NAME [KIND] [DOMAIN]  append role to aon.toml roster
                             defaults: KIND=generalist, DOMAIN=fullstack
  doctor                     sanity-check local setup
  prompts render             render agent-prompts/<role>.md from templates
  auth render                mint NSC operator + account + per-role users from
                             aon.toml; render nats-server.conf with JWT
                             placeholders substituted; publish account JWT to
                             ~/.aon/teams/<team>/nats/resolver/.
  auth set-passwords         no-op (deprecated under JWT auth)
  auth migrate               move legacy nats/auth.conf + .passwords out of repo
  bootstrap                  ensure JetStream streams + KV from aon.toml roster
  nats SUB                   docker compose wrapper (up|down|logs|status|reload)
  creds ROLE [DEST]          emit per-role .creds file via nsc (chmod 600)
                             default DEST: ~/.aon/teams/<team>/creds/<role>.creds
  creds --all                emit .creds for every NSC user in the team account
  revoke ROLE                revoke ROLE's user JWT (re-publishes team JWT)
  revoke list                list revoked users in this team's account
  revoke clear ROLE          un-revoke ROLE
  launch ROLE [WORK_REPO]    set env, install hooks, exec claude as ROLE
  join ROLE WORK_REPO        full joiner setup (creds, .mcp.json, hooks,
                             CLAUDE.md symlink, NATS handshake)
  join-link TOKEN BITS       one-shot joiner setup from operator's token + bits
                             (recommended) — clones team repo, places creds,
                             runs aon join automatically. Re-run with new BITS
                             to rotate the NATS URL only (no re-clone).
  set-nats-url BITS          joiner-side tunnel rotation (no re-clone, no creds
                             change) — updates env + .mcp.json + settings.json
                             and re-probes handshake. Use --role NAME if more
                             than one role on this box.
  monitor [ROLE]             exec role-monitor.sh with env baked from
                             aon.toml + ~/.aon/teams/<team>/creds/<role>.creds
                             (defaults role from \$AON_ROLE)
  pub SUBJECT PAYLOAD        publish as cwd's role (auth auto-injected).
                             Use this for DMs, broadcasts, A2A, KV writes —
                             NEVER call \`nats pub\` directly (no creds).
                             Examples:
                               aon pub agents.vahid.inbox "Hi from mihai"
                               aon pub broadcast.team "Standup at 10am"
  sub SUBJECT                subscribe as cwd's role (long-running stream;
                             use Monitor tool, not Bash)
  req SUBJECT PAYLOAD        request/reply as cwd's role
  apparmor SUB               personal AppArmor overrides (sync|show|reload|watch)
  help                       this help

Env:
  AON_ENGINE_DIR             engine repo path (auto-detected)
  AON_TEAM_DIR               per-team repo path (default: cwd)
EOF
}

cmd_init() {
  aon_load_config
  aon_info "aon init — team=$AON_TEAM_NAME engine=$AON_ENGINE_DIR"

  if [[ "$AON_TOML_PRESENT" -eq 0 ]]; then
    # Default team name from cwd basename — operator can edit before
    # any onboard. Avoids every fresh init starting as "team-alpha".
    local _team_default; _team_default="$(basename "$AON_TEAM_DIR")"
    local _operator_default="${AON_OPERATOR:-${USER:-operator}}"
    aon_render "$AON_ENGINE_DIR/templates/aon.toml.example" "$AON_TOML" \
      "TEAM_NAME=$_team_default" \
      "OPERATOR=$_operator_default"
    aon_ok "wrote $AON_TOML (team=$_team_default operator=$_operator_default — edit if you want different)"
    aon_load_config   # reload after creating
  else
    aon_ok "aon.toml present (schema=$AON_SCHEMA, $AON_ROLES_COUNT roles)"
  fi

  mkdir -p "$AON_TEAM_DIR/$AON_TASK_DIR"        \
           "$AON_TEAM_DIR/$AON_PROMPTS_DIR"     \
           "$AON_TEAM_DIR/$AON_AGENTS_DIR"      \
           "$AON_TEAM_DIR/$AON_HOOKS_DIR"
  aon_ok "directory tree present"

  # Auto-init git so subsequent `aon onboard`'s commit/push step can't
  # walk up to $HOME/.git. Idempotent — skip if already a repo. Default
  # branch name `main` matches GitHub's default to avoid the legacy
  # `master` rename dance on first push.
  if [[ ! -d "$AON_TEAM_DIR/.git" ]]; then
    git -C "$AON_TEAM_DIR" init -q -b main
    aon_ok "initialized git repo (branch main)"
  fi

  # nats-server.conf is rendered into ~/.aon/teams/<team>/nats/ by
  # `aon auth render` and the docker-compose runtime dir bind-mount
  # exposes it at /etc/nats/runtime/nats-server.conf inside the
  # container. No team-repo copy needed — keeps placeholders out of
  # the committed tree.
  local COMPOSE="$AON_TEAM_DIR/docker-compose.yml"
  if [[ ! -f "$COMPOSE" ]]; then
    local _nats_dir; _nats_dir="$(_aon_team_nats_dir "$AON_TEAM_NAME")"
    mkdir -p "$_nats_dir"
    aon_render "$AON_ENGINE_DIR/templates/docker-compose.yml.tmpl" "$COMPOSE" \
      "TEAM_NAME=$AON_TEAM_NAME" \
      "NATS_DIR_PATH=$_nats_dir"
    aon_ok "wrote docker-compose.yml"
  fi

  cat <<EOF >&2

Next steps:
  1. Edit $AON_TOML — set roster + NATS URLs.
  2. Render agent prompts:  aon prompts render
  3. Render NSC + nats-server.conf:  aon auth render
  4. Bring up NATS:         aon nats up
  5. Bootstrap streams:     aon bootstrap
  6. Launch your role:      aon launch <role>
EOF
}

cmd_add_role() {
  local name="${1:-}" kind="${2:-generalist}" domain="${3:-fullstack}"
  [[ -n "$name" ]] || {
    aon_err "usage: aon add-role NAME [KIND] [DOMAIN]"
    aon_err "  KIND ∈ manager | generalist | specialist  (default: generalist)"
    aon_err "  DOMAIN: primary skill                      (default: fullstack)"
    return 2
  }
  case "$kind" in
    manager|generalist|specialist) ;;
    *) aon_fail "kind must be manager|generalist|specialist (got: $kind)" ;;
  esac

  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"

  # Detect existing role (idempotency).
  local i count
  count="$AON_ROLES_COUNT"
  for ((i=0; i<count; i++)); do
    if [[ "$(aon_toml_array_get "$AON_TOML" roles "$i" name)" == "$name" ]]; then
      aon_warn "role '$name' already in roster (index $i) — leaving as-is"
      return 0
    fi
  done

  cat >> "$AON_TOML" <<EOF

[[roles]]
name   = "$name"
kind   = "$kind"
domain = "$domain"
EOF
  aon_ok "appended role '$name' ($kind / $domain) to $AON_TOML"
  aon_warn "Templates not yet wired — run 'aon prompts render' + 'aon auth render' once Cards 234/235 land."
}

cmd_doctor() {
  aon_load_config
  local fail=0
  ok() { aon_ok "$*"; }
  bad() { aon_err "$*"; fail=1; }

  [[ "$AON_TOML_PRESENT" -eq 1 ]] && ok "aon.toml present" || bad "aon.toml missing — run 'aon init'"
  [[ -d "$AON_TEAM_DIR/$AON_TASK_DIR" ]]    && ok "$AON_TASK_DIR/ present"    || bad "$AON_TASK_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_PROMPTS_DIR" ]] && ok "$AON_PROMPTS_DIR/ present" || bad "$AON_PROMPTS_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_AGENTS_DIR" ]]  && ok "$AON_AGENTS_DIR/ present"  || bad "$AON_AGENTS_DIR/ missing"
  if [[ -d "$AON_TEAM_DIR/.git" ]]; then
    ok ".git/ present (onboard commit/push won't walk up to \$HOME)"
  else
    bad ".git/ missing at $AON_TEAM_DIR — re-run 'aon init' or 'git -C $AON_TEAM_DIR init'"
  fi

  if [[ "$AON_ROLES_COUNT" -gt 0 ]]; then
    ok "roster has $AON_ROLES_COUNT role(s)"
    local i name kind
    for ((i=0; i<AON_ROLES_COUNT; i++)); do
      name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
      kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
      printf '    - %-12s %s\n' "$name" "$kind" >&2
    done
  else
    bad "roster empty"
  fi

  if command -v nats >/dev/null 2>&1; then ok "nats CLI present"; else bad "nats CLI not on PATH"; fi
  if command -v jq   >/dev/null 2>&1; then ok "jq present";       else bad "jq not on PATH"; fi
  if command -v claude >/dev/null 2>&1; then ok "claude CLI present"; else bad "claude CLI not on PATH"; fi

  # NSC migration tooling (warn only — used by scripts/nsc-smoke + the
  # forthcoming JWT-based auth pipeline; not blocking until cutover).
  if command -v nsc >/dev/null 2>&1; then
    ok "nsc present ($(nsc --version 2>&1 | tr -d '\n'))"
  else
    aon_warn "nsc not on PATH — needed by scripts/nsc-smoke and the JWT migration (brew install nats-io/nats-tools/nsc)"
  fi
  if command -v timeout >/dev/null 2>&1 || command -v gtimeout >/dev/null 2>&1; then
    ok "GNU timeout present"
  else
    aon_warn "no GNU timeout (gtimeout) — needed by scripts/nsc-smoke (brew install coreutils)"
  fi

  # ── Operator-side runtime state (rendered nats-server.conf + resolver dir) ──
  if [[ "$AON_TOML_PRESENT" -eq 1 ]]; then
    local _natsdir; _natsdir="$(_aon_team_nats_dir "$AON_TEAM_NAME")"
    local _conf="$_natsdir/nats-server.conf"
    local _rdir="$_natsdir/resolver"
    if [[ -d "$_natsdir" ]]; then
      ok "nats runtime dir → $_natsdir"
    else
      aon_warn "no $_natsdir (run 'aon auth render')"
    fi
    if [[ -f "$_conf" ]]; then
      if grep -E '@(OP_JWT|SYS_ID|SYS_JWT|TEAM_NAME)@' "$_conf" >/dev/null 2>&1; then
        bad "$_conf has unsubstituted placeholders — re-run 'aon auth render'"
      else
        ok "nats-server.conf rendered → $_conf"
      fi
    else
      aon_warn "no $_conf (operator only — run 'aon auth render')"
    fi
    if [[ -d "$_rdir" ]] && compgen -G "$_rdir/*.jwt" >/dev/null; then
      ok "resolver dir has $(ls "$_rdir"/*.jwt 2>/dev/null | wc -l | tr -d ' ') account JWT(s)"
    else
      aon_warn "no account JWT(s) under $_rdir (operator only — run 'aon auth render')"
    fi
    # Detect lingering legacy files in repo.
    if [[ -f "$AON_TEAM_DIR/nats/auth.conf" || -f "$AON_TEAM_DIR/nats/.passwords" ]]; then
      bad "legacy in-repo state still present under $AON_TEAM_DIR/nats/ — run 'aon auth migrate'"
    fi
    # Half-migrated team: team-repo nats-server.conf with unrendered
    # placeholders means docker-compose still mounts the template and
    # nats-server will restart-loop. Fix: drop team-repo file + bounce
    # NATS so the runtime-dir mount takes effect.
    local _repo_conf="$AON_TEAM_DIR/nats/nats-server.conf"
    if [[ -f "$_repo_conf" ]] && grep -E '@(OP_JWT|SYS_ID|SYS_JWT|TEAM_NAME)@' "$_repo_conf" >/dev/null 2>&1; then
      bad "$_repo_conf has unsubstituted placeholders — delete it and bounce NATS (template is now runtime-mounted)"
    fi
    # Legacy artifacts under registry root — fine to leave during soak.
    if [[ -f "$_natsdir/auth.conf" ]]; then
      aon_warn "legacy auth.conf at $_natsdir/auth.conf — safe to delete after JWT cutover soak"
    fi
    if [[ -f "$HOME/.aon/teams/$AON_TEAM_NAME/.passwords" ]]; then
      aon_warn "legacy .passwords at ~/.aon/teams/$AON_TEAM_NAME/.passwords — safe to delete after JWT cutover soak"
    fi
  fi

  # ── Registry / cwd resolution ──
  local reg; reg="$(_aon_work_repos_json)"
  if [[ -f "$reg" ]]; then
    local count; count="$(jq 'length' "$reg" 2>/dev/null || echo 0)"
    ok "registry: $reg ($count work-repo entry/entries)"
    local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || res=""
    if [[ -n "$res" ]]; then
      local rt rr rp; IFS=$'\t' read -r rt rr rp <<<"$res"
      ok "cwd resolves → team=$rt role=$rr (work-repo: $rp)"
      local creds; creds="$(_aon_role_creds "$rr" "$rt")"
      [[ -f "$creds" ]] && ok "creds present → $creds" || bad "creds missing → $creds"
    else
      ok "cwd not in registry (operator dir or untracked work-repo) — fine"
    fi
  else
    ok "no registry yet ($reg) — first 'aon join' creates it"
  fi
  [[ -f "$HOME/.claude/settings.json" ]] && ok "global ~/.claude/settings.json present" \
    || aon_warn "no ~/.claude/settings.json — run 'aon join' to install global MCP+hooks"

  echo >&2
  if [[ "$fail" -eq 0 ]]; then
    aon_ok "PASS — local setup looks healthy."
    return 0
  else
    aon_err "FAIL — fix items above."
    return 1
  fi
}

cmd_prompts() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render) cmd_prompts_render "$@" ;;
    -h|--help|help|"") echo "Usage: aon prompts render" >&2 ;;
    *) aon_err "aon prompts: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_prompts_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local TPL="$AON_ENGINE_DIR/templates/agent-prompts"
  local OUT="$AON_TEAM_DIR/$AON_PROMPTS_DIR"
  mkdir -p "$OUT"

  # Render _common.md once, shared by all roles.
  aon_render "$TPL/_common.md.tmpl" "$OUT/_common.md" \
    "TEAM_NAME=$AON_TEAM_NAME" \
    "KV_BUCKET=$AON_TEAM_KV"
  aon_ok "rendered $OUT/_common.md"

  local i name kind domain learning title
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    title="$(printf '%s' "$name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
    [[ -f "$TPL/$kind.md.tmpl" ]] || { aon_warn "no template for kind=$kind ($name) — skipping"; continue; }
    aon_render "$TPL/$kind.md.tmpl" "$OUT/$name.md" \
      "ROLE=$name" \
      "ROLE_TITLE=$title" \
      "DOMAIN=$domain" \
      "LEARNING=${learning:-$domain}" \
      "TEAM_NAME=$AON_TEAM_NAME" \
      "KV_BUCKET=$AON_TEAM_KV"
    aon_ok "rendered $OUT/$name.md ($kind / $domain)"
  done
}

cmd_auth() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render)        cmd_auth_render "$@" ;;
    set-passwords) cmd_auth_set_passwords "$@" ;;
    migrate)       cmd_auth_migrate "$@" ;;
    -h|--help|help|"") cat >&2 <<EOF
Usage: aon auth <render|set-passwords|migrate>
  render          mint NSC operator + account + per-role users from
                  aon.toml roster; render nats-server.conf with JWT
                  placeholders substituted; publish team account JWT
                  to ~/.aon/teams/<team>/nats/resolver/.
  set-passwords   no-op under JWT auth (kept as a deprecation stub
                  so existing scripts don't crash mid-cutover).
  migrate         move legacy nats/auth.conf + nats/.passwords out of the
                  team-aon repo into ~/.aon/teams/<team>/. Idempotent.
EOF
    ;;
    *) aon_err "aon auth: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_auth_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  command -v nsc >/dev/null 2>&1 \
    || aon_fail "nsc not on PATH — install via 'brew install nats-io/nats-tools/nsc'"

  local team="$AON_TEAM_ACCOUNT"
  local kv="$AON_TEAM_KV"
  local nats_url; nats_url="$(aon_toml_get "$AON_TOML" nats url 2>/dev/null || echo 'nats://localhost:4222')"
  [[ -n "$nats_url" ]] || nats_url="nats://localhost:4222"

  aon_info "── 1/4 ensure NSC operator + account ──"
  _aon_nsc_ensure_operator "$nats_url"
  _aon_nsc_ensure_account "$team"
  aon_ok "operator=$(_aon_nsc_operator)  account=$team"

  aon_info "── 2/4 ensure users (sysadmin + ${AON_ROLES_COUNT} role(s)) ──"
  # sysadmin always present (used by bootstrap.sh + ops scripts).
  _aon_nsc_ensure_user "$team" "$kv" sysadmin sysadmin
  local i name kind domain learning created=0 existed=0
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    if nsc describe user --account "$team" --name "$name" >/dev/null 2>&1; then
      existed=$((existed+1))
    else
      _aon_nsc_ensure_user "$team" "$kv" "$name" "$kind" "$domain" "$learning" \
        || aon_fail "failed to add user '$name' (kind=$kind)"
      created=$((created+1))
    fi
  done
  aon_ok "users: created=$created existed=$existed (sysadmin always ensured)"

  aon_info "── 3/4 publish team account JWT ──"
  _aon_nsc_publish_team_jwt "$team"
  local rdir; rdir="$(_aon_nsc_resolver_dir "$team")"
  aon_ok "team JWT → $rdir"
  # Soft-push to running server too (no-op + warn if NATS isn't up
  # yet; on first render the substrate hasn't started). After cutover
  # this keeps the in-memory JWT in sync on roster expansion.
  _aon_nsc_push_team_jwt "$team"

  aon_info "── 4/4 render nats-server.conf ──"
  local TPL="$AON_ENGINE_DIR/templates/nats-server.conf"
  local OUT; OUT="$(_aon_team_nats_dir "$AON_TEAM_NAME")/nats-server.conf"
  [[ -r "$TPL" ]] || aon_fail "missing template: $TPL"
  mkdir -p "$(dirname "$OUT")"
  chmod 700 "$(_aon_registry_root)" 2>/dev/null || true

  local OP_JWT SYS_ID SYS_JWT
  OP_JWT="$(_aon_nsc_op_jwt)"
  SYS_ID="$(_aon_nsc_sys_id)"
  SYS_JWT="$(_aon_nsc_sys_jwt)"
  [[ -n "$OP_JWT" && -n "$SYS_ID" && -n "$SYS_JWT" ]] \
    || aon_fail "missing operator/SYS JWT (run 'aon doctor' for diagnostics)"

  local TMP; TMP="$(mktemp)"
  sed -e "s|@OP_JWT@|$OP_JWT|g" \
      -e "s|@SYS_ID@|$SYS_ID|g" \
      -e "s|@SYS_JWT@|$SYS_JWT|g" \
      -e "s|@TEAM_NAME@|$AON_TEAM_NAME|g" \
      "$TPL" > "$TMP"
  if grep -E '@(OP_JWT|SYS_ID|SYS_JWT|TEAM_NAME)@' "$TMP" >/dev/null; then
    rm -f "$TMP"
    aon_fail "unsubstituted placeholders remain after render — template + getters out of sync"
  fi
  install -m 0644 "$TMP" "$OUT"
  rm -f "$TMP"
  aon_ok "rendered $OUT"
  aon_info "Next: aon creds <role>  (writes per-role .creds for distribution)"
}

cmd_auth_set_passwords() {
  # Deprecated: under JWT auth, per-role creds are .creds files emitted
  # via `aon creds` (which calls nsc generate creds). There are no
  # passwords to set. Kept as a stub so legacy scripts that chain
  #   aon auth render && aon auth set-passwords
  # don't crash mid-cutover. Will be removed after the soak window.
  aon_warn "aon auth set-passwords is a no-op under JWT auth (deprecated; remove from scripts)"
  aon_info "use 'aon creds <role>' to emit a .creds file via nsc"
}

# Move legacy nats/auth.conf, nats/.passwords, nats/auth.conf.example
# from $AON_TEAM_DIR/nats/ to ~/.aon/teams/<team>/. Idempotent.
cmd_auth_migrate() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — cd into a team-aon repo first"

  local team="$AON_TEAM_NAME"
  local STATE; STATE="$(_aon_team_state_dir "$team")"
  mkdir -p "$STATE"
  chmod 700 "$(_aon_registry_root)" 2>/dev/null || true

  local moved=0 skipped=0
  _migrate_one() {
    local src="$1" dst="$2" mode="$3"
    if [[ ! -f "$src" ]]; then
      return 0
    fi
    if [[ -f "$dst" ]]; then
      if cmp -s "$src" "$dst"; then
        aon_ok "already migrated: $dst"
      else
        local s_size d_size
        s_size="$(wc -c <"$src" | tr -d ' ')"
        d_size="$(wc -c <"$dst" | tr -d ' ')"
        aon_warn "skip $src → $dst (target exists, sizes differ: src=$s_size dst=$d_size)"
        aon_warn "  resolve manually; rerun migrate after."
      fi
      skipped=$((skipped+1))
      return 0
    fi
    cp "$src" "$dst"
    chmod "$mode" "$dst"
    aon_ok "migrated $src → $dst (chmod $mode)"
    moved=$((moved+1))
  }

  _migrate_one "$AON_TEAM_DIR/nats/auth.conf"         "$STATE/auth.conf"         "0644"
  _migrate_one "$AON_TEAM_DIR/nats/.passwords"        "$STATE/.passwords"        "0600"
  _migrate_one "$AON_TEAM_DIR/nats/auth.conf.example" "$STATE/auth.conf.example" "0644"

  echo >&2
  aon_info "migrate summary: moved=$moved skipped=$skipped"
  echo >&2
  if [[ -f "$AON_TEAM_DIR/nats/auth.conf" || -f "$AON_TEAM_DIR/nats/.passwords" || -f "$AON_TEAM_DIR/nats/auth.conf.example" ]]; then
    cat >&2 <<EOF
Now remove the originals from the team-aon repo (operator runs, not aon):

  cd $AON_TEAM_DIR
  git rm --cached nats/auth.conf nats/.passwords nats/auth.conf.example 2>/dev/null
  rm -f nats/auth.conf nats/.passwords nats/auth.conf.example
  # ensure .gitignore covers them:
  printf '%s\n' 'nats/auth.conf' 'nats/.passwords' 'nats/auth.conf.example' >> .gitignore
  sort -u .gitignore -o .gitignore
  git add .gitignore && git commit -m "Move auth.conf + .passwords out of repo"

If NATS is running with the OLD bind-mount, restart it so the new mount
takes effect:
  aon nats down && aon nats up
EOF
  fi
}

cmd_bootstrap() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  # Sysadmin .creds — emit if missing (operator side, NSC available).
  local SYS_CREDS; SYS_CREDS="$(_aon_role_creds sysadmin)"
  if [[ ! -s "$SYS_CREDS" ]]; then
    aon_info "sysadmin creds missing — running 'aon creds sysadmin'"
    cmd_creds sysadmin "$SYS_CREDS" \
      || aon_fail "could not emit sysadmin creds — run 'aon auth render' first"
  fi

  # Build roster string from aon.toml roles.
  local roster=""
  local i name
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ -n "$name" ]] && roster+="${roster:+ }$name"
  done

  local script="$AON_ENGINE_DIR/scripts/bootstrap.sh"
  [[ -x "$script" ]] || aon_fail "engine bootstrap not executable: $script"

  aon_info "aon bootstrap — team=$AON_TEAM_NAME url=$AON_NATS_URL roles=($roster)"
  AON_ROSTER="$roster" \
  AON_KV_BUCKET="$AON_TEAM_KV" \
  NATS_URL="$AON_NATS_URL" \
  NATS_ADMIN_CREDS="$SYS_CREDS" \
    bash "$script"
}

cmd_nats() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    up|start)     cmd_nats_up "$@" ;;
    down|stop)    cmd_nats_down "$@" ;;
    logs)   cmd_nats_logs "$@" ;;
    status) cmd_nats_status "$@" ;;
    reload) cmd_nats_reload "$@" ;;
    migrate-mount) cmd_nats_migrate_mount "$@" ;;
    -h|--help|help|"") cat >&2 <<EOF
Usage: aon nats <up|down|logs|status|reload|migrate-mount>
  up              docker compose up -d nats
  down            docker compose down nats
  logs            docker compose logs -f nats
  status          ps + healthz
  reload          send SIGHUP to the running nats container — reloads
                  nats-server.conf (cluster routes, log levels, etc.).
                  Does NOT force the dir resolver to re-scan account
                  JWTs; that path is `nsc push`, which 'aon revoke'
                  and 'aon auth render' do internally.
  migrate-mount   move legacy ~/.aon/teams/<team>/auth.conf into the
                  new nats/ subdir + regenerate docker-compose.yml so
                  the container does a directory bind-mount instead
                  of single-file (fixes macOS bind-mount staleness).
                  Idempotent. Safe to re-run.
EOF
    ;;
    *) aon_err "aon nats: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_nats_reload() {
  aon_load_config
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)" || cname=""
  if [[ -z "$cname" ]]; then
    # Fall back to any container running nats:* image — e.g. a hand-run
    # `docker run nats` outside compose.
    local cid
    cid="$(docker ps --format '{{.ID}} {{.Image}}' 2>/dev/null \
           | awk '$2 ~ /^nats(:|$)/ {print $1; exit}')"
    if [[ -n "$cid" ]]; then
      cname="$(docker inspect "$cid" --format '{{.Name}}' 2>/dev/null | sed 's|^/||')"
    fi
  fi
  if [[ -z "$cname" ]]; then
    aon_err "no running nats container found"
    aon_err "  start one: aon nats up"
    return 1
  fi
  if ! docker kill -s HUP "$cname" >/dev/null 2>&1; then
    aon_err "docker kill -s HUP $cname failed"
    return 1
  fi
  aon_ok "SIGHUP sent → $cname (nats-server.conf reloaded)"
  aon_info "note: SIGHUP does NOT push account JWTs — for revoke/claim updates use 'aon revoke' (which calls nsc push internally)"
}

# Move legacy ~/.aon/teams/<team>/{auth.conf,auth.conf.example} into
# the new nats/ subdir, and regenerate docker-compose.yml so the
# directory bind-mount takes effect on next 'aon nats up'. Idempotent.
cmd_nats_migrate_mount() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — cd into a team-aon repo first"

  local team="$AON_TEAM_NAME"
  local STATE; STATE="$(_aon_team_state_dir "$team")"
  local NATS_DIR; NATS_DIR="$(_aon_team_nats_dir "$team")"
  mkdir -p "$NATS_DIR"

  local moved=0 already=0
  _move_one() {
    local name="$1"
    local src="$STATE/$name" dst="$NATS_DIR/$name"
    if [[ -f "$dst" && ! -f "$src" ]]; then
      aon_ok "already in place: $dst"
      already=$((already+1))
      return
    fi
    if [[ -f "$src" ]]; then
      if [[ -f "$dst" ]]; then
        if cmp -s "$src" "$dst"; then
          rm -f "$src"
          aon_ok "deduped: $src (== $dst, removed source)"
        else
          aon_warn "both $src and $dst exist with differing content; leaving both — resolve manually"
        fi
        return
      fi
      mv "$src" "$dst"
      aon_ok "moved $src → $dst"
      moved=$((moved+1))
    fi
  }
  _move_one "auth.conf"
  _move_one "auth.conf.example"

  aon_info "migrate-mount summary: moved=$moved already=$already"

  # nats-server.conf in the team repo had `include "auth.conf"` (relative
  # to /etc/nats, where the legacy single-file mount landed). The new
  # mount puts auth.conf at /etc/nats/runtime/. Patch in place.
  local NATS_SERVER_CONF="$AON_TEAM_DIR/nats/nats-server.conf"
  if [[ -f "$NATS_SERVER_CONF" ]]; then
    if grep -qE '^include "auth\.conf"' "$NATS_SERVER_CONF"; then
      sed -i '' 's|^include "auth.conf"|include "runtime/auth.conf"|' "$NATS_SERVER_CONF"
      aon_ok "patched include path in $NATS_SERVER_CONF"
    elif grep -qE '^include "/etc/nats/runtime/auth\.conf"' "$NATS_SERVER_CONF"; then
      # Fix earlier (incorrect) absolute-path migration. nats-server's
      # include directive resolves absolute paths relative to the
      # config file dir (/etc/nats/), producing /etc/nats/etc/nats/...
      sed -i '' 's|^include "/etc/nats/runtime/auth.conf"|include "runtime/auth.conf"|' "$NATS_SERVER_CONF"
      aon_ok "fixed (re-patched) include path in $NATS_SERVER_CONF"
    fi
  fi

  # Regenerate docker-compose.yml so the directory bind-mount takes
  # effect on next 'aon nats up'. Backup the old one for audit.
  local COMPOSE="$AON_TEAM_DIR/docker-compose.yml"
  if [[ -f "$COMPOSE" ]]; then
    if grep -q "auth.conf:/etc/nats/auth.conf" "$COMPOSE" 2>/dev/null; then
      cp "$COMPOSE" "$COMPOSE.legacy.bak"
      rm -f "$COMPOSE"
      aon_ok "backed up legacy compose → $COMPOSE.legacy.bak"
    fi
  fi
  if [[ ! -f "$COMPOSE" ]]; then
    aon_render "$AON_ENGINE_DIR/templates/docker-compose.yml.tmpl" "$COMPOSE" \
      "TEAM_NAME=$team" \
      "NATS_DIR_PATH=$NATS_DIR"
    aon_ok "wrote new docker-compose.yml (directory bind-mount)"
  fi

  echo >&2
  aon_info "Next: bounce NATS so the new mount takes effect:"
  aon_info "  aon nats down && aon nats up"
}

_aon_nats_compose() {
  # Resolve compose file: prefer team repo's, else engine top-level.
  if [[ -f "$AON_TEAM_DIR/docker-compose.yml" ]]; then
    echo "$AON_TEAM_DIR/docker-compose.yml"
  else
    echo "$AON_ENGINE_DIR/docker-compose.yml"
  fi
}

_aon_nats_project_name() {
  # Use the team name from aon.toml so containers have a stable name
  # across cwds. Fall back to the dir basename only if aon.toml is
  # missing (which cmd_nats_up's guard refuses anyway).
  if [[ -n "${AON_TEAM_NAME:-}" ]]; then
    printf '%s' "$AON_TEAM_NAME"
  else
    basename "$AON_TEAM_DIR"
  fi
}

# Extract host port from $AON_NATS_URL (e.g. nats://localhost:4322 → 4322).
# Falls back to 4222 if URL is unset or has no port. Multi-team setups on
# the same host need this so each team checks its own port, not 4222.
_aon_nats_port() {
  local url="${AON_NATS_URL:-nats://localhost:4222}"
  # Strip scheme + host, take everything after last colon up to / or end.
  local p; p="${url##*:}"; p="${p%%/*}"
  if [[ "$p" =~ ^[0-9]+$ ]]; then printf '%s' "$p"; else printf '4222'; fi
}

_aon_nats_port_in_use() {
  # Returns 0 if the team's NATS port is already bound on this host.
  local port; port="$(_aon_nats_port)"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | grep -q LISTEN
}

_aon_nats_find_container() {
  # Find a running container that bind-mounts our team's nats dir
  # (~/.aon/teams/<team>/nats) — i.e. the directory that holds
  # auth.conf. Returns the container NAME on stdout (rc=0). Empty +
  # rc=1 if no match. Uses bind-mount source, not name, so legacy
  # containers from before the project-name=team-name fix (e.g.
  # saas-nats-1) are still found.
  #
  # Backwards-compat: pre-dir-mount containers bound the single file
  # ~/.aon/teams/<team>/auth.conf or older $TEAM_DIR/nats/auth.conf;
  # we still match those so 'aon nats down' / migrate flows can find
  # and stop them.
  local team="${AON_TEAM_NAME:-team-alpha}"
  local nats_dir; nats_dir="$(_aon_team_nats_dir "$team")"
  local legacy_auth; legacy_auth="$HOME/.aon/teams/$team/auth.conf"
  local cid
  for cid in $(docker ps -q 2>/dev/null); do
    local sources; sources="$(docker inspect "$cid" --format '{{range .Mounts}}{{.Source}}{{"\n"}}{{end}}' 2>/dev/null)"
    if printf '%s\n' "$sources" | grep -qxF "$nats_dir" \
       || printf '%s\n' "$sources" | grep -qxF "$legacy_auth" \
       || printf '%s\n' "$sources" | grep -qE "/nats/auth\.conf$"; then
      docker inspect "$cid" --format '{{.Name}}' 2>/dev/null | sed 's|^/||'
      return 0
    fi
  done
  return 1
}

_aon_nats_external_serving() {
  # Returns 0 if a real NATS server is answering on the team's NATS port
  # (from aon.toml nats.url, default 4222). NATS greets every TCP connect
  # with `INFO {…}\r\n` before any auth, so we just peek the first 5
  # bytes. Use python (already a hard dep) — BSD nc closes stdin too
  # aggressively, missing the greeting. Detects colima/lima port-
  # forwards, remote tunnels, native nats-server, and our own docker
  # container (across cwds with different project names).
  local port; port="$(_aon_nats_port)"
  AON_NATS_PORT="$port" python3 - <<'PY' >/dev/null 2>&1
import os, socket, sys
port = int(os.environ.get("AON_NATS_PORT", "4222"))
try:
    s = socket.create_connection(("127.0.0.1", port), timeout=2)
    s.settimeout(2)
    data = s.recv(5)
    s.close()
    sys.exit(0 if data.startswith(b"INFO ") else 1)
except Exception:
    sys.exit(1)
PY
}

cmd_nats_up() {
  aon_load_config
  # Guard: bind-mount sources must exist as FILES, not dirs.
  # Docker auto-creates an empty DIR for any missing host path at
  # `compose up` time. The container then fails ("is a directory")
  # AND the empty dir poisons subsequent `aon init` runs (cp into a
  # dir-as-dst puts the file INSIDE the dir). Bail loudly with the
  # exact remediation instead of letting docker corrupt state.
  if [[ "$AON_TOML_PRESENT" -eq 1 ]]; then
    local _nats_dir;     _nats_dir="$(_aon_team_nats_dir "$AON_TEAM_NAME")"
    local _runtime_conf="$_nats_dir/nats-server.conf"
    local _resolver_dir="$_nats_dir/resolver"
    local _bad=0
    if [[ ! -d "$_nats_dir" ]]; then
      aon_err "missing nats runtime dir: $_nats_dir"
      aon_err "  fix: mkdir -p '$_nats_dir' && aon auth render"
      _bad=1
    fi
    if [[ ! -f "$_runtime_conf" ]]; then
      aon_err "missing rendered nats-server.conf: $_runtime_conf"
      aon_err "  fix: aon auth render"
      _bad=1
    elif grep -E '@(OP_JWT|SYS_ID|SYS_JWT|TEAM_NAME)@' "$_runtime_conf" >/dev/null 2>&1; then
      aon_err "$_runtime_conf has unsubstituted JWT placeholders"
      aon_err "  fix: aon auth render"
      _bad=1
    fi
    if [[ ! -d "$_resolver_dir" ]] || ! compgen -G "$_resolver_dir/*.jwt" >/dev/null; then
      aon_err "no account JWT(s) under $_resolver_dir"
      aon_err "  fix: aon auth render"
      _bad=1
    fi
    [[ "$_bad" -eq 0 ]] || return 1
  fi
  # Guard: refuse to run outside a team dir. Without this guard,
  # running from $HOME makes project=basename($HOME) (e.g. "mid"), the
  # compose file falls back to engine's docker-compose.yml, and the
  # resulting orphan container squats :4222 forever — blocking later
  # `aon onboard` from the real team dir.
  if [[ "$AON_TOML_PRESENT" -ne 1 ]]; then
    aon_err "no aon.toml in $AON_TEAM_DIR — refusing to spin up nats here."
    aon_err "  cd into your team dir (with aon.toml) before running 'aon nats up'."
    aon_err "  or run 'aon init' first to create one."
    return 1
  fi
  # Pre-check :4222 — three cases when bound:
  #   (1) our compose container running  → already up, return 0
  #   (2) something else answers NATS protocol  → external NATS (colima
  #       VM port-forward, remote tunnel, native nats-server). Trust
  #       it and skip docker start. Auth gets validated on the next
  #       handshake probe anyway.
  #   (3) port held by something that isn't NATS → bail loud.
  local pname; pname="$(_aon_nats_project_name)"
  local port;  port="$(_aon_nats_port)"
  if _aon_nats_port_in_use; then
    if docker ps --filter "name=${pname}-nats-1" --format "{{.Names}}" 2>/dev/null | grep -q "${pname}-nats-1"; then
      aon_ok "team's NATS container already running ($pname-nats-1)"
      curl -s "http://127.0.0.1:$((port+4000))/healthz" 2>/dev/null && echo
      return 0
    fi
    if _aon_nats_external_serving; then
      aon_ok "external NATS already serving on :$port — skipping docker start"
      aon_info "  (auth.conf changes need a manual reload on whoever runs that nats)"
      return 0
    fi
    aon_err "port $port bound but not answering NATS protocol."
    aon_err "  $(lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | tail -n +2 | head -1)"
    aon_err "  Stop the squatter first; see 'ps -fp <PID>' to identify."
    return 1
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  aon_info "aon nats up — compose=$compose project=$pname"
  # Capture compose exit so we don't false-positive when port :4222 is
  # held by some OTHER process — that other listener also answers
  # :8222/healthz, which would make us claim health for the wrong nats.
  local compose_log; compose_log="$(mktemp -t aon-nats-up.XXXXXX)"
  if ! ( cd "$AON_TEAM_DIR" && docker compose -f "$compose" --project-name "$pname" up -d nats ) >"$compose_log" 2>&1; then
    cat "$compose_log" >&2
    # Compose often leaves a stopped container behind on port-bind
    # failure. Remove it so the next attempt isn't blocked by it.
    docker rm -f "${pname}-nats-1" >/dev/null 2>&1 || true
    if grep -q "port is already allocated\|address already in use" "$compose_log"; then
      aon_err "port 4222 (or 8222/8080) already bound by another listener."
      local lsof_out; lsof_out="$(lsof -nP -iTCP:4222 -sTCP:LISTEN 2>/dev/null | tail -n +1 | head -3)"
      [[ -n "$lsof_out" ]] && printf '%s\n' "$lsof_out" >&2
      # Identify common cases by command name in lsof output.
      if printf '%s' "$lsof_out" | grep -qE '^ssh\b'; then
        aon_err "  Squatter is 'ssh' — likely a colima/lima VM port-forward or an SSH tunnel."
        aon_err "  Check 'colima list' / 'limactl list' or 'ps -fp <PID>' to find the source."
        aon_err "  If colima is forwarding NATS from inside the VM, you don't need a second"
        aon_err "  container — point aon at the VM's nats and skip 'aon nats up'."
      elif printf '%s' "$lsof_out" | grep -qE '^nats-server\b'; then
        aon_err "  Squatter is a native 'nats-server' process — kill it: pkill nats-server"
      elif printf '%s' "$lsof_out" | grep -qE '^com.docker'; then
        aon_err "  Squatter is Docker — find the stale container:"
        aon_err "    docker ps --format 'table {{.Names}}\t{{.Ports}}' | grep 4222"
        aon_err "    docker rm -f <name>     # or: aon nats down (if it's this team's)"
      else
        aon_err "  Stop the other listener and retry. (ps -fp <PID> shows what it is.)"
      fi
    fi
    rm -f "$compose_log"
    return 1
  fi
  rm -f "$compose_log"

  # Verify OUR container is actually running before probing :8222.
  local cname="${pname}-nats-1"
  if ! docker ps --filter "name=^${cname}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${cname}$"; then
    aon_err "compose returned 0 but $cname is not running — check 'docker ps -a' and 'aon nats logs'"
    return 1
  fi

  # Wait for healthz (10s) — now safe to trust because we know our
  # container is the one bound to :8222.
  local i
  for i in {1..20}; do
    sleep 0.5
    if curl -sf http://127.0.0.1:8222/healthz >/dev/null 2>&1; then
      aon_ok "NATS healthy on 127.0.0.1:4222 (monitor :8222, ws :8080) — container $cname"
      return 0
    fi
  done
  aon_err "NATS did not pass healthz within 10s — check 'aon nats logs'"
  return 1
}

cmd_nats_down() {
  aon_load_config
  # Prefer to find OUR container by auth.conf mount — handles legacy
  # containers from before project-name=team-name (e.g. saas-nats-1
  # when team-name is team-alpha). Falls back to compose down.
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    aon_info "stopping container $cname (matched by auth.conf mount)"
    docker stop "$cname" >/dev/null && docker rm "$cname" >/dev/null
    aon_ok "stopped + removed $cname"
    return 0
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  ( cd "$AON_TEAM_DIR" && docker compose -f "$compose" --project-name "$pname" down nats )
  aon_ok "stopped"
}

cmd_nats_logs() {
  aon_load_config
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    exec docker logs -f "$cname"
  fi
  local compose pname
  compose="$(_aon_nats_compose)"
  pname="$(_aon_nats_project_name)"
  ( cd "$AON_TEAM_DIR" && exec docker compose -f "$compose" --project-name "$pname" logs -f nats )
}

cmd_nats_status() {
  aon_load_config
  local cname; cname="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$cname" ]]; then
    docker ps --filter "name=^${cname}$" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  else
    local pname; pname="$(_aon_nats_project_name)"
    docker ps --filter "name=${pname}-nats-1" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  fi
  echo
  curl -s http://127.0.0.1:8222/healthz 2>&1 || echo "(monitor unreachable)"
}

cmd_creds() {
  aon_load_config
  local role="${1:-}" dest="${2:-}"
  if [[ "$role" == "--all" ]]; then
    cmd_creds_all "${2:-}"
    return $?
  fi
  [[ -n "$role" ]] || { aon_err "usage: aon creds <role> [<dest>]   |   aon creds --all"; return 2; }
  case "$dest" in
    →|←|⇒)
      aon_err "dest looks like a documentation glyph ('$dest'); did you copy-paste a comment?"
      aon_err "  fix: re-run without the glyph, e.g.  aon creds $role"
      return 2
      ;;
  esac
  command -v nsc >/dev/null 2>&1 \
    || aon_fail "nsc not on PATH — install via 'brew install nats-io/nats-tools/nsc'"

  local team="$AON_TEAM_ACCOUNT"
  if ! nsc describe user --account "$team" --name "$role" >/dev/null 2>&1; then
    aon_fail "no NSC user '$role' in account '$team' — run 'aon auth render' first"
  fi
  if [[ -z "$dest" ]]; then
    local creds_dir; creds_dir="$(_aon_team_creds_dir "$AON_TEAM_NAME")"
    mkdir -p "$creds_dir"
    chmod 700 "$(_aon_registry_root)"
    dest="$creds_dir/$role.creds"
  fi
  _aon_nsc_emit_creds "$team" "$role" "$dest"
  aon_ok "wrote $dest (chmod 600)"
}

cmd_creds_all() {
  aon_load_config
  command -v nsc >/dev/null 2>&1 \
    || aon_fail "nsc not on PATH — install via 'brew install nats-io/nats-tools/nsc'"
  local team="$AON_TEAM_ACCOUNT"
  local creds_dir; creds_dir="$(_aon_team_creds_dir "$AON_TEAM_NAME")"
  mkdir -p "$creds_dir"
  chmod 700 "$(_aon_registry_root)"

  # Pull user list from NSC so we cover sysadmin + every roster role
  # that's actually been provisioned (skips any aon.toml entries that
  # never made it into NSC — those need 'aon auth render' first).
  local users
  # nsc 2.12.x writes list output (both --json and table) to stderr,
  # not stdout. Merge 2>&1 so the parser sees it. Older nsc wrote to
  # stdout; either path works once merged.
  users="$(_aon_nsc_env; nsc list users --account "$team" --json 2>&1 \
    | python3 -c 'import sys,json; xs=json.load(sys.stdin); print("\n".join(x.get("name","") for x in xs if x.get("name")))' 2>/dev/null)"
  if [[ -z "$users" ]]; then
    # Fallback: parse the table output (older / non-JSON nsc).
    users="$(_aon_nsc_env; nsc list users --account "$team" 2>&1 \
      | awk -F '|' '/^\| [a-zA-Z]/ { gsub(/ /,"",$2); print $2 }')"
  fi
  [[ -n "$users" ]] || aon_fail "no NSC users in account '$team' — run 'aon auth render' first"

  local u dest count=0
  for u in $users; do
    dest="$creds_dir/$u.creds"
    _aon_nsc_emit_creds "$team" "$u" "$dest"
    aon_ok "wrote $dest"
    count=$((count+1))
  done
  aon_info "emitted $count .creds file(s) → $creds_dir"
}

# `aon revoke <role>` — revoke a user JWT and propagate the change
# to the running nats-server immediately via `nsc push`
# (`$SYS.REQ.CLAIMS.UPDATE`). The disk resolver dir is server-write
# at runtime; without the push the server keeps the old in-memory
# JWT until the next scan interval (default 2m). See
# .tasks/aon-revoke-fold-nsc-push.md for the bug history.
#
# When NATS is down: disk JWT still updated, server picks up at next
# start. Warns but doesn't fail.
#
# Subcommands:
#   aon revoke <role>            — revoke + push (immediate effect)
#   aon revoke list              — list revoked users in this team's account
#   aon revoke clear <role>      — clear a revocation + push
cmd_revoke() {
  aon_load_config
  command -v nsc >/dev/null 2>&1 \
    || aon_fail "nsc not on PATH — install via 'brew install nats-io/nats-tools/nsc'"
  local team="$AON_TEAM_ACCOUNT"
  local sub="${1:-}"; shift || true

  case "$sub" in
    "")
      aon_err "usage: aon revoke <role>   |   aon revoke list   |   aon revoke clear <role>"
      return 2
      ;;
    list)
      _aon_nsc_env
      nsc revocations list-users --account "$team"
      ;;
    clear)
      local role="${1:-}"
      [[ -n "$role" ]] || { aon_err "usage: aon revoke clear <role>"; return 2; }
      _aon_nsc_env
      if ! nsc describe user --account "$team" --name "$role" >/dev/null 2>&1; then
        aon_fail "no NSC user '$role' in account '$team'"
      fi
      nsc revocations delete-user --account "$team" --name "$role" \
        || aon_fail "nsc revocations delete-user failed"
      _aon_nsc_publish_team_jwt "$team"
      _aon_nsc_push_team_jwt "$team"
      aon_ok "cleared revocation for $role; team JWT published + pushed"
      ;;
    *)
      # Treat sub as role name.
      local role="$sub"
      _aon_nsc_env
      if ! nsc describe user --account "$team" --name "$role" >/dev/null 2>&1; then
        aon_fail "no NSC user '$role' in account '$team'"
      fi
      nsc revocations add-user --account "$team" --name "$role" \
        || aon_fail "nsc revocations add-user failed"
      _aon_nsc_publish_team_jwt "$team"
      _aon_nsc_push_team_jwt "$team"
      aon_ok "revoked $role; team JWT published + pushed to running server"
      aon_warn "existing .creds for $role are now invalid — you'll need 'aon creds $role' to re-issue"
      ;;
  esac
}

cmd_launch() {
  aon_load_config
  local role="${1:-}" work_repo="${2:-}"
  [[ -n "$role" ]] || { aon_err "usage: aon launch <role> [<work-repo>]"; return 2; }

  # Verify role is in roster.
  local i found="" rname
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    rname="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ "$rname" == "$role" ]] && { found=1; break; }
  done
  [[ -n "$found" ]] || aon_fail "role '$role' not in aon.toml roster"

  # Resolve creds; auto-populate if missing.
  local CREDS; CREDS="$(_aon_role_creds "$role")"
  if [[ ! -s "$CREDS" ]]; then
    aon_info "creds missing — running 'aon creds $role'"
    cmd_creds "$role" || return $?
  fi

  # NATS handshake (2s timeout) — bail with a clear msg if auth fails.
  if ! nats --server "$AON_NATS_URL" --creds "$CREDS" --timeout 2s rtt >/dev/null 2>&1; then
    aon_err "NATS handshake failed for role=$role url=$AON_NATS_URL"
    aon_err "  - is NATS up? try: aon nats up"
    aon_err "  - are the creds valid? try: rm $CREDS && aon creds $role"
    return 1
  fi
  aon_ok "NATS handshake OK as $role"

  # Hooks — install in the relevant repo.
  local target="$AON_TEAM_DIR"
  if [[ -n "$work_repo" ]]; then
    target="$(cd -- "$work_repo" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory: $work_repo"
  fi

  local HOOK_INSTALL="$AON_ENGINE_DIR/scripts/hooks/install.sh"
  if [[ -x "$HOOK_INSTALL" ]]; then
    ( cd "$target" && bash "$HOOK_INSTALL" install >/dev/null )
    aon_ok "hooks installed in $target/.claude/"
  else
    aon_warn "engine hook installer missing — skipping"
  fi

  # Export env + exec claude.
  export AON_ROLE="$role"
  export AON_NATS_URL="$AON_NATS_URL"
  export AON_CREDS="$CREDS"
  aon_info "launching claude (role=$role url=$AON_NATS_URL cwd=$target)"
  cd "$target"
  exec claude
}

cmd_resolve_env() {
  # Reads cwd → ~/.aon/work-repos.json → echoes shell `export` lines so
  # callers can `eval $(aon resolve-env)`. Silent (rc=0) on miss so eval
  # doesn't error in non-team shells; pass --strict to make miss fatal.
  local strict=0
  [[ "${1:-}" == "--strict" ]] && strict=1
  local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || {
    [[ "$strict" == 1 ]] && { aon_err "cwd not in ~/.aon/work-repos.json"; return 1; }
    return 0
  }
  local team role path; IFS=$'\t' read -r team role path <<<"$res"
  local creds_dir; creds_dir="$(_aon_team_creds_dir "$team")"
  local creds="$creds_dir/$role.creds"
  local env_file="$creds_dir/$role.env"
  if [[ ! -f "$creds" ]]; then
    [[ "$strict" == 1 ]] && aon_err "missing $creds"
    return $strict
  fi
  local nats_url="" kv="team-state"
  if [[ -f "$env_file" ]]; then
    nats_url="$(grep '^export AON_NATS_URL=' "$env_file" 2>/dev/null | cut -d= -f2-)"
    local k; k="$(grep '^export AON_KV_BUCKET=' "$env_file" 2>/dev/null | cut -d= -f2-)"
    [[ -n "$k" ]] && kv="$k"
  fi
  # Roster: read role names from the team's aon.toml so callers like
  # scripts/bootstrap.sh can `eval $(aon resolve-env)` instead of
  # falling back to a hard-coded constant. Tolerates missing toml
  # (degraded boxes) by emitting an empty AON_ROSTER.
  local roster=""
  local team_repo; team_repo="$(_aon_team_repo_dir "$team")"
  local team_toml="$team_repo/aon.toml"
  if [[ -f "$team_toml" ]]; then
    local rcount; rcount="$(aon_toml_array_count "$team_toml" roles 2>/dev/null || echo 0)"
    local i name
    for ((i=0; i<rcount; i++)); do
      name="$(aon_toml_array_get "$team_toml" roles "$i" name 2>/dev/null)"
      [[ -n "$name" ]] && roster+="${roster:+ }$name"
    done
  fi
  printf 'export AON_ROLE=%s\n' "$role"
  printf 'export AON_NATS_URL=%s\n' "$nats_url"
  printf 'export AON_CREDS=%s\n' "$creds"
  printf 'export AON_KV_BUCKET=%s\n' "$kv"
  printf 'export AON_TEAM=%s\n' "$team"
  printf 'export AON_ROSTER=%q\n' "$roster"
  printf 'export AON_WORK_REPO=%s\n' "$path"
}

# Per-repo install of aon MCP + board MCP into <work_repo>/.mcp.json,
# plus hooks into ~/.claude/settings.json (global). Per-work-repo CLAUDE.md
# gets a fenced aon block (preserves any existing content). Hook commands
# are wrapped in `eval $(aon resolve-env) && ...` so they pick up role/url
# at runtime from the registry instead of being baked per-repo.
#
# .mcp.json uses the `aon mcp-server <name>` launcher so the file is
# host-portable: joiners pull it from git and it just works (every box
# has `aon` on PATH). No operator-homedir paths baked in.
_aon_install_repo_mcp() {
  local engine_dir="$1"
  local work_repo="${2:-}"
  local global_settings="$HOME/.claude/settings.json"
  local aon_bin="$engine_dir/bin/aon"

  if [[ -z "$work_repo" || ! -d "$work_repo" ]]; then
    aon_fail "_aon_install_repo_mcp requires a valid work-repo"
  fi
  local repo_mcp_json="$work_repo/.mcp.json"

  # Ensure engine venv + board-tui exist locally (so this operator's
  # `aon mcp-server` works). Joiners get their own venv on first
  # `aon join-link`. The .mcp.json file written below is portable —
  # no absolute paths.
  local venv_bin="$engine_dir/mcp-server/.venv/bin/aon-mcp"
  if [[ ! -x "$venv_bin" ]]; then
    aon_info "installing aon-mcp venv (one-time)"
    python3 -m venv "$engine_dir/mcp-server/.venv"
    "$engine_dir/mcp-server/.venv/bin/pip" install --quiet --upgrade pip
    "$engine_dir/mcp-server/.venv/bin/pip" install --quiet "$engine_dir/mcp-server"
  fi
  [[ -x "$venv_bin" ]] || aon_fail "$venv_bin missing after install"

  local board_bin="${BOARD_TUI_MCP_BIN:-$(command -v board-tui-mcp || true)}"
  if [[ -z "$board_bin" || ! -x "$board_bin" ]]; then
    aon_info "installing board-tui via pipx (one-time)"
    pipx install --quiet git+https://github.com/dincamihai/board-tui.git \
      || aon_fail "pipx install board-tui failed"
    board_bin="$(command -v board-tui-mcp || true)"
    [[ -n "$board_bin" && -x "$board_bin" ]] || aon_fail "board-tui-mcp not on PATH after install"
  fi

  local board_tasks_dir="${AON_BOARD_DIR:-$HOME/aon-board}"
  mkdir -p "$board_tasks_dir" "$HOME/.claude"

  # Migration: drop legacy team-alpha* keys from previously-installed
  # global ~/.claude/settings.json so they don't double-load alongside
  # the new per-repo entries.
  if [[ -s "$global_settings" ]] \
     && jq -e '.mcpServers | has("team-alpha") or has("team-alpha-board")' "$global_settings" >/dev/null 2>&1; then
    jq 'if .mcpServers then .mcpServers |= (del(.["team-alpha"]) | del(.["team-alpha-board"])) else . end' \
      "$global_settings" > "$global_settings.tmp" && mv "$global_settings.tmp" "$global_settings"
    aon_ok "removed legacy team-alpha* keys from $global_settings"
  fi

  # Merge MCP servers into work-repo's .mcp.json (don't clobber existing keys).
  # Portable launcher: `aon mcp-server <name>` resolves the engine dir
  # at runtime on each user's box. Joiners need only `aon` on PATH.
  local existing="{}"
  [[ -s "$repo_mcp_json" ]] && existing="$(cat "$repo_mcp_json")"
  printf '%s' "$existing" | jq \
    --arg board_dir "$board_tasks_dir" \
    '.mcpServers = ((.mcpServers // {}) + {
      "aon":       {type:"stdio", command:"aon", args:["mcp-server","aon"]},
      "aon-board": {type:"stdio", command:"aon", args:["mcp-server","board"],
                    env:{BOARD_TASKS_DIR:$board_dir}}
    })' > "$repo_mcp_json.tmp" && mv "$repo_mcp_json.tmp" "$repo_mcp_json"
  aon_ok "per-repo MCP install → $repo_mcp_json (portable; uses 'aon mcp-server' launcher)"

  # Ensure .mcp.json is gitignored in the work-repo (file may contain
  # operator-local board paths via env). Idempotent: only append if not
  # already matched by an existing gitignore entry.
  local repo_gitignore="$work_repo/.gitignore"
  if [[ -d "$work_repo/.git" || -f "$work_repo/.git" ]]; then
    if ! { [[ -f "$repo_gitignore" ]] && grep -qxE '\.mcp\.json|/\.mcp\.json' "$repo_gitignore"; }; then
      [[ -s "$repo_gitignore" && -n "$(tail -c1 "$repo_gitignore")" ]] && printf '\n' >> "$repo_gitignore"
      printf '.mcp.json\n' >> "$repo_gitignore"
      aon_ok "added .mcp.json to $repo_gitignore"
    fi
  fi

  # Merge hooks from engine .claude/settings.json into global settings,
  # wrapping commands so they resolve env via registry at runtime
  # (no per-role baking). Hooks remain global; MCP servers are per-repo.
  local engine_settings="$engine_dir/.claude/settings.json"
  if [[ -f "$engine_settings" ]]; then
    local hooks_json; hooks_json="$(jq '.hooks // {}' "$engine_settings")"
    if [[ -n "$hooks_json" && "$hooks_json" != "null" && "$hooks_json" != "{}" ]]; then
      local existing_global="{}"
      [[ -s "$global_settings" ]] && existing_global="$(cat "$global_settings")"
      printf '%s' "$existing_global" | jq --argjson hooks "$hooks_json" --arg aon_bin "$aon_bin" '
        .hooks = ($hooks | with_entries(
          .value |= map(.hooks |= map(
            if .type == "command" and (.command | type) == "string"
            then .command = ("eval $(" + $aon_bin + " resolve-env) && " + .command)
            else .
            end
          ))
        ))
      ' > "$global_settings.tmp" && mv "$global_settings.tmp" "$global_settings"
      aon_ok "global hooks installed (registry-resolved at runtime)"
    fi
  fi

  local repo_claude_md="$work_repo/CLAUDE.md"
  local block; block="$(cat <<'EOF'
<!-- AON-MARKER-GET-ROLE-BRIEF-START -->
# aon agent

If an `aon` MCP server is connected for this cwd, you are an aon
agent. Role + NATS auth come from that MCP. Call
`get_role_brief()` on your first turn to load full role context
(subject permissions, comms protocol, preemption rules).

When the human user asks for any of the intents below, take the
matching action. Match generously on phrasing — "arm monitor", "watch
traffic", "show traffic", "tail nats" all mean watch your NATS
traffic.

| User says (any phrasing)                          | Run                                              | Tool       |
|---------------------------------------------------|--------------------------------------------------|------------|
| "start monitor", "watch traffic", "arm monitor"   | `aon monitor`                                    | **Monitor**|
| "ping ROLE", "say hi to ROLE", "DM ROLE: MSG"     | `aon pub agents.<ROLE>.inbox "<MSG>"`            | Bash       |
| "broadcast MSG", "announce MSG"                   | `aon pub broadcast.team "MSG"`                   | Bash       |
| "subscribe to SUBJECT"                            | `aon sub "SUBJECT"`                              | **Monitor**|
| "rotate URL with bits BITS"                       | `aon set-nats-url BITS`                          | Bash       |
| "doctor", "diagnose env"                          | `aon doctor`                                     | Bash       |
| "show env", "what env do I have"                  | `aon resolve-env`                                | Bash       |

`aon monitor` and `aon sub` are long-running streams: invoke them with
the **Monitor** tool, NEVER Bash. Bash buffers their output to a hidden
background buffer the human can't see; Monitor surfaces each line as a
notification. Running `aon monitor` under Bash is the #1 reason "the
DM arrived but nobody saw it" — message landed, claude couldn't see it.

Never call `nats` CLI directly — it doesn't carry creds. Use
`aon pub / aon sub / aon req`, which inject auth from the registry.
Never publish secrets (passwords, tokens) over NATS — every publish
hits the AUDIT stream.

If `aon` isn't on PATH, fall back to `~/Repos/ai-over-nats/bin/aon`.

If the `aon` MCP server is NOT connected for this directory,
this section is a no-op and claude operates normally.
<!-- AON-MARKER-GET-ROLE-BRIEF-END -->
EOF
)"

  if [[ ! -f "$repo_claude_md" ]]; then
    printf '%s\n' "$block" > "$repo_claude_md"
    aon_ok "created $repo_claude_md (aon block only)"
  elif grep -q "AON-MARKER-GET-ROLE-BRIEF-START" "$repo_claude_md"; then
    AON_CLAUDE_BLOCK="$block" python3 - "$repo_claude_md" <<'PY'
import os, sys, re, pathlib
p = pathlib.Path(sys.argv[1])
src = p.read_text()
new_block = os.environ["AON_CLAUDE_BLOCK"]
out = re.sub(
    r"<!-- AON-MARKER-GET-ROLE-BRIEF-START -->.*?<!-- AON-MARKER-GET-ROLE-BRIEF-END -->",
    lambda m: new_block,
    src,
    flags=re.DOTALL,
)
p.write_text(out)
PY
    aon_ok "refreshed aon block in $repo_claude_md (rest preserved)"
  else
    printf '\n%s\n' "$block" >> "$repo_claude_md"
    aon_ok "appended aon block to $repo_claude_md (existing content preserved)"
  fi
}

cmd_join() {
  aon_load_config
  local role="${1:-}" work_repo="${2:-}"

  # Auto-detect work-repo: if omitted, use cwd's git toplevel (when cwd
  # sits inside a git repo distinct from the team repo). Saves typing.
  if [[ -z "$work_repo" ]]; then
    local cwd_top
    if cwd_top="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)"; then
      local team_top=""
      [[ -n "${AON_TEAM_DIR:-}" && -d "$AON_TEAM_DIR/.git" ]] \
        && team_top="$(git -C "$AON_TEAM_DIR" rev-parse --show-toplevel 2>/dev/null)"
      if [[ -n "$team_top" && "$cwd_top" == "$team_top" ]]; then
        aon_warn "cwd is the team repo — pass <work-repo> explicitly"
      else
        work_repo="$cwd_top"
        aon_info "auto-detected work-repo: $work_repo"
      fi
    fi
  fi

  if [[ -z "$role" || -z "$work_repo" ]]; then
    cat >&2 <<EOF
Usage: aon join <role> [work-repo]
  role        worker role from this team's aon.toml roster
  work-repo   path to the code repo where you'll run claude
              (default: cwd's git toplevel)
EOF
    return 2
  fi

  # Validate role against roster.
  local i found="" rname
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    rname="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ "$rname" == "$role" ]] && { found=1; break; }
  done
  [[ -n "$found" ]] || aon_fail "role '$role' not in roster (aon.toml)"

  # Validate work repo.
  work_repo="$(cd -- "$work_repo" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory"
  [[ -d "$work_repo/.git" ]] || aon_warn "$work_repo is not a git repo — continuing anyway"

  # Prereq checks.
  local need_msg=""
  for cmd_pair in "claude:npm install -g @anthropic-ai/claude-code" \
                  "nats:brew install nats-io/nats-tools/nats" \
                  "jq:brew install jq" \
                  "python3:standard" \
                  "pipx:brew install pipx && pipx ensurepath"; do
    local cmd="${cmd_pair%%:*}" hint="${cmd_pair#*:}"
    if ! command -v "$cmd" >/dev/null 2>&1; then
      aon_err "$cmd not on PATH — $hint"
      need_msg=1
    fi
  done
  [[ -z "$need_msg" ]] || return 1

  if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    aon_warn "\$ANTHROPIC_API_KEY unset — claude will prompt for login on first run"
  fi

  # All team state lives under ~/.aon/teams/<team>/. Creds + env per role,
  # repo symlink so MCP server can read role briefs.
  local team="$AON_TEAM_NAME"
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local TEAM_REPO_LINK; TEAM_REPO_LINK="$(_aon_team_repo_dir "$team")"
  mkdir -p "$CREDS_DIR" && chmod 700 "$(_aon_registry_root)"

  # Symlink ~/.aon/teams/<team>/repo → $AON_TEAM_DIR (idempotent).
  if [[ ! -e "$TEAM_REPO_LINK" ]]; then
    mkdir -p "$(dirname "$TEAM_REPO_LINK")"
    ln -s "$AON_TEAM_DIR" "$TEAM_REPO_LINK"
    aon_ok "linked $TEAM_REPO_LINK → $AON_TEAM_DIR"
  fi

  local CREDS_FILE="$CREDS_DIR/$role.creds"
  if [[ ! -s "$CREDS_FILE" ]]; then
    # Under JWT auth (.tasks/nsc-jwt-migration.md), creds = signed
    # user JWT in a .creds file. Operator side: derive from local NSC
    # via 'aon creds'. Joiner side: must have been delivered by
    # waiting-room admit (or legacy join-link token) — bail with a
    # clear msg.
    if command -v nsc >/dev/null 2>&1 \
       && nsc describe user --account "$AON_TEAM_ACCOUNT" --name "$role" >/dev/null 2>&1; then
      aon_info "creds missing — running 'aon creds $role'"
      cmd_creds "$role" "$CREDS_FILE" || aon_fail "creds emit failed"
    else
      aon_fail "no creds at $CREDS_FILE — joiners get creds via 'aon join-link' (legacy) or waiting-room admit; operators run 'aon auth render' first"
    fi
  else
    aon_ok "creds present → $CREDS_FILE"
  fi

  # NATS URL — prefer the previously-stored value from <role>.env so
  # re-running 'aon join' with empty Enter reuses the working URL.
  # Fall back to env override, then aon.toml. Refuse to write the
  # known placeholder strings (wss://nats.example.com,
  # wss://YOUR-CURRENT-TUNNEL.trycloudflare.com) — those are aon.toml
  # template defaults, not real URLs.
  local PREV_URL=""
  local _prev_env="$CREDS_DIR/$role.env"
  if [[ -s "$_prev_env" ]]; then
    PREV_URL="$(grep '^export AON_NATS_URL=' "$_prev_env" 2>/dev/null | cut -d= -f2-)"
  fi
  _is_placeholder_url() {
    case "$1" in
      ""|"wss://nats.example.com"|"wss://YOUR-CURRENT-TUNNEL.trycloudflare.com") return 0 ;;
      *) return 1 ;;
    esac
  }
  local DEFAULT_URL="$PREV_URL"
  if _is_placeholder_url "$DEFAULT_URL"; then
    DEFAULT_URL="${AON_NATS_URL:-}"
  fi
  if _is_placeholder_url "$DEFAULT_URL"; then
    DEFAULT_URL="${AON_NATS_WS_URL:-${AON_NATS_URL:-}}"
  fi
  printf "NATS URL [%s]: " "${DEFAULT_URL:-<none>}" >&2
  local NATS_URL; read -r NATS_URL
  NATS_URL="${NATS_URL:-$DEFAULT_URL}"
  if _is_placeholder_url "$NATS_URL"; then
    aon_fail "no NATS URL — aon.toml has only the placeholder; pass cloudflared bits or a wss:// URL at the prompt"
  fi
  case "$NATS_URL" in
    nats://*|ws://*|wss://*) ;;
    *)
      local _expanded; _expanded="$(_aon_nats_url_from_bits "$NATS_URL")"
      aon_info "expanded bits → $_expanded"
      NATS_URL="$_expanded"
      ;;
  esac

  # Persist env file. MCP server + hooks read these at runtime via
  # cwd→registry resolution; no env vars are baked into per-repo files.
  local ENV_FILE="$CREDS_DIR/$role.env"
  cat > "$ENV_FILE" <<EOF
# team env for $role — read by MCP server + 'aon resolve-env'.
export AON_ROLE=$role
export AON_NATS_URL=$NATS_URL
export AON_CREDS=$CREDS_FILE
export AON_KV_BUCKET=$AON_TEAM_KV
export AON_WORK_REPO=$work_repo
EOF
  chmod 600 "$ENV_FILE"
  aon_ok "wrote $ENV_FILE"

  # Register work-repo + install MCP/CLAUDE.md BEFORE the handshake
  # probe. Stamping is idempotent and useful even when NATS isn't
  # reachable yet (e.g. operator just added the role and nats hasn't
  # reloaded auth.conf). Joiner can run claude immediately; if NATS
  # auth isn't ready, the agent's first publish will surface the real
  # cause.
  _aon_register_work_repo "$work_repo" "$team" "$role"
  aon_ok "registered $work_repo → ($team, $role)"
  _aon_install_repo_mcp "$AON_ENGINE_DIR" "$work_repo"

  # NATS handshake — pub returns nonzero on failure (rtt is misleading).
  aon_info "probing $NATS_URL as $role …"
  if ! nats --server "$NATS_URL" --creds "$CREDS_FILE" --timeout 5s \
       pub "agents.$role.events" '{"kind":"probe","ts":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' \
       >/dev/null 2>&1; then
    cat >&2 <<EOF
⚠ NATS handshake failed (work-repo IS still set up).
  url:  $NATS_URL
  user: $role
  Common causes:
    - operator's NATS not running or tunnel down
    - operator hasn't pushed account JWT yet (run 'aon auth render' on operator side)
    - creds expired or revoked (rm $CREDS_FILE && aon join $role $work_repo)
    - wrong URL
  Re-probe later:
    nats --server $NATS_URL --creds $CREDS_FILE --timeout 5s \\
      pub agents.$role.events '{"kind":"probe"}'
EOF
    return 1
  fi
  aon_ok "NATS reachable as $role"

  cat <<EOF

✓ Setup complete.

Next:
  cd $work_repo
  claude

On first turn claude calls get_role_brief() to load your role context.
Once running, ask claude any of:
  • "start monitor"          → tails your NATS traffic
  • "doctor"                 → diagnoses the env
  • "rotate URL <bits>"      → applies new tunnel bits

Raw watch (separate terminal, no claude):
  nats --server $NATS_URL --creds $CREDS_FILE sub 'AUDIT.>'

Env file (auto-loaded by hooks via 'aon resolve-env'):
  $ENV_FILE
EOF
}

cmd_onboard() {
  aon_load_config
  local name="${1:-}" bits="${2:-}" kind="${3:-generalist}" domain="${4:-fullstack}"
  [[ -n "$name" && -n "$bits" ]] || {
    aon_err "usage: aon onboard NAME CLOUDFLARED_BITS [KIND] [DOMAIN]"
    aon_err "  CLOUDFLARED_BITS = 4-word subdomain piece, e.g. transportation-repeated-ppm-bobby"
    aon_err "                     (full URL becomes wss://<bits>.trycloudflare.com)"
    aon_err "  defaults: KIND=generalist DOMAIN=fullstack"
    return 2
  }
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"

  # Refuse if aon.toml has a live ws_url committed — that file is in
  # git, anyone with team-repo read can learn the tunnel address.
  # Acceptable values: empty, or the literal placeholder.
  if [[ -n "$AON_NATS_WS_URL" \
        && "$AON_NATS_WS_URL" != "wss://YOUR-CURRENT-TUNNEL.trycloudflare.com" \
        && "$AON_NATS_WS_URL" != "wss://nats.example.com" ]]; then
    aon_err "✗ [nats] ws_url in aon.toml is set to a live URL: $AON_NATS_WS_URL"
    aon_err "  Bits travel out-of-band only — they must NOT live in a committed file."
    aon_err "  Fix: edit $AON_TOML and set ws_url = \"wss://YOUR-CURRENT-TUNNEL.trycloudflare.com\""
    aon_err "       (or remove the ws_url line entirely). Then re-run."
    return 1
  fi

  # Sanity: if NATS is already running, ensure its bind-mount of the
  # nats runtime dir matches OUR team's canonical path
  # (~/.aon/teams/<team>/nats). Otherwise the auth.conf we regenerate
  # in step 3 won't be seen by the running server. Catches stale
  # containers from before either refactor (single-file mount of old
  # auth.conf, or pre-out-of-repo $TEAM_DIR/nats/auth.conf mount).
  local _expected_dir; _expected_dir="$(_aon_team_nats_dir "$AON_TEAM_NAME")"
  local _running_mount=""
  local _running_dest=""
  local _cid
  for _cid in $(docker ps -q 2>/dev/null); do
    # Try new dir-mount destination first.
    local _src; _src="$(docker inspect "$_cid" --format '{{range .Mounts}}{{if eq .Destination "/etc/nats/runtime"}}{{.Source}}{{end}}{{end}}' 2>/dev/null)"
    if [[ -n "$_src" ]]; then
      _running_mount="$_src"; _running_dest="/etc/nats/runtime"
      break
    fi
    # Fall back to legacy single-file mount destination.
    _src="$(docker inspect "$_cid" --format '{{range .Mounts}}{{if eq .Destination "/etc/nats/auth.conf"}}{{.Source}}{{end}}{{end}}' 2>/dev/null)"
    if [[ -n "$_src" ]]; then
      _running_mount="$_src"; _running_dest="/etc/nats/auth.conf"
      break
    fi
  done
  if [[ -n "$_running_mount" ]]; then
    if [[ "$_running_dest" == "/etc/nats/auth.conf" ]]; then
      aon_err "Running NATS uses legacy single-file auth.conf bind-mount:"
      aon_err "  container mount: $_running_mount  →  /etc/nats/auth.conf"
      aon_err "  expected dir:    $_expected_dir   →  /etc/nats/runtime"
      aon_err ""
      aon_err "Single-file mounts cache stale content on macOS. Migrate:"
      aon_err ""
      aon_err "  docker stop $_cid"
      aon_err "  aon nats migrate-mount   # moves auth.conf into nats/ subdir"
      aon_err "  aon nats up              # picks up new dir mount"
      aon_err "  aon onboard $name $bits ${kind:+$kind} ${domain:+$domain}"
      return 1
    fi
    if [[ "$_running_mount" != "$_expected_dir" ]]; then
      aon_err "Running NATS mounts a different team's nats dir:"
      aon_err "  container mount: $_running_mount"
      aon_err "  expected:        $_expected_dir"
      aon_err ""
      aon_err "Stop the running NATS first ('docker stop ${_cid}') and let"
      aon_err "this onboard restart it with the canonical mount."
      return 1
    fi
  fi

  aon_info "── Step 1/8: roster ──"
  cmd_add_role "$name" "$kind" "$domain"
  aon_load_config   # reload after possible add

  aon_info "── Step 2/8: prompts render ──"
  cmd_prompts_render

  aon_info "── Step 3/8: auth render (NSC + nats-server.conf) ──"
  cmd_auth_render

  aon_info "── Step 4/8: creds materialize ──"
  cmd_creds "$name"

  aon_info "── Step 5/8: NATS up + auth reload ──"
  # Three modes:
  #   - external: NATS already serving on :4222 from a process we don't
  #       own (colima VM, remote tunnel, native daemon). We don't touch
  #       it — auth.conf reload is the operator's responsibility on
  #       whatever box actually runs nats-server. Skip step 5 entirely,
  #       and skip step 6 (probe would fail until external reload).
  #   - managed-running: our compose container is up. SIGHUP the
  #       running nats-server to hot-reload the new auth.conf without
  #       dropping joiner connections.
  #   - managed-down: no container, port free. cmd_nats_up to start.
  local _pname; _pname="$(_aon_nats_project_name)"
  local _compose; _compose="$(_aon_nats_compose)"
  local _cname="${_pname}-nats-1"
  local _external=0
  # Find OUR running nats container by bind-mount, not by name. Catches
  # the case where a previous `aon nats up` ran with a different
  # project name (e.g. basename(cwd) before the team-name fix), so the
  # container is alive but doesn't match `${team}-nats-1`.
  local _our_container; _our_container="$(_aon_nats_find_container 2>/dev/null)"
  if [[ -n "$_our_container" ]]; then
    aon_info "container '$_our_container' mounts our nats runtime dir — sending SIGHUP (no drops)"
    if docker kill --signal=HUP "$_our_container" >/dev/null 2>&1; then
      sleep 1
      aon_ok "auth.conf reloaded (existing connections preserved)"
    else
      aon_warn "SIGHUP failed — falling back to recreate"
      ( cd "$AON_TEAM_DIR" && \
        docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
      aon_ok "NATS recreated"
    fi
  elif _aon_nats_port_in_use \
     && ! docker ps --filter "name=${_cname}" --format "{{.Names}}" 2>/dev/null | grep -q "${_cname}" \
     && _aon_nats_external_serving; then
    _external=1
    aon_ok "external NATS detected on :4222 — aon will not touch it."
    aon_info "  auth.conf was regenerated at $(_aon_team_auth_conf "$AON_TEAM_NAME")"
    aon_info "  Reload it on whatever process actually runs nats-server, e.g."
    aon_info "  SIGHUP nats-server (or your usual reload mechanism)."
    aon_info "  Skipping local handshake probe (step 6) — joiner's probe"
    aon_info "  in 'aon join-link' will validate auth end-to-end."
  elif docker ps --filter "name=${_cname}" --format "{{.Names}}" 2>/dev/null \
       | grep -q "${_cname}"; then
    aon_info "container running — sending SIGHUP to reload auth.conf (no drops)"
    if docker kill --signal=HUP "$_cname" >/dev/null 2>&1; then
      sleep 1
      if curl -sf http://127.0.0.1:8222/healthz >/dev/null 2>&1; then
        aon_ok "auth.conf reloaded (existing connections preserved)"
      else
        aon_warn "post-SIGHUP healthz failed — falling back to recreate"
        ( cd "$AON_TEAM_DIR" && \
          docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
        aon_ok "NATS recreated"
      fi
    else
      aon_warn "SIGHUP failed — falling back to recreate"
      ( cd "$AON_TEAM_DIR" && \
        docker compose -f "$_compose" --project-name "$_pname" up -d --force-recreate nats >/dev/null )
      aon_ok "NATS recreated"
    fi
  else
    if ! cmd_nats_up; then
      aon_err "✗ NATS failed to start — aborting onboard."
      aon_err "  Fix the port collision (see message above), then re-run:"
      aon_err "    aon onboard $name <bits>"
      return 1
    fi
  fi

  if [[ "$_external" -eq 1 ]]; then
    aon_info "── Step 6/8: local handshake probe (skipped — external NATS) ──"
  else
    aon_info "── Step 6/8: local handshake probe ──"
    local PROBE_CREDS; PROBE_CREDS="$(_aon_role_creds "$name")"
    [[ -s "$PROBE_CREDS" ]] || aon_fail "no creds at $PROBE_CREDS — onboarding flow expected 'aon creds $name' to have run"
    local PROBE_URL="${AON_NATS_URL:-nats://localhost:4222}"
    # Use a role-permitted publish (same pattern as `aon join`) — `server
    # check connection` needs reply-inbox perms most roles don't have.
    if ! nats --server "$PROBE_URL" --creds "$PROBE_CREDS" --timeout 5s \
         pub "agents.$name.events" '{"kind":"probe","ts":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' \
         >/dev/null 2>&1; then
      aon_err "✗ local handshake failed for $name @ $PROBE_URL"
      aon_err "  diagnose: /aon:diagnose-handshake (or aon doctor)"
      return 1
    fi
    aon_ok "local handshake OK"
  fi

  aon_info "── Step 7/8: commit + push ──"
  _aon_require_team_git
  if [[ -n "$(git -C "$AON_TEAM_DIR" status --porcelain 2>/dev/null)" ]]; then
    git -C "$AON_TEAM_DIR" add -A
    git -C "$AON_TEAM_DIR" commit -m "Onboard $name ($kind/$domain)" >/dev/null
    if git -C "$AON_TEAM_DIR" push 2>&1 | tail -1 | grep -qiE "rejected|error"; then
      aon_warn "git push failed — push manually after resolving"
    else
      aon_ok "pushed onboarding commit"
    fi
  else
    aon_ok "no changes to commit"
  fi

  aon_info "── Step 8/8: emit share-block token ──"
  _aon_require_team_git
  local TS_NOW TS_EXPIRE
  TS_NOW=$(_aon_iso_now)
  TS_EXPIRE=$(_aon_iso_plus_1h)
  local REPO_URL; REPO_URL="$(git -C "$AON_TEAM_DIR" remote get-url origin 2>/dev/null || echo '')"
  # Derive owner/repo slug so joiner can clone via `gh repo clone`
  # (works whether their gh auth is HTTPS-PAT or SSH). Avoids the
  # operator's protocol choice (HTTPS vs SSH origin) leaking onto the
  # joiner's box.
  local REPO_SLUG; REPO_SLUG="$(printf '%s' "$REPO_URL" \
    | sed -E 's|\.git$||; s|^git@github.com:|https://github.com/|; s|^https://github.com/||')"
  local CREDS_CONTENT; CREDS_CONTENT="$(cat "$(_aon_role_creds "$name")")"
  local ENGINE_SHA; ENGINE_SHA="$(git -C "$AON_ENGINE_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"

  # v3 token (NSC/JWT cutover): carries a .creds blob (signed user JWT
  # + nkey seed) instead of a password. Older v2 tokens with a
  # `password` field are no longer honored — joiners on those tokens
  # need a re-issue. Bits still travel separately, OOB-only.
  local TOKEN_JSON; TOKEN_JSON="$(jq -nc \
    --arg v "3" --arg team "$AON_TEAM_NAME" --arg url "$REPO_URL" \
    --arg slug "$REPO_SLUG" \
    --arg role "$name" --arg creds "$CREDS_CONTENT" \
    --arg sha "$ENGINE_SHA" --arg exp "$TS_EXPIRE" --arg ts "$TS_NOW" \
    '{v:($v|tonumber), team:$team, team_repo_url:$url, team_repo_slug:$slug,
      role:$role, creds:$creds, engine_sha:$sha,
      issued_at:$ts, expires_at:$exp}')"
  local TOKEN; TOKEN="aon://$(printf '%s' "$TOKEN_JSON" | base64 | tr -d '\n=' | sed 's|+|-|g; s|/|_|g')"

  # Engine repo URL for the joiner's clone+install. Derive from local
  # engine origin so forks / private mirrors work. Strip .git, normalize
  # ssh→https for display (joiner's `gh repo clone` accepts owner/repo).
  local ENGINE_REMOTE; ENGINE_REMOTE="$(git -C "$AON_ENGINE_DIR" remote get-url origin 2>/dev/null \
    | sed -E 's|\.git$||; s|^git@github.com:|https://github.com/|')"
  local ENGINE_URL="${ENGINE_REMOTE:-https://github.com/dincamihai/ai-over-nats}"
  local ENGINE_SLUG; ENGINE_SLUG="$(printf '%s' "$ENGINE_URL" | sed -E 's|^https://github.com/||')"

  aon_info "── doctor ──"
  cmd_doctor || aon_warn "doctor reports issues — review above"

  cat <<EOF

════════════════════════════════════════════════════════════════════
  ✓ ONBOARDING COMPLETE for: $name
════════════════════════════════════════════════════════════════════

Send the JOINER this block (1Password / private DM only —
token contains the password). Joiner needs read access on
$ENGINE_SLUG and \`gh auth login\` already done.

  AON_DIR=\$HOME/Repos/ai-over-nats   # change once if you want a different path
  gh repo clone $ENGINE_SLUG "\$AON_DIR"
  "\$AON_DIR/bin/aon" join-link $TOKEN $bits

For tunnel rotation later, joiner can PATH it:
  export PATH="\$AON_DIR/bin:\$PATH"

Token expires: $TS_EXPIRE (1 hour)
If tunnel rotates: joiner runs  aon set-nats-url <new-bits>

Watch traffic:

  aon monitor $name

════════════════════════════════════════════════════════════════════
EOF
}

# ── helpers: cross-platform ISO-8601 timestamps ─────────────────────
_aon_iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
_aon_iso_plus_1h() {
  date -u -v+1H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || date -u -d '+1 hour' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || python3 -c 'import time, datetime as d; print((d.datetime.utcnow()+d.timedelta(hours=1)).strftime("%Y-%m-%dT%H:%M:%SZ"))'
}

# Build NATS URL from cloudflared bits or pass-through full URL.
_aon_nats_url_from_bits() {
  local bits="$1"
  if [[ "$bits" == wss://* || "$bits" == ws://* || "$bits" == nats://* ]]; then
    printf '%s' "$bits"   # full URL passed through
  else
    printf 'wss://%s.trycloudflare.com' "$bits"
  fi
}

cmd_join_link() {
  local TOKEN="${1:-}" BITS="${2:-}"
  [[ -n "$TOKEN" && -n "$BITS" ]] || {
    aon_err "usage: aon join-link <token> <cloudflared-bits>"
    aon_err "  cloudflared-bits = 4-word subdomain piece (e.g. transportation-repeated-ppm-bobby)"
    aon_err "  or full URL (wss://..., nats://...) for named tunnels"
    return 2
  }
  [[ "$TOKEN" == aon://* ]] || aon_fail "token must start with 'aon://'"

  local B64="${TOKEN#aon://}"
  B64="$(printf '%s' "$B64" | sed 's|-|+|g; s|_|/|g')"
  local PAD=$((4 - ${#B64} % 4)); [[ "$PAD" == 4 ]] || B64="$B64$(printf '=%.0s' $(seq 1 $PAD))"
  local JSON; JSON="$(printf '%s' "$B64" | base64 -d 2>/dev/null)" \
    || aon_fail "token base64 decode failed"

  local v team repo slug role creds_blob legacy_pw sha exp legacy_nats
  v="$(printf '%s' "$JSON" | jq -r .v)"
  team="$(printf '%s' "$JSON" | jq -r .team)"
  repo="$(printf '%s' "$JSON" | jq -r .team_repo_url)"
  slug="$(printf '%s' "$JSON" | jq -r '.team_repo_slug // empty')"
  role="$(printf '%s' "$JSON" | jq -r .role)"
  creds_blob="$(printf '%s' "$JSON" | jq -r '.creds // empty')"
  legacy_pw="$(printf '%s' "$JSON" | jq -r '.password // empty')"
  sha="$(printf '%s' "$JSON" | jq -r .engine_sha)"
  exp="$(printf '%s' "$JSON" | jq -r .expires_at)"
  legacy_nats="$(printf '%s' "$JSON" | jq -r '.nats_url // empty')"

  case "$v" in
    1) aon_warn "v1 token (deprecated; carries nats_url). Bits arg overrides token URL." ;;
    2) aon_fail "v2 token carries a password — invalid under JWT auth (.tasks/nsc-jwt-migration.md). Ask operator to regenerate (v3)." ;;
    3) [[ -n "$creds_blob" ]] || aon_fail "v3 token missing 'creds' field" ;;
    *) aon_fail "unsupported token version: $v" ;;
  esac

  # Expiry check (string compare on ISO-8601 UTC works).
  local NOW; NOW=$(_aon_iso_now)
  if [[ "$NOW" > "$exp" ]]; then
    aon_fail "token expired at $exp — ask operator to regenerate"
  fi

  local NATS_URL; NATS_URL="$(_aon_nats_url_from_bits "$BITS")"
  aon_info "token decoded: team=$team role=$role engine_sha=$sha"
  aon_info "nats url: $NATS_URL"

  # Step 1: ensure team-aon repo at registry path ~/.aon/teams/<team>/repo.
  # If joiner ran us from inside a matching git checkout, link to it
  # instead of cloning twice.
  local TEAM_DIR; TEAM_DIR="$(_aon_team_repo_dir "$team")"
  local _norm; _norm() { printf '%s' "$1" | sed -E 's|\.git$||; s|^git@github.com:|https://github.com/|; s|/+$||'; }
  local repo_norm; repo_norm="$(_norm "$repo")"
  if [[ ! -e "$TEAM_DIR" ]]; then
    local CWD_TOP; CWD_TOP="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$CWD_TOP" ]]; then
      local CWD_ORIGIN; CWD_ORIGIN="$(git -C "$CWD_TOP" remote get-url origin 2>/dev/null || true)"
      if [[ -n "$CWD_ORIGIN" && "$(_norm "$CWD_ORIGIN")" == "$repo_norm" ]]; then
        mkdir -p "$(dirname "$TEAM_DIR")"
        ln -s "$CWD_TOP" "$TEAM_DIR"
        aon_ok "linked $TEAM_DIR → $CWD_TOP (running inside matching repo)"
      fi
    fi
  fi
  if [[ ! -e "$TEAM_DIR" ]]; then
    aon_info "cloning team-aon repo → $TEAM_DIR"
    mkdir -p "$(dirname "$TEAM_DIR")"
    # Prefer `gh repo clone <slug>` — uses joiner's gh auth (HTTPS-PAT
    # or SSH per their config) instead of the operator's origin URL.
    # Fall back to plain git for v2 tokens missing the slug, or when
    # gh isn't installed.
    local _cloned=0
    if [[ -n "$slug" ]] && command -v gh >/dev/null 2>&1; then
      if gh repo clone "$slug" "$TEAM_DIR" -- --quiet 2>&1 | tail -3; then
        [[ -d "$TEAM_DIR/.git" ]] && _cloned=1
      fi
    fi
    if [[ "$_cloned" -ne 1 ]]; then
      git clone "$repo" "$TEAM_DIR" || aon_fail "clone failed: $repo (and gh fallback unavailable)"
    fi
  elif [[ -d "$TEAM_DIR/.git" ]]; then
    aon_ok "team-aon repo present → $TEAM_DIR"
    aon_info "git pull (fast-forward only) …"
    # Resolve real path so error msgs reference the user's checkout,
    # not the registry symlink.
    local _team_real; _team_real="$(_aon_realpath "$TEAM_DIR")"
    local _pull_log; _pull_log="$(mktemp)"
    if ! git -C "$TEAM_DIR" pull --ff-only >"$_pull_log" 2>&1; then
      aon_err "✗ team-aon repo not fast-forward with origin — aon.toml is likely stale"
      aon_err "  checkout: $_team_real"
      sed 's/^/    /' "$_pull_log" >&2
      aon_err ""
      aon_err "  Resolve divergence and retry:"
      aon_err "    cd $_team_real"
      aon_err "    git fetch origin"
      aon_err "    git status                      # inspect your local commits"
      aon_err "    git stash                       # if you have uncommitted work"
      aon_err "    git rebase origin/<branch>      # or: git reset --hard origin/<branch>"
      aon_err "    git stash pop                   # if you stashed"
      aon_err ""
      aon_err "  Then re-run:"
      aon_err "    aon join-link <token> <bits>"
      rm -f "$_pull_log"
      return 1
    fi
    rm -f "$_pull_log"
  fi

  # Step 2: place .creds file in registry.
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  mkdir -p "$CREDS_DIR" && chmod 700 "$(_aon_registry_root)"
  local CREDS_FILE="$CREDS_DIR/$role.creds"
  printf '%s' "$creds_blob" > "$CREDS_FILE"
  chmod 600 "$CREDS_FILE"
  aon_ok "creds → $CREDS_FILE (chmod 600)"

  # Step 3: detect rotation mode (existing env file + work-repo).
  local ENV_FILE="$CREDS_DIR/$role.env"
  if [[ -s "$ENV_FILE" ]]; then
    local PREV_WORK_REPO; PREV_WORK_REPO="$(grep '^export AON_WORK_REPO=' "$ENV_FILE" 2>/dev/null | cut -d= -f2-)"
    if [[ -n "$PREV_WORK_REPO" && -d "$PREV_WORK_REPO" ]]; then
      aon_info "── rotation mode: existing setup detected, refreshing URL + stamps ──"
      _aon_apply_nats_url "$role" "$PREV_WORK_REPO" "$NATS_URL"
      # Re-stamp registry + global MCP + work-repo CLAUDE.md so adding
      # the aon block later (e.g. after fixing handshake on first run)
      # actually lands. All idempotent.
      _aon_register_work_repo "$PREV_WORK_REPO" "$team" "$role"
      _aon_install_repo_mcp "$AON_ENGINE_DIR" "$PREV_WORK_REPO"
      aon_ok "✓ URL rotated + stamps refreshed. Restart claude in $PREV_WORK_REPO."
      return 0
    fi
  fi

  # Step 4: cold join — prompt for work-repo + run cmd_join.
  local WORK_REPO_DEFAULT="${PWD}"
  [[ -d "$WORK_REPO_DEFAULT/.git" ]] || WORK_REPO_DEFAULT=""
  printf "Work-repo path [%s]: " "${WORK_REPO_DEFAULT:-/absolute/path/to/repo}" >&2
  local WORK_REPO; read -r WORK_REPO
  WORK_REPO="${WORK_REPO:-$WORK_REPO_DEFAULT}"
  [[ -n "$WORK_REPO" ]] || aon_fail "work-repo required"
  WORK_REPO="$(cd -- "$WORK_REPO" 2>/dev/null && pwd)" || aon_fail "work-repo not a directory"

  export AON_NATS_URL="$NATS_URL"
  AON_TEAM_DIR="$TEAM_DIR" AON_TOML="$TEAM_DIR/aon.toml" cmd_join "$role" "$WORK_REPO"
}

# ── shared NATS URL update helper (used by cmd_join_link rotation +
#    cmd_set_nats_url). Updates ~/.aon/teams/<team>/creds/<role>.env +
#    re-probes handshake. No per-repo patches — MCP server reads URL
#    from registry on next startup.
_aon_apply_nats_url() {
  local role="$1" work_repo="$2" nats_url="$3"

  # Resolve team from work-repo path (registry lookup); fall back to
  # team-alpha for legacy callers.
  local team="team-alpha"
  if [[ -n "$work_repo" ]]; then
    local res; res="$(_aon_resolve_from_cwd "$work_repo" 2>/dev/null)" || true
    if [[ -n "$res" ]]; then
      IFS=$'\t' read -r team _ _ <<<"$res"
    fi
  fi
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local ENV_FILE="$CREDS_DIR/$role.env"
  local CREDS_FILE="$CREDS_DIR/$role.creds"

  if [[ -s "$ENV_FILE" ]]; then
    if grep -q '^export AON_NATS_URL=' "$ENV_FILE"; then
      _aon_inplace_sed "$ENV_FILE" "s|^export AON_NATS_URL=.*|export AON_NATS_URL=$nats_url|"
    else
      printf 'export AON_NATS_URL=%s\n' "$nats_url" >> "$ENV_FILE"
    fi
    chmod 600 "$ENV_FILE"
    aon_ok "updated $ENV_FILE"
  else
    aon_warn "$ENV_FILE missing — env not updated"
  fi

  if [[ ! -f "$CREDS_FILE" ]]; then
    aon_warn "$CREDS_FILE missing — skipping handshake probe"
    return 0
  fi
  if nats --server "$nats_url" --creds "$CREDS_FILE" --timeout 5s \
       pub "agents.$role.events" '{"kind":"probe","ts":"'"$(_aon_iso_now)"'"}' \
       >/dev/null 2>&1; then
    aon_ok "handshake OK against $nats_url"
  else
    aon_warn "handshake FAILED against $nats_url — verify bits + tunnel up"
    return 1
  fi
}

# Cross-platform sed -i (macOS uses BSD sed which needs -i ''; GNU sed
# uses -i alone). Write to temp + mv to avoid the difference.
_aon_inplace_sed() {
  local file="$1" expr="$2"
  local tmp; tmp="$(mktemp "${file}.XXXXXX")"
  sed "$expr" "$file" > "$tmp" && mv "$tmp" "$file"
}

cmd_set_nats_url() {
  local BITS="${1:-}"
  local explicit_role="${AON_ROLE:-}"
  # parse --role flag (surgical override; default rotates ALL roles).
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role) explicit_role="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  [[ -n "$BITS" ]] || { aon_err "usage: aon set-nats-url <cloudflared-bits> [--role NAME]"; return 2; }

  local NATS_URL; NATS_URL="$(_aon_nats_url_from_bits "$BITS")"

  # Decide which role env files to rotate.
  #   --role NAME (or $AON_ROLE) → only that one
  #   otherwise                          → every role in every team
  # Tunnel URL is a team-scoped config param: one team-aon repo, one
  # cloudflared, one wss URL; every role in the team points at it.
  # Rotation defaults to "all roles in the team(s) on this host".
  local team="${AON_TEAM:-team-alpha}"
  local CREDS_DIR; CREDS_DIR="$(_aon_team_creds_dir "$team")"
  local -a targets=()
  if [[ -n "$explicit_role" ]]; then
    targets=("$CREDS_DIR/$explicit_role.env")
    [[ -s "${targets[0]}" ]] || aon_fail "no ${targets[0]} — run 'aon join-link' first"
  else
    local f
    for f in "$CREDS_DIR"/*.env; do
      [[ -s "$f" ]] && targets+=("$f")
    done
    [[ "${#targets[@]}" -gt 0 ]] || aon_fail "no env files in $CREDS_DIR — run 'aon join-link' first"
    aon_info "rotating $((${#targets[@]})) role(s) in $team → $NATS_URL"
  fi

  local fail=0
  local env
  for env in "${targets[@]}"; do
    local role; role="$(basename "$env" .env)"
    local WORK_REPO; WORK_REPO="$(grep '^export AON_WORK_REPO=' "$env" 2>/dev/null | cut -d= -f2-)"
    aon_info "── role: $role ──"
    if [[ -z "$WORK_REPO" || ! -d "$WORK_REPO" ]]; then
      aon_warn "  no AON_WORK_REPO in $env (or path missing) — updating env file only"
      # Still update the env file so future re-stamps see the new URL.
      if grep -q '^export AON_NATS_URL=' "$env"; then
        _aon_inplace_sed "$env" "s|^export AON_NATS_URL=.*|export AON_NATS_URL=$NATS_URL|"
      else
        printf 'export AON_NATS_URL=%s\n' "$NATS_URL" >> "$env"
      fi
      chmod 600 "$env"
      aon_ok "  updated $env (env-only)"
      continue
    fi
    if ! _aon_apply_nats_url "$role" "$WORK_REPO" "$NATS_URL"; then
      fail=$((fail+1))
      aon_warn "  rotation failed for role $role (continuing with other roles)"
    fi
  done

  if [[ "$fail" -gt 0 ]]; then
    aon_err "✗ $fail role(s) failed to rotate — see warnings above"
    return 1
  fi
  aon_ok "✓ Restart claude in each work-repo to pick up new env."
}

cmd_monitor() {
  # Resolve role + nats URL + creds from cwd→registry first; fall back to
  # operator flow (aon_load_config + arg/$AON_ROLE) if cwd isn't
  # registered. Lets joiner run `aon monitor` from work-repo with no args.
  local role="${1:-}" nats_url="" creds="" team="" kv="team-state"

  local res; res="$(_aon_resolve_from_cwd 2>/dev/null)" || res=""
  if [[ -n "$res" ]]; then
    local r_team r_role _; IFS=$'\t' read -r r_team r_role _ <<<"$res"
    role="${role:-$r_role}"
    team="$r_team"
    creds="$(_aon_role_creds "$role" "$team")"
    local env_file; env_file="$(_aon_team_creds_dir "$team")/$role.env"
    if [[ -f "$env_file" ]]; then
      nats_url="$(grep '^export AON_NATS_URL=' "$env_file" 2>/dev/null | cut -d= -f2-)"
      local k; k="$(grep '^export AON_KV_BUCKET=' "$env_file" 2>/dev/null | cut -d= -f2-)"
      [[ -n "$k" ]] && kv="$k"
    fi
    # Operator monitoring another role on the same box has creds for
    # that role (from `aon creds --all`) but no per-role env file.
    # Fall back to the team's own aon.toml for url + kv.
    if [[ -z "$nats_url" ]]; then
      aon_load_config
      nats_url="$AON_NATS_URL"
      [[ -n "$AON_TEAM_KV" ]] && kv="$AON_TEAM_KV"
    fi
  else
    aon_load_config
    role="${role:-${AON_ROLE:-}}"
    [[ -n "$role" ]] || aon_fail "usage: aon monitor <role>   (or cd into a registered work-repo)"
    creds="$(_aon_role_creds "$role")"
    nats_url="$AON_NATS_URL"
    kv="$AON_TEAM_KV"
  fi

  [[ -s "$creds" ]] || aon_fail "no creds at $creds — run 'aon creds $role' first"
  [[ -n "$nats_url" ]] || aon_fail "no NATS URL — env file missing or not set"

  local SCRIPT="$AON_ENGINE_DIR/scripts/hooks/role-monitor.sh"
  [[ -x "$SCRIPT" ]] || aon_fail "role-monitor.sh not executable: $SCRIPT"

  export AON_ROLE="$role"
  export AON_NATS_URL="$nats_url"
  export AON_CREDS="$creds"
  export AON_KV_BUCKET="$kv"
  exec bash "$SCRIPT" "$role"
}

# Resolve role + nats_url + creds for the current cwd. Echoes
# "ROLE\tURL\tCREDS_FILE" on stdout, rc=1 if not resolvable.
# Shared by cmd_pub / cmd_sub / cmd_req — all the wrappers that
# inject auth into the underlying nats CLI.
_aon_resolve_cred_ctx() {
  local role url creds team res
  res="$(_aon_resolve_from_cwd 2>/dev/null)" || res=""
  if [[ -n "$res" ]]; then
    local r_team r_role _; IFS=$'\t' read -r r_team r_role _ <<<"$res"
    role="$r_role"; team="$r_team"
    creds="$(_aon_role_creds "$role" "$team")"
    local env_file; env_file="$(_aon_team_creds_dir "$team")/$role.env"
    if [[ -f "$env_file" ]]; then
      url="$(grep '^export AON_NATS_URL=' "$env_file" 2>/dev/null | cut -d= -f2-)"
    fi
    if [[ -z "$url" ]]; then
      aon_load_config
      url="$AON_NATS_URL"
    fi
  else
    aon_load_config
    role="${AON_ROLE:-}"
    [[ -n "$role" ]] || return 1
    creds="$(_aon_role_creds "$role")"
    url="$AON_NATS_URL"
  fi
  [[ -s "$creds" && -n "$url" && -n "$role" ]] || return 1
  printf '%s\t%s\t%s\n' "$role" "$url" "$creds"
}

# `aon pub <subject> <payload>` — publish as the cwd's role with auth
# auto-injected. Subject is exactly what nats CLI accepts; payload
# can be a string or `--` to read stdin.
cmd_pub() {
  local subj="${1:-}" payload="${2:-}"
  [[ -n "$subj" ]] || { aon_err "usage: aon pub <subject> <payload>"; return 2; }
  shift 2 || true
  local ctx; ctx="$(_aon_resolve_cred_ctx)" \
    || aon_fail "cannot resolve role+url — cd into a registered work-repo, or set AON_ROLE"
  local role url creds; IFS=$'\t' read -r role url creds <<<"$ctx"
  if [[ "$payload" == "--" ]]; then
    nats --server "$url" --creds "$creds" pub "$subj" --
  else
    nats --server "$url" --creds "$creds" pub "$subj" "$payload" "$@"
  fi
}

# `aon sub <subject>` — subscribe as the cwd's role.
cmd_sub() {
  local subj="${1:-}"
  [[ -n "$subj" ]] || { aon_err "usage: aon sub <subject>"; return 2; }
  shift || true
  local ctx; ctx="$(_aon_resolve_cred_ctx)" \
    || aon_fail "cannot resolve role+url — cd into a registered work-repo, or set AON_ROLE"
  local role url creds; IFS=$'\t' read -r role url creds <<<"$ctx"
  exec nats --server "$url" --creds "$creds" sub "$subj" "$@"
}

# `aon req <subject> <payload>` — request/reply, auth auto-injected.
cmd_req() {
  local subj="${1:-}" payload="${2:-}"
  [[ -n "$subj" && -n "$payload" ]] || { aon_err "usage: aon req <subject> <payload>"; return 2; }
  shift 2 || true
  local ctx; ctx="$(_aon_resolve_cred_ctx)" \
    || aon_fail "cannot resolve role+url"
  local role url creds; IFS=$'\t' read -r role url creds <<<"$ctx"
  nats --server "$url" --creds "$creds" req "$subj" "$payload" "$@"
}

# `aon mcp-server <name>` — host-portable MCP launcher used by .mcp.json.
# Resolves the engine's installed binary at runtime so the same .mcp.json
# can be committed to the team-aon repo and pulled by every joiner —
# no operator-homedir paths baked in.
cmd_mcp_server() {
  local name="${1:-}"
  shift || true
  case "$name" in
    aon|"")
      local venv_bin="$AON_ENGINE_DIR/mcp-server/.venv/bin/aon-mcp"
      [[ -x "$venv_bin" ]] || aon_fail "aon-mcp venv missing — run 'aon join-link <token> <bits>' to install"
      exec "$venv_bin" "$@"
      ;;
    board)
      local board_bin="${BOARD_TUI_MCP_BIN:-$(command -v board-tui-mcp || true)}"
      [[ -n "$board_bin" && -x "$board_bin" ]] || aon_fail "board-tui-mcp not on PATH — install with: pipx install git+https://github.com/dincamihai/board-tui.git"
      exec "$board_bin" "$@"
      ;;
    -h|--help|help)
      cat >&2 <<EOF
Usage: aon mcp-server <name>
  aon     launch the engine's aon MCP server (Python venv)
  board   launch the board-tui MCP server (pipx)
EOF
      ;;
    *)
      aon_err "aon mcp-server: unknown name: $name (expected: aon|board)"
      return 2
      ;;
  esac
}

cmd_apparmor() {
  if [[ -x "$AON_ENGINE_DIR/bin/aon-apparmor" ]]; then
    exec "$AON_ENGINE_DIR/bin/aon-apparmor" "$@"
  else
    aon_fail "aon-apparmor not found at $AON_ENGINE_DIR/bin/aon-apparmor"
  fi
}

case "${1:-}" in
  init)      shift; cmd_init "$@" ;;
  onboard)   shift; cmd_onboard "$@" ;;
  add-role)  shift; cmd_add_role "$@" ;;
  doctor)    shift; cmd_doctor "$@" ;;
  prompts)   shift; cmd_prompts "$@" ;;
  auth)      shift; cmd_auth "$@" ;;
  bootstrap) shift; cmd_bootstrap "$@" ;;
  nats)      shift; cmd_nats "$@" ;;
  creds)     shift; cmd_creds "$@" ;;
  revoke)    shift; cmd_revoke "$@" ;;
  launch)    shift; cmd_launch "$@" ;;
  join)      shift; cmd_join "$@" ;;
  join-link) shift; cmd_join_link "$@" ;;
  set-nats-url) shift; cmd_set_nats_url "$@" ;;
  resolve-env) shift; cmd_resolve_env "$@" ;;
  monitor)   shift; cmd_monitor "$@" ;;
  mcp-server) shift; cmd_mcp_server "$@" ;;
  pub)       shift; cmd_pub "$@" ;;
  sub)       shift; cmd_sub "$@" ;;
  req)       shift; cmd_req "$@" ;;
  apparmor)  shift; cmd_apparmor "$@" ;;
  help|-h|--help) usage ;;
  "")        usage; exit 1 ;;
  *)         aon_err "unknown command: $1"; usage; exit 2 ;;
esac
