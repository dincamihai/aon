#!/usr/bin/env bash
# aon — ai-over-nats engine CLI.
#
# Operator entrypoint. Run from inside a per-team repo.
#
# Subcommands:
#   init                   bootstrap harness in current repo
#   add-role NAME KIND     append role to roster (kind ∈ manager|generalist|specialist)
#   doctor                 sanity-check the local setup
#   apparmor SUB           manage personal AppArmor overrides (Cards 228/229)
#                          (delegates to bin/team-alpha-apparmor for now)
#   help                   this help

set -uo pipefail

_aon_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_aon-lib.sh
source "$_aon_dir/_aon-lib.sh"

usage() {
  cat <<EOF
aon — ai-over-nats engine CLI

usage: aon <command> [args]

Commands:
  init                       bootstrap harness in current repo
  add-role NAME KIND DOMAIN  append role to aon.toml roster
                             KIND ∈ manager | generalist | specialist
  doctor                     sanity-check local setup
  prompts render             render agent-prompts/<role>.md from templates
  auth render                render nats/auth.conf.example from roster
  auth set-passwords         substitute PASSWORD_* placeholders → nats/auth.conf
  bootstrap                  ensure JetStream streams + KV from aon.toml roster
  apparmor SUB               personal AppArmor overrides (sync|show|reload|watch)
  help                       this help

Env:
  AON_ENGINE_DIR             engine repo path (auto-detected)
  AON_TEAM_DIR               per-team repo path (default: cwd)
EOF
}

cmd_init() {
  aon_load_config
  aon_info "aon init — team=$AON_TEAM_NAME engine=$AON_ENGINE_DIR"

  if [[ "$AON_TOML_PRESENT" -eq 0 ]]; then
    cp "$AON_ENGINE_DIR/templates/aon.toml.example" "$AON_TOML"
    aon_ok "wrote $AON_TOML (review + edit roster)"
    aon_load_config   # reload after creating
  else
    aon_ok "aon.toml present (schema=$AON_SCHEMA, $AON_ROLES_COUNT roles)"
  fi

  mkdir -p "$AON_TEAM_DIR/$AON_TASK_DIR"        \
           "$AON_TEAM_DIR/$AON_PROMPTS_DIR"     \
           "$AON_TEAM_DIR/$AON_AGENTS_DIR"      \
           "$AON_TEAM_DIR/$AON_HOOKS_DIR"       \
           "$AON_TEAM_DIR/nats"
  aon_ok "directory tree present"

  cat <<EOF >&2

Next steps:
  1. Edit $AON_TOML — set roster + NATS URLs.
  2. Render agent prompts:  aon prompts render
  3. Render auth.conf:      aon auth render && aon auth set-passwords
  4. Bring up NATS:         docker compose -f \$(aon engine path)/docker-compose.yml up -d
  5. Bootstrap streams:     aon bootstrap
  6. Verify:                aon doctor
EOF
}

cmd_add_role() {
  local name="${1:-}" kind="${2:-}" domain="${3:-}"
  [[ -n "$name" && -n "$kind" && -n "$domain" ]] || {
    aon_err "usage: aon add-role NAME KIND DOMAIN"
    aon_err "  KIND ∈ manager | generalist | specialist"
    return 2
  }
  case "$kind" in
    manager|generalist|specialist) ;;
    *) aon_fail "kind must be manager|generalist|specialist (got: $kind)" ;;
  esac

  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"

  # Detect existing role (idempotency).
  local i count
  count="$AON_ROLES_COUNT"
  for ((i=0; i<count; i++)); do
    if [[ "$(aon_toml_array_get "$AON_TOML" roles "$i" name)" == "$name" ]]; then
      aon_warn "role '$name' already in roster (index $i) — leaving as-is"
      return 0
    fi
  done

  cat >> "$AON_TOML" <<EOF

[[roles]]
name   = "$name"
kind   = "$kind"
domain = "$domain"
EOF
  aon_ok "appended role '$name' ($kind / $domain) to $AON_TOML"
  aon_warn "Templates not yet wired — run 'aon prompts render' + 'aon auth render' once Cards 234/235 land."
}

cmd_doctor() {
  aon_load_config
  local fail=0
  ok() { aon_ok "$*"; }
  bad() { aon_err "$*"; fail=1; }

  [[ "$AON_TOML_PRESENT" -eq 1 ]] && ok "aon.toml present" || bad "aon.toml missing — run 'aon init'"
  [[ -d "$AON_TEAM_DIR/$AON_TASK_DIR" ]]    && ok "$AON_TASK_DIR/ present"    || bad "$AON_TASK_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_PROMPTS_DIR" ]] && ok "$AON_PROMPTS_DIR/ present" || bad "$AON_PROMPTS_DIR/ missing"
  [[ -d "$AON_TEAM_DIR/$AON_AGENTS_DIR" ]]  && ok "$AON_AGENTS_DIR/ present"  || bad "$AON_AGENTS_DIR/ missing"

  if [[ "$AON_ROLES_COUNT" -gt 0 ]]; then
    ok "roster has $AON_ROLES_COUNT role(s)"
    local i name kind
    for ((i=0; i<AON_ROLES_COUNT; i++)); do
      name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
      kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
      printf '    - %-12s %s\n' "$name" "$kind" >&2
    done
  else
    bad "roster empty"
  fi

  if command -v nats >/dev/null 2>&1; then ok "nats CLI present"; else bad "nats CLI not on PATH"; fi
  if command -v jq   >/dev/null 2>&1; then ok "jq present";       else bad "jq not on PATH"; fi
  if command -v claude >/dev/null 2>&1; then ok "claude CLI present"; else bad "claude CLI not on PATH"; fi

  echo >&2
  if [[ "$fail" -eq 0 ]]; then
    aon_ok "PASS — local setup looks healthy."
    return 0
  else
    aon_err "FAIL — fix items above."
    return 1
  fi
}

cmd_prompts() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render) cmd_prompts_render "$@" ;;
    -h|--help|help|"") echo "Usage: aon prompts render" >&2 ;;
    *) aon_err "aon prompts: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_prompts_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local TPL="$AON_ENGINE_DIR/templates/agent-prompts"
  local OUT="$AON_TEAM_DIR/$AON_PROMPTS_DIR"
  mkdir -p "$OUT"

  # Render _common.md once, shared by all roles.
  aon_render "$TPL/_common.md.tmpl" "$OUT/_common.md" \
    "TEAM_NAME=$AON_TEAM_NAME" \
    "KV_BUCKET=$AON_TEAM_KV"
  aon_ok "rendered $OUT/_common.md"

  local i name kind domain learning title
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    title="$(printf '%s' "$name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
    [[ -f "$TPL/$kind.md.tmpl" ]] || { aon_warn "no template for kind=$kind ($name) — skipping"; continue; }
    aon_render "$TPL/$kind.md.tmpl" "$OUT/$name.md" \
      "ROLE=$name" \
      "ROLE_TITLE=$title" \
      "DOMAIN=$domain" \
      "LEARNING=${learning:-$domain}" \
      "TEAM_NAME=$AON_TEAM_NAME" \
      "KV_BUCKET=$AON_TEAM_KV"
    aon_ok "rendered $OUT/$name.md ($kind / $domain)"
  done
}

cmd_auth() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    render)        cmd_auth_render "$@" ;;
    set-passwords) cmd_auth_set_passwords "$@" ;;
    -h|--help|help|"") cat >&2 <<EOF
Usage: aon auth <render|set-passwords>
  render          render nats/auth.conf.example from aon.toml roster
  set-passwords   replace PASSWORD_* placeholders in auth.conf with random
                  per-user secrets; mapping written to nats/.passwords (chmod 600)
EOF
    ;;
    *) aon_err "aon auth: unknown subcommand: $sub"; return 2 ;;
  esac
}

cmd_auth_render() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local TPL="$AON_ENGINE_DIR/templates/auth"
  local OUT="$AON_TEAM_DIR/nats/auth.conf.example"
  mkdir -p "$(dirname "$OUT")"

  local TMP
  TMP="$(mktemp)"

  # Header
  sed "s|@TEAM_ACCOUNT@|$AON_TEAM_ACCOUNT|g" "$TPL/header.tmpl" > "$TMP"
  # sysadmin (always)
  cat "$TPL/sysadmin.tmpl" >> "$TMP"

  # Roles
  local i name kind domain learning title upper
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    kind="$(aon_toml_array_get "$AON_TOML" roles "$i" kind)"
    domain="$(aon_toml_array_get "$AON_TOML" roles "$i" domain)"
    learning="$(aon_toml_array_get "$AON_TOML" roles "$i" learning)"
    [[ -n "$name" && -n "$kind" ]] || continue
    [[ -f "$TPL/$kind.tmpl" ]] || { aon_warn "no auth template for kind=$kind ($name)"; continue; }
    title="$(printf '%s' "$name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
    upper="$(printf '%s' "$name" | tr '[:lower:]' '[:upper:]')"
    sed -e "s|@ROLE@|$name|g" \
        -e "s|@ROLE_TITLE@|$title|g" \
        -e "s|@ROLE_UPPER@|$upper|g" \
        -e "s|@DOMAIN@|$domain|g" \
        -e "s|@LEARNING@|${learning:-$domain}|g" \
        -e "s|@KV_BUCKET@|$AON_TEAM_KV|g" \
        "$TPL/$kind.tmpl" >> "$TMP"
  done

  # sys + footer
  cat "$TPL/sys.tmpl" >> "$TMP"
  cat "$TPL/footer.tmpl" >> "$TMP"

  install -m 0644 "$TMP" "$OUT"
  rm -f "$TMP"
  aon_ok "rendered $OUT ($AON_ROLES_COUNT roles + sysadmin + sys)"
  aon_info "Next: aon auth set-passwords  (substitutes PASSWORD_* placeholders)"
}

cmd_auth_set_passwords() {
  aon_load_config
  local SRC="$AON_TEAM_DIR/nats/auth.conf.example"
  local OUT="$AON_TEAM_DIR/nats/auth.conf"
  local PWFILE="$AON_TEAM_DIR/nats/.passwords"
  [[ -r "$SRC" ]] || aon_fail "no $SRC — run 'aon auth render' first"

  cp "$SRC" "$OUT"
  : > "$PWFILE"
  chmod 600 "$PWFILE"

  # Find all PASSWORD_<NAME> placeholders, generate one secret per unique
  # name. Sort by length descending so PASSWORD_SYSADMIN substitutes before
  # PASSWORD_SYS (otherwise sed s|PASSWORD_SYS|…| matches the longer
  # placeholder's prefix and leaves "<pw>ADMIN" garbage).
  local placeholders
  placeholders="$(grep -oE 'PASSWORD_[A-Z][A-Z0-9_]*' "$SRC" | sort -u | awk '{ print length, $0 }' | sort -rn | cut -d' ' -f2-)"
  [[ -n "$placeholders" ]] || aon_fail "no PASSWORD_* placeholders found in $SRC"

  local p who pw
  for p in $placeholders; do
    who="${p#PASSWORD_}"
    pw="$(openssl rand -hex 24)"
    # Substitute in-place; sed `|` delimiter to avoid hex collision.
    sed -i '' -e "s|$p|$pw|g" "$OUT"
    printf '%s=%s\n' "$who" "$pw" >> "$PWFILE"
  done
  aon_ok "wrote $OUT"
  aon_ok "wrote $PWFILE (chmod 600) — distribute via secret manager, never commit"
}

cmd_bootstrap() {
  aon_load_config
  [[ "$AON_TOML_PRESENT" -eq 1 ]] || aon_fail "no aon.toml — run 'aon init' first"
  [[ "$AON_ROLES_COUNT" -gt 0 ]]  || aon_fail "roster empty"

  local PWFILE="$AON_TEAM_DIR/nats/.passwords"
  [[ -r "$PWFILE" ]] || aon_fail "no $PWFILE — run 'aon auth set-passwords' first"

  # Build roster string from aon.toml roles.
  local roster=""
  local i name
  for ((i=0; i<AON_ROLES_COUNT; i++)); do
    name="$(aon_toml_array_get "$AON_TOML" roles "$i" name)"
    [[ -n "$name" ]] && roster+="${roster:+ }$name"
  done

  # Pull sysadmin pw.
  local SYS_PW
  SYS_PW="$(grep -E "^${AON_NATS_ADMIN^^}=" "$PWFILE" | cut -d= -f2-)"
  [[ -n "$SYS_PW" ]] || aon_fail "no ${AON_NATS_ADMIN^^}= entry in $PWFILE"

  local script="$AON_ENGINE_DIR/scripts/bootstrap.sh"
  [[ -x "$script" ]] || aon_fail "engine bootstrap not executable: $script"

  aon_info "aon bootstrap — team=$AON_TEAM_NAME url=$AON_NATS_URL roles=($roster)"
  AON_ROSTER="$roster" \
  AON_KV_BUCKET="$AON_TEAM_KV" \
  NATS_URL="$AON_NATS_URL" \
  NATS_ADMIN_USER="$AON_NATS_ADMIN" \
  NATS_ADMIN_PASSWORD="$SYS_PW" \
    bash "$script"
}

cmd_apparmor() {
  if [[ -x "$AON_ENGINE_DIR/bin/team-alpha-apparmor" ]]; then
    exec "$AON_ENGINE_DIR/bin/team-alpha-apparmor" "$@"
  else
    aon_fail "team-alpha-apparmor not found at $AON_ENGINE_DIR/bin/team-alpha-apparmor"
  fi
}

case "${1:-}" in
  init)      shift; cmd_init "$@" ;;
  add-role)  shift; cmd_add_role "$@" ;;
  doctor)    shift; cmd_doctor "$@" ;;
  prompts)   shift; cmd_prompts "$@" ;;
  auth)      shift; cmd_auth "$@" ;;
  bootstrap) shift; cmd_bootstrap "$@" ;;
  apparmor)  shift; cmd_apparmor "$@" ;;
  help|-h|--help) usage ;;
  "")        usage; exit 1 ;;
  *)         aon_err "unknown command: $1"; usage; exit 2 ;;
esac
