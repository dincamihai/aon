#!/usr/bin/env bash
# team-alpha-status — human-driven availability flag flipper.
#
# Updates KV team-state.agent.<your-role>.human and emits a live event so
# subscribed peers (notably Maya) see your status change in real time.
#
# Usage:
#   team-alpha-status available
#   team-alpha-status busy --reason "in meeting"
#   team-alpha-status offline
#   team-alpha-status delegated --scope go,terraform --until 2026-04-25T17:00:00Z
#   team-alpha-status                                # show current status
#
# Required env (same as rest of substrate):
#   AON_ROLE         your role
#   AON_NATS_URL     nats://...
#   AON_CREDS        path to your password file
set -eu

: "${AON_ROLE:?AON_ROLE not set}"
: "${AON_NATS_URL:?AON_NATS_URL not set}"
: "${AON_CREDS:?AON_CREDS not set}"
case " maya raj lin sam diego priya " in
  *" $AON_ROLE "*) ;;
  *) echo "AON_ROLE=$AON_ROLE invalid" >&2; exit 2 ;;
esac

PASS="$(tr -d '[:space:]' < "$AON_CREDS")"
NATS_BIN="${NATS_BIN:-nats}"
KEY="agent.$AON_ROLE.human"

nats_self() {
  "$NATS_BIN" --server "$AON_NATS_URL" --user "$AON_ROLE" \
    --password "$PASS" "$@"
}
ts_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# Show current.
if [ "$#" -eq 0 ]; then
  val=$(nats_self kv get team-state "$KEY" --raw 2>/dev/null || echo "{}")
  echo "$val" | jq . 2>/dev/null || echo "$val"
  exit 0
fi

STATUS="$1"; shift
case "$STATUS" in
  available|busy|offline|delegated) ;;
  *) echo "status must be available|busy|offline|delegated; got $STATUS" >&2; exit 2 ;;
esac

REASON=""
SCOPE=""
UNTIL=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --reason) REASON="${2:-}"; shift 2 ;;
    --scope)  SCOPE="${2:-}";  shift 2 ;;
    --until)  UNTIL="${2:-}";  shift 2 ;;
    *) echo "unknown flag: $1" >&2; exit 2 ;;
  esac
done

# Build payload.
JQ_ARGS=(--arg s "$STATUS" --arg t "$(ts_now)")
JQ_FILTER='{status:$s, since:$t}'
if [ -n "$REASON" ]; then
  JQ_ARGS+=(--arg r "$REASON"); JQ_FILTER="$JQ_FILTER + {reason:\$r}"
fi
if [ "$STATUS" = "delegated" ]; then
  if [ -n "$SCOPE" ]; then
    JQ_ARGS+=(--arg sc "$SCOPE")
    JQ_FILTER="$JQ_FILTER + {scope: (\$sc|split(\",\"))}"
  fi
  if [ -n "$UNTIL" ]; then
    JQ_ARGS+=(--arg u "$UNTIL"); JQ_FILTER="$JQ_FILTER + {until:\$u}"
  fi
fi

PAYLOAD=$(jq -nc "${JQ_ARGS[@]}" "$JQ_FILTER")

# Write KV (durable) + emit live event (subscribers see flip immediately).
echo -n "$PAYLOAD" | nats_self kv put team-state "$KEY" >/dev/null
nats_self pub "state.agent.$AON_ROLE.human" "$PAYLOAD" >/dev/null

echo "✓ $AON_ROLE.human → $PAYLOAD"
