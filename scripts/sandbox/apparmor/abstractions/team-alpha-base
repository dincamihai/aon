# team-alpha-base — shared rules for team-alpha roles (coord + workers).
# Installed at /etc/apparmor.d/abstractions/team-alpha-base.
# Path-based; arch-agnostic; works on arm64 + x86_64 Ubuntu LTS.

  #include <abstractions/base>
  #include <abstractions/consoles>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>
  #include <abstractions/ssl_certs>
  #include <abstractions/python>
  #include <abstractions/user-tmp>

  # Toolchain — inherit current profile so subprocesses stay confined.
  /usr/bin/git                     ix,
  /usr/bin/git-*                   ix,
  /usr/bin/node                    ix,
  /usr/bin/node[0-9]*              ix,
  /usr/bin/npm                     ix,
  /usr/bin/npx                     ix,
  /usr/bin/python3                 ix,
  /usr/bin/python3.[0-9]*          ix,
  /usr/bin/jq                      ix,
  /usr/bin/curl                    ix,
  /usr/bin/ssh                     ix,
  /usr/bin/bash                    ix,
  /usr/bin/sh                      ix,
  /usr/bin/cat                     ix,
  /usr/bin/grep                    ix,
  /usr/bin/sed                     ix,
  /usr/bin/awk                     ix,
  /usr/bin/find                    ix,
  /usr/bin/ls                      ix,
  /usr/local/bin/claude            ix,
  /usr/local/bin/team-alpha        ix,

  # Read-only system view.
  /etc/ssl/**                      r,
  /etc/ca-certificates/**          r,
  /etc/gitconfig                   r,
  /etc/nsswitch.conf               r,
  /etc/resolv.conf                 r,
  /etc/hosts                       r,
  /usr/**                          r,
  /lib/**                          r,
  /lib64/**                        r,
  /opt/**                          r,
  /proc/sys/kernel/random/uuid     r,
  /proc/cpuinfo                    r,
  /proc/meminfo                    r,
  /proc/loadavg                    r,
  /proc/version                    r,
  /sys/fs/cgroup/**                r,

  # Host repos (virtiofs from macOS) — ALLOWLIST MODE.
  # The shared abstraction does NOT grant a broad /Users/** r,. Operators
  # explicitly allow individual repos via personal overrides at
  # ~/.team-alpha/apparmor/{base,worker,coord}, generated by
  # `team-alpha-apparmor sync` from policy.toml's allow_orgs list.
  # Default = deny (no rule). New repos cloned to ~/Repos are invisible
  # to workers until policy is updated and sync re-runs.

  # Hard denies — fail closed even if a later rule would have allowed.
  deny /root/**                    rwklx,
  deny /home/*/.ssh/**             rwklx,
  deny /home/*/.gnupg/**           rwklx,
  deny /home/*/.aws/**             rwklx,
  deny /home/*/.kube/**            rwklx,
  deny /home/*/.docker/**          rwklx,
  deny /home/*/.npmrc              r,
  deny /home/*/.netrc              r,
  deny /etc/shadow                 r,
  deny /etc/gshadow                r,
  deny /etc/sudoers                r,
  deny /etc/sudoers.d/**           r,
  deny /var/log/**                 r,
  deny /var/spool/**               rwklx,
  deny /boot/**                    rwklx,
  deny /dev/sd*                    rwklx,
  deny /dev/nvme*                  rwklx,
  deny capability sys_admin,
  deny capability sys_module,
  deny capability sys_ptrace,
  deny capability dac_override,
  deny capability dac_read_search,
  deny mount,
  deny umount,
  deny ptrace,

  # Network — outbound TCP/UDP for git/HTTPS/NATS. nftables egress allowlist
  # narrows by host:port at a layer AppArmor can't see.
  network inet  stream,
  network inet  dgram,
  network inet6 stream,
  network inet6 dgram,
  network unix  stream,
  network unix  dgram,

  # Personal/local overrides. Empty by default. User-controlled path-allow
  # or path-deny rules go here, kept outside the repo. AppArmor unions allow+
  # deny; deny always wins, so this file can tighten the shared policy.
  # Edit on host: ~/.team-alpha/apparmor/base   →  /etc/apparmor.d/local/team-alpha-base
  #include if exists <local/team-alpha-base>
