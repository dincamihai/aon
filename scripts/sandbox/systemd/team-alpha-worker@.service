[Unit]
Description=team-alpha worker (%i)
After=network-online.target
# nats unit is masked under --external-nats; Wants= is the soft form
# so the dep is satisfied either way (in-VM unit OR external broker).
Wants=team-alpha-nats.service network-online.target

[Service]
Type=simple
User=ta-worker-%i
Group=team-alpha
WorkingDirectory=/work/workers/%i
# /etc/team-alpha/env carries TA_NATS_URL + AON_NATS_URL (set by
# install-in-vm.sh; either nats://127.0.0.1:4222 for in-VM broker
# or nats://host.lima.internal:4222 for external).
EnvironmentFile=/etc/team-alpha/env
Environment=AI_FLEET_BOX_ROLE=worker
Environment=AI_FLEET_WORKER_ID=%i
Environment=AON_ROLE=%i
ExecStart=/usr/local/bin/claude --dangerously-skip-permissions
Restart=on-failure
RestartSec=5

# AppArmor — kernel MAC. owner-match in the profile pins this UID to its
# own /work/workers/%i tree.
AppArmorProfile=team-alpha-worker

# DAC + namespace hardening.
ProtectSystem=strict
ProtectHome=tmpfs
InaccessiblePaths=/work/coord
ReadWritePaths=/work/workers/%i /var/lib/team-alpha/workers/%i /var/log/team-alpha
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
NoNewPrivileges=yes
RemoveIPC=yes
CapabilityBoundingSet=
AmbientCapabilities=
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @debug @mount @swap @reboot @raw-io @cpu-emulation @obsolete
SystemCallErrorNumber=EPERM

StandardOutput=append:/var/log/team-alpha/worker-%i.log
StandardError=append:/var/log/team-alpha/worker-%i.log

[Install]
WantedBy=multi-user.target
